# Local development only. For GitHub Pages, configure the same names in
# Settings > Secrets and variables > Actions > Variables.

# Optional. GitHub Actions can leave these empty because astro.config.mjs
# calculates them automatically for GitHub Pages.
ASTRO_SITE=https://jalonsomerchan.github.io
ASTRO_BASE=/menu-diario

# Optional repository link shown in the UI.
PUBLIC_REPOSITORY_URL=https://github.com/jalonsomerchan/menu-diario

# Firebase public web app config.
# These values are public identifiers, not private server secrets, but Firestore
# must still be protected with rules.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
