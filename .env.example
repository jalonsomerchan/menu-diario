# Override the default site URL if needed.
ASTRO_SITE=https://example.com

# Use / for root domains or /nombre-repo for subfolder deployments.
ASTRO_BASE=/

# Override the repository link shown in the UI.
PUBLIC_REPOSITORY_URL=https://github.com/jalonsomerchan/menu-diario

# Firebase public web app config. These are not secrets, but real secrets must never be committed.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
