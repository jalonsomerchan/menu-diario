rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && groupId is string
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isMemberDocument() {
      return signedIn() && request.auth.uid in resource.data.members;
    }

    function willBeMemberDocument() {
      return signedIn() && request.auth.uid in request.resource.data.members;
    }

    function createsOwnMemberDocument() {
      return signedIn() && request.auth.uid in request.resource.data.members;
    }

    function createsOwnMenu() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
    }

    function keepsExistingMembers() {
      return request.resource.data.members.hasAll(resource.data.members);
    }

    function joinsDocument() {
      return signedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && keepsExistingMembers();
    }

    function isGlobalDishData(data) {
      return data.scope == 'global' || data.isGlobal == true;
    }

    function isValidGlobalDishWrite(data) {
      return isGlobalDishData(data)
        && data.scope == 'global'
        && data.isGlobal == true
        && data.editable == false
        && data.source == 'admin'
        && data.groupId == null;
    }

    function isOwnPersonalDish(data) {
      return signedIn()
        && data.scope == 'user'
        && data.createdBy == request.auth.uid
        && request.auth.uid in data.members
        && data.isGlobal == false
        && data.editable == true;
    }

    function isGroupDishData(data) {
      return data.scope == 'group'
        && data.groupId is string
        && data.isGlobal == false
        && data.editable == true
        && request.auth.uid in data.members
        && isGroupMember(data.groupId);
    }

    function isShoppingListScope(data) {
      return (data.scope == 'user' && data.ownerId == request.auth.uid && data.groupId == null)
        || (data.scope == 'group' && data.groupId is string && isGroupMember(data.groupId));
    }

    function canAccessShoppingList(data) {
      return signedIn()
        && data.ownerId is string
        && (data.ownerId == request.auth.uid || (data.groupId is string && isGroupMember(data.groupId)));
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /weeklyMenus/{menuId} {
      allow create: if createsOwnMenu();
      allow read: if signedIn();
      allow update: if isMemberDocument() || joinsDocument();
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow create: if createsOwnMemberDocument() && request.resource.data.ownerId == request.auth.uid;
      allow read: if signedIn();
      allow update: if isMemberDocument() || joinsDocument();
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /dishes/{dishId} {
      allow read: if signedIn();
      allow create: if (isAdmin() && isValidGlobalDishWrite(request.resource.data))
        || isGroupDishData(request.resource.data)
        || isOwnPersonalDish(request.resource.data);
      allow update: if (isAdmin()
          && isValidGlobalDishWrite(resource.data)
          && isValidGlobalDishWrite(request.resource.data))
        || (!isGlobalDishData(resource.data)
          && !isGlobalDishData(request.resource.data)
          && (isGroupDishData(request.resource.data) || isOwnPersonalDish(request.resource.data)));
      allow delete: if false;
    }

    match /tuppers/{tupperId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow read: if signedIn();
      allow update: if isMemberDocument() || willBeMemberDocument();
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /shoppingLists/{listId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isShoppingListScope(request.resource.data);
      allow read: if canAccessShoppingList(resource.data);
      allow update: if canAccessShoppingList(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.rangeStart == resource.data.rangeStart
        && request.resource.data.rangeEnd == resource.data.rangeEnd
        && isShoppingListScope(request.resource.data);
      allow delete: if canAccessShoppingList(resource.data);
    }
  }
}
