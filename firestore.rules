rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isMemberDocument() {
      return signedIn() && request.auth.uid in resource.data.members;
    }

    function willBeMemberDocument() {
      return signedIn() && request.auth.uid in request.resource.data.members;
    }

    function createsOwnMenu() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
    }

    function keepsExistingMembers() {
      return request.resource.data.members.hasAll(resource.data.members);
    }

    function joinsDocument() {
      return signedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && keepsExistingMembers();
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /weeklyMenus/{menuId} {
      allow create: if createsOwnMenu();
      allow read: if signedIn();
      allow update: if isMemberDocument() || joinsDocument();
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /dishes/{dishId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow read: if signedIn();
      allow update: if isMemberDocument() || willBeMemberDocument();
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
