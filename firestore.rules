rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserGroupId() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId
        : null;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && groupId is string
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isSharedGroupOwnerMenu() {
      let groupId = currentUserGroupId();
      return signedIn()
        && groupId is string
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members
        && resource.data.ownerId == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId;
    }

    function canReadUserProfile(userId) {
      return isSelf(userId) || (resource.data.groupId is string && isGroupMember(resource.data.groupId));
    }

    function isMemberDocument() {
      return signedIn() && request.auth.uid in resource.data.members;
    }

    function willBeMemberDocument() {
      return signedIn() && request.auth.uid in request.resource.data.members;
    }

    function createsOwnMemberDocument() {
      return signedIn() && request.auth.uid in request.resource.data.members;
    }

    function createsOwnMenu() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
    }

    function keepsExistingMembers() {
      return request.resource.data.members.hasAll(resource.data.members);
    }

    function joinsDocument() {
      return signedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && keepsExistingMembers();
    }

    function changesOnlyFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function updatesMenuContent() {
      return (isMemberDocument() || isSharedGroupOwnerMenu())
        && request.resource.data.members == resource.data.members
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.groupId == resource.data.groupId
        && changesOnlyFields(['days', 'updatedAt', 'updatedBy']);
    }

    function joinsMenuDocument() {
      return joinsDocument()
        && changesOnlyFields(['members', 'updatedAt', 'updatedBy']);
    }

    function createsSharedGroupMenu() {
      let groupId = currentUserGroupId();
      return signedIn()
        && groupId is string
        && request.resource.data.groupId == groupId
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members
        && request.resource.data.ownerId == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
        && request.resource.data.members.hasAll(get(/databases/$(database)/documents/groups/$(groupId)).data.members)
        && get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAll(request.resource.data.members);
    }

    function syncsSharedMenuMembership() {
      let groupId = currentUserGroupId();
      return isSharedGroupOwnerMenu()
        && groupId is string
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.groupId == groupId
        && request.resource.data.days == resource.data.days
        && request.resource.data.members.hasAll(get(/databases/$(database)/documents/groups/$(groupId)).data.members)
        && get(/databases/$(database)/documents/groups/$(groupId)).data.members.hasAll(request.resource.data.members)
        && changesOnlyFields(['members', 'groupId', 'updatedAt', 'updatedBy']);
    }

    function isGlobalDishData(data) {
      return data.scope == 'global' || data.isGlobal == true;
    }

    function isValidGlobalDishWrite(data) {
      return isGlobalDishData(data)
        && data.scope == 'global'
        && data.isGlobal == true
        && data.editable == false
        && data.source == 'admin'
        && data.groupId == null;
    }

    function isOwnPersonalDish(data) {
      return signedIn()
        && data.scope == 'user'
        && data.createdBy == request.auth.uid
        && request.auth.uid in data.members
        && data.isGlobal == false
        && data.editable == true;
    }

    function isGroupDishData(data) {
      return data.scope == 'group'
        && data.groupId is string
        && data.isGlobal == false
        && data.editable == true
        && isGroupMember(data.groupId);
    }

    function keepsGroupDishScope() {
      return resource.data.scope == 'group'
        && request.resource.data.scope == 'group'
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.isGlobal == resource.data.isGlobal
        && request.resource.data.editable == resource.data.editable;
    }

    function isShoppingListScope(data) {
      return (data.scope == 'user' && data.ownerId == request.auth.uid && data.groupId == null)
        || (data.scope == 'group' && data.groupId is string && isGroupMember(data.groupId));
    }

    function canAccessShoppingList(data) {
      return signedIn()
        && data.ownerId is string
        && (data.ownerId == request.auth.uid || (data.groupId is string && isGroupMember(data.groupId)));
    }

    function canAccessTupper(data) {
      return signedIn()
        && (
          request.auth.uid in data.members
          || (data.groupId is string && isGroupMember(data.groupId))
        );
    }

    function isDailyOptionScope(data) {
      return signedIn()
        && (
          (data.scope == 'user'
            && data.ownerId == request.auth.uid
            && data.groupId == null
            && request.auth.uid in data.members)
          || (data.scope == 'group'
            && data.groupId is string
            && data.ownerId == data.groupId
            && isGroupMember(data.groupId))
        );
    }

    function canAccessDailyOption(data) {
      return signedIn()
        && (
          request.auth.uid in data.members
          || (data.groupId is string && isGroupMember(data.groupId))
        );
    }

    function isValidTupperCreate(data) {
      return signedIn()
        && data.createdBy == request.auth.uid
        && request.auth.uid in data.members
        && (
          data.groupId == null
          || (data.groupId is string && isGroupMember(data.groupId))
        );
    }

    match /users/{userId} {
      allow read: if canReadUserProfile(userId);
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /weeklyMenus/{menuId} {
      allow create: if createsOwnMenu() || createsSharedGroupMenu();
      allow read: if isMemberDocument() || isSharedGroupOwnerMenu();
      allow update: if updatesMenuContent() || joinsMenuDocument() || syncsSharedMenuMembership();
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow create: if createsOwnMemberDocument() && request.resource.data.ownerId == request.auth.uid;
      allow read: if signedIn();
      allow update: if isMemberDocument() || joinsDocument();
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /dishes/{dishId} {
      allow read: if signedIn();
      allow create: if (isAdmin() && isValidGlobalDishWrite(request.resource.data))
        || isGroupDishData(request.resource.data)
        || isOwnPersonalDish(request.resource.data);
      allow update: if (isAdmin()
          && isValidGlobalDishWrite(resource.data)
          && isValidGlobalDishWrite(request.resource.data))
        || (!isGlobalDishData(resource.data)
          && !isGlobalDishData(request.resource.data)
          && ((keepsGroupDishScope() && isGroupDishData(resource.data) && isGroupDishData(request.resource.data))
            || isOwnPersonalDish(request.resource.data)));
      allow delete: if false;
    }

    match /dailyOptions/{optionId} {
      allow read: if canAccessDailyOption(resource.data);
      allow create: if isDailyOptionScope(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canAccessDailyOption(resource.data)
        && isDailyOptionScope(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.groupId == resource.data.groupId;
      allow delete: if canAccessDailyOption(resource.data);
    }

    match /tuppers/{tupperId} {
      allow create: if isValidTupperCreate(request.resource.data);
      allow read: if canAccessTupper(resource.data);
      allow update: if canAccessTupper(resource.data) || canAccessTupper(request.resource.data);
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /shoppingLists/{listId} {
      allow get, list: if canAccessShoppingList(resource.data);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isShoppingListScope(request.resource.data);
      allow update: if canAccessShoppingList(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.groupId == resource.data.groupId
        && isShoppingListScope(request.resource.data);
      allow delete: if canAccessShoppingList(resource.data);
    }
  }
}
