---
import Button from './Button.astro';
import Breadcrumb from './Breadcrumb.astro';
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { usePublicPageCopy } from '../i18n/public-pages';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tp = usePublicPageCopy(locale);
const t = useTranslations(locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const values = [tp('aboutValueSimple'), tp('aboutValueGroup'), tp('aboutValueHistory'), tp('aboutValueMobile')];
---

<Container class="public-about-container" size="page">
  <Breadcrumb locale={locale} rootItem={{ label: t('nav.home'), href: getLocalizedPath('/', locale) }} items={[{ label: tp('aboutTitle') }]} />
  <article class="about-page">
    <header class="about-page__hero">
      <p class="about-page__eyebrow">{tp('aboutEyebrow')}</p>
      <h1>{tp('aboutTitle')}</h1>
      <p>{tp('aboutIntro')}</p>
      <div class="about-page__actions" aria-label={tp('aboutCtaTitle')}>
        <Button href={dashboardPath}>{tp('aboutPrimaryCta')}</Button>
        <Button href={siteConfig.repositoryUrl} variant="secondary">{tp('aboutSecondaryCta')}</Button>
      </div>
    </header>

    <section class="about-page__grid" aria-labelledby="about-who-title">
      <div class="about-page__panel">
        <h2 id="about-who-title">{tp('aboutWhoTitle')}</h2>
        <p>{tp('aboutWhoDescription')}</p>
      </div>

      <div class="about-page__panel">
        <h2>{tp('aboutValuesTitle')}</h2>
        <ul class="about-page__list">
          {values.map((value) => <li>{value}</li>)}
        </ul>
      </div>
    </section>

    <section class="about-page__panel about-page__panel--wide" aria-labelledby="about-practical-title">
      <h2 id="about-practical-title">{tp('aboutPrivacyTitle')}</h2>
      <p>{tp('aboutPrivacyDescription')}</p>
    </section>

    <section class="about-page__cta" aria-labelledby="about-cta-title">
      <div>
        <h2 id="about-cta-title">{tp('aboutCtaTitle')}</h2>
        <p>{tp('aboutCtaDescription')}</p>
      </div>
      <Button href={dashboardPath}>{tp('aboutPrimaryCta')}</Button>
    </section>
  </article>
</Container>

<style>
  .public-about-container {
    padding-block: clamp(2rem, 7vw, 4.5rem);
  }

  .about-page {
    display: grid;
    gap: clamp(1rem, 3vw, 1.5rem);
  }

  .about-page__hero,
  .about-page__panel,
  .about-page__cta {
    border: 1px solid var(--panel-border);
    border-radius: clamp(1.3rem, 4vw, 2.35rem);
    background: var(--panel-background);
    box-shadow: var(--shadow-sm);
  }

  .about-page__hero {
    display: grid;
    justify-items: center;
    gap: 1.2rem;
    padding: clamp(2.8rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    text-align: center;
  }

  .about-page__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    font-weight: 380;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .about-page h1,
  .about-page h2,
  .about-page p {
    margin: 0;
  }

  .about-page h1 {
    max-width: 12ch;
    color: var(--color-text);
    font-size: clamp(2.75rem, 8vw, 5.2rem);
    font-weight: 620;
    line-height: 0.95;
    letter-spacing: -0.085em;
  }

  .about-page__hero > p {
    max-width: 46rem;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 420;
    letter-spacing: -0.035em;
    line-height: 1.42;
  }

  .about-page h2 {
    color: var(--color-text);
    font-size: clamp(1.55rem, 4.5vw, 2.5rem);
    font-weight: 610;
    line-height: 0.98;
    letter-spacing: -0.075em;
  }

  .about-page p,
  .about-page li {
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.7vw, 1.08rem);
    font-weight: 420;
    letter-spacing: -0.025em;
    line-height: 1.55;
  }

  .about-page__actions,
  .about-page__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .about-page__grid {
    display: grid;
    gap: 1rem;
  }

  .about-page__panel {
    display: grid;
    gap: 1rem;
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  .about-page__list {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .about-page__list li {
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 14%);
    color: var(--color-text);
    padding: 1rem;
  }

  .about-page__cta {
    justify-content: space-between;
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  .about-page__cta div {
    display: grid;
    gap: 0.55rem;
    min-width: min(100%, 24rem);
  }

  @media (min-width: 760px) {
    .about-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
