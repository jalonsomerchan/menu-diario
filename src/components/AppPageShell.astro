---
import type { Locale } from '../config/site';
import Breadcrumb from './Breadcrumb.astro';
import Container from './Container.astro';
import PageHeader from './PageHeader.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  showHeader?: boolean;
}

const { locale, title, description, showHeader = true } = Astro.props;
---

<Container class="app-page-shell" size="page">
  <Breadcrumb locale={locale} items={[{ label: title }]} />
  {showHeader && <PageHeader title={title} description={description} />}
  <slot />
</Container>
