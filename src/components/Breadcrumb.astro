---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  locale: Locale;
  items: BreadcrumbItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/dashboard', locale);
const homeLabel = t('appNav.dashboard');
---

<nav class="breadcrumb" aria-label={t('breadcrumb.label')}>
  <ol class="breadcrumb__list">
    <li class="breadcrumb__item">
      <a class="breadcrumb__link" href={homePath}>{homeLabel}</a>
    </li>
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li class="breadcrumb__item" aria-current={isLast ? 'page' : undefined}>
          {item.href && !isLast ? (
            <a class="breadcrumb__link" href={item.href}>{item.label}</a>
          ) : (
            <span class="breadcrumb__current">{item.label}</span>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumb {
    margin-bottom: 0.75rem;
  }

  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.84rem;
    font-weight: 800;
  }

  .breadcrumb__item + .breadcrumb__item::before {
    content: '/';
    color: var(--color-border-strong);
    font-weight: 600;
  }

  .breadcrumb__link {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .breadcrumb__link:hover,
  .breadcrumb__link:focus-visible {
    color: var(--color-primary);
  }

  .breadcrumb__current {
    color: var(--color-text);
  }
</style>
