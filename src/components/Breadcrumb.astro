---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  locale: Locale;
  items: BreadcrumbItem[];
  rootItem?: BreadcrumbItem;
}

const { locale, items, rootItem } = Astro.props;
const t = useTranslations(locale);
const defaultRootItem: BreadcrumbItem = {
  href: getLocalizedPath('/dashboard', locale),
  label: t('appNav.dashboard'),
};
const firstItem = rootItem ?? defaultRootItem;
const hasOnlyRoot = items.length === 0;
---

<nav class="breadcrumb" aria-label={t('breadcrumb.label')}>
  <ol class="breadcrumb__list">
    <li class="breadcrumb__item" aria-current={hasOnlyRoot ? 'page' : undefined}>
      {firstItem.href && !hasOnlyRoot ? (
        <a class="breadcrumb__link" href={firstItem.href}>{firstItem.label}</a>
      ) : (
        <span class="breadcrumb__current">{firstItem.label}</span>
      )}
    </li>
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li class="breadcrumb__item" aria-current={isLast ? 'page' : undefined}>
          {item.href && !isLast ? (
            <a class="breadcrumb__link" href={item.href}>{item.label}</a>
          ) : (
            <span class="breadcrumb__current">{item.label}</span>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumb {
    margin-bottom: 0.85rem;
  }

  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.01em;
  }

  .breadcrumb__item + .breadcrumb__item::before {
    content: '›';
    color: var(--color-muted);
    font-weight: 600;
  }

  .breadcrumb__link {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .breadcrumb__link:hover,
  .breadcrumb__link:focus-visible {
    color: var(--color-primary);
  }

  .breadcrumb__current {
    color: var(--color-text);
  }
</style>
