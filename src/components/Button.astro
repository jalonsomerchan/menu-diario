---
const {
  href,
  variant = 'primary',
  class: className = '',
  ...attrs
} = Astro.props;

const classes = [
  'button',
  'button--small',
  variant === 'secondary'
    ? 'button--secondary'
    : 'button--primary',
  className,
];
---

{href ? (
  <a href={href} class:list={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button class:list={classes} {...attrs}>
    <slot />
  </button>
)}
