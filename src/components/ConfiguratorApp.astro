---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import EmptyState from './EmptyState.astro';
import InlineHint from './InlineHint.astro';
import { usePlanningTranslations } from '../i18n/planning';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  configure: tp('title'),
  configureHint: tp('hint'),
  cancel: t('dashboard.cancel'),
  save: t('dashboard.save'),
  deleteDay: t('dashboard.deleteDay'),
  editDay: t('dashboard.editDay'),
  loadMoreDays: t('dashboard.nextSeven'),
  aiLoading: t('ai.loading'),
  aiError: t('ai.error'),
  aiMissingConfig: t('ai.missingConfig'),
  aiPendingTitle: t('ai.pendingMealsTitle'),
  aiPendingDescription: t('ai.pendingMealsDescription'),
  aiPendingHint: t('ai.pendingMealsHint'),
  aiPendingGenerate: t('ai.pendingMealsGenerate'),
  aiPendingEmpty: t('ai.pendingMealsEmpty'),
  aiPendingNoCatalog: t('ai.pendingMealsNoCatalog'),
  aiPendingNoResults: t('ai.pendingMealsNoResults'),
  aiPendingApply: t('ai.pendingMealsApply'),
  aiPendingAddDish: t('ai.pendingMealsAddDish'),
  aiPendingApplied: t('ai.pendingMealsApplied'),
  aiPendingDishAdded: t('ai.pendingMealsDishAdded'),
  aiPendingMealLabel: t('ai.pendingMealsMealLabel'),
  aiPendingReasonLabel: t('ai.pendingMealsReasonLabel'),
  aiPendingDishOriginGlobal: t('ai.pendingMealsDishOriginGlobal'),
  aiPendingDishOriginGroup: t('ai.pendingMealsDishOriginGroup'),
  aiPendingDishOriginUser: t('ai.pendingMealsDishOriginUser'),
  'ai.loading': t('ai.loading'),
  'ai.error': t('ai.error'),
  'ai.quotaExhausted': t('ai.quotaExhausted'),
  'ai.missingConfig': t('ai.missingConfig'),
  'ai.appCheckUnavailable': t('ai.appCheckUnavailable'),
  'ai.invalidResponse': t('ai.invalidResponse'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  todayEmpty: t('dashboard.todayEmpty'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  noMeal: t('dashboard.noMeal'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  offlineReadOnly: t('pwa.offlineReadOnly'),
  tuppers: tt('nav'),
  shopping: t('appNav.shopping'),
  homePath,
};
---

<section class="configurator-app" data-configurator-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <section class="dashboard-section app-panel ai-meals-panel" aria-labelledby="ai-pending-meals-title">
      <div class="section-heading section-heading--simple ai-meals-panel__header">
        <div>
          <p class="menu-app__eyebrow">{labels.aiPendingHint}</p>
          <h2 id="ai-pending-meals-title">{labels.aiPendingTitle}</h2>
          <p>{labels.aiPendingDescription}</p>
        </div>
        <button class="button button--primary button--small" type="button" data-ai-generate>
          {labels.aiPendingGenerate}
        </button>
      </div>
      <InlineHint text={t('emptyStates.aiHint')} />
      <p class="ai-meals-panel__helper" data-ai-helper>{labels.aiPendingHint}</p>
      <div class="ai-meals-panel__status" data-ai-status role="status" aria-live="polite"></div>
      <div class="ai-meals-panel__results" data-ai-results>
        <EmptyState
          title={t('emptyStates.aiEmptyTitle')}
          description={t('emptyStates.aiEmptyDescription')}
          actionLabel={t('emptyStates.addDishAction')}
          actionHref={getLocalizedPath('/mis-platos', locale)}
          icon="✨"
        />
      </div>
    </section>

    <section id="configurador" class="dashboard-section app-panel configurator-planner-panel">
      <div class="section-heading section-heading--simple">
        <div>
          <p class="menu-app__eyebrow">{labels.configureHint}</p>
          <h1>{labels.configure}</h1>
        </div>
        <div class="configurator-planner-panel__actions">
          <a class="button button--ghost button--small" href={shoppingPath}>{labels.shopping}</a>
          <a class="button button--ghost button--small" href={tuppersPath}>{labels.tuppers}</a>
        </div>
      </div>
      <div class="menu-days menu-days--cards" data-config-days>
        <EmptyState
          title={t('emptyStates.configuratorTitle')}
          description={t('emptyStates.configuratorDescription')}
          icon="🗓️"
        />
      </div>
      <div class="configurator-app__load-more">
        <button class="button button--secondary" type="button" data-config-load-more>
          {labels.loadMoreDays}
        </button>
      </div>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.configureHint}
    title={labels.configure}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .configurator-app .plate-row {
    align-items: start;
  }

  .configurator-app .plate-row label {
    position: relative;
    gap: 0.35rem;
  }

  .configurator-planner-panel {
    display: grid;
    gap: 1rem;
    background: var(--panel-background);
  }

  .configurator-planner-panel .section-heading {
    margin-bottom: 0.15rem;
  }

  .configurator-planner-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .configurator-planner-panel .menu-days--cards {
    gap: 0.9rem;
  }

  .configurator-app .dish-combobox {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2.85rem;
    width: 100%;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff, transparent 90%);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .configurator-app .dish-combobox:focus-within {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 28%);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--color-primary), transparent 82%),
      inset 0 1px 0 color-mix(in srgb, #fff, transparent 92%);
  }

  .configurator-app .dish-combobox input {
    min-height: 3rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0.72rem 0.9rem;
    font-size: 1rem;
    font-weight: 850;
    outline: 0;
  }

  .configurator-app .dish-combobox__toggle {
    display: grid;
    min-width: 2.85rem;
    place-items: center;
    border: 0;
    border-left: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    background: color-mix(in srgb, var(--color-surface-raised), var(--color-surface-soft) 42%);
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 950;
    transition:
      background var(--transition-base),
      color var(--transition-base);
  }

  .configurator-app .dish-combobox__toggle:hover,
  .configurator-app .dish-combobox__toggle:focus-visible {
    background: color-mix(in srgb, var(--color-primary-soft), transparent 30%);
    color: var(--color-primary);
    outline: 0;
  }

  .configurator-app .dish-combobox__toggle[aria-expanded='true'] {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }
</style>

<script>
  import '../scripts/configurator-app.ts';
</script>