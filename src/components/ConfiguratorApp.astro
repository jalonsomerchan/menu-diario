---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { usePlanningTranslations } from '../i18n/planning';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import '../styles/history.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const planningPath = getLocalizedPath('/planificador-ai', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  configure: t('dashboard.configure'),
  configureHint: t('dashboard.configureHint'),
  configureDescription: t('dashboard.configureDescription'),
  todayShort: t('dashboard.todayShort'),
  planning: tp('nav'),
  planningTitle: tp('title'),
  planningHint: tp('hint'),
  cancel: t('dashboard.cancel'),
  saveChanges: t('dashboard.saveChanges'),
  deleteDay: t('dashboard.deleteDay'),
  deleteMenu: t('dashboard.deleteMenu'),
  editDay: t('dashboard.editDay'),
  configureDay: t('dashboard.configureDay'),
  editDayDescription: t('dashboard.editDayDescription'),
  plannedStatus: t('dashboard.plannedStatus'),
  moreActions: t('dashboard.moreActions'),
  loadMoreDays: t('dashboard.nextSeven'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  todayEmpty: t('dashboard.todayEmpty'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  dailyOptionsTitle: t('dailyOptions.dayTitle'),
  dailyOptionsDescription: t('dailyOptions.dayDescription'),
  dailyOptionsSummary: t('dailyOptions.summaryLabel'),
  noMeal: t('dashboard.noMeal'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  participants: t('group.members'),
  participantsAll: t('history.statusAll'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  tuppers: tt('nav'),
  shopping: t('appNav.shopping'),
  dashboard: t('appNav.dashboard'),
  planningPath,
  homePath,
};
---

<section class="configurator-app" data-configurator-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <header class="configurator-page-header app-page-intro app-panel">
      <div class="configurator-page-header__copy app-page-intro__copy">
        <h1>{labels.configure}</h1>
        <p>{labels.configureDescription}</p>
      </div>
      <div class="app-page-intro__actions">
        <a class="button button--primary" href={planningPath}>{labels.planning}</a>
      </div>
    </header>

    <section id="configurador" class="dashboard-section app-panel configurator-planner-panel">
      <div class="menu-days menu-days--cards" data-config-days></div>
      <div class="configurator-app__load-more">
        <button class="button button--secondary" type="button" data-config-load-more>
          {labels.loadMoreDays}
        </button>
      </div>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.configureHint}
    title={labels.configureDay}
    subtitle={labels.editDayDescription}
    cancelLabel={labels.cancel}
    saveLabel={labels.saveChanges}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .configurator-app .plate-row {
    align-items: start;
  }

  .configurator-app .plate-row label {
    position: relative;
    gap: 0.35rem;
  }

  .configurator-planner-panel {
    display: grid;
    gap: 1rem;
    border: 0;
    background: transparent;
    padding: 0;
    box-shadow: none;
  }

  .configurator-planner-panel .menu-days--cards {
    gap: 1rem;
  }

  .configurator-app .history-card.configurator-day-card {
    min-height: 7.75rem;
    border-color: var(--color-border);
    background: var(--color-surface);
    box-shadow: none;
  }

  .configurator-app .history-card.configurator-day-card--today {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 52%);
    background: color-mix(in srgb, var(--color-primary-soft), var(--color-surface) 92%);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-primary), transparent 72%);
  }

  .configurator-app .configurator-day-card .history-card__body {
    gap: 0.5rem;
  }

  .configurator-app .configurator-day-card .history-card__date {
    align-content: center;
    gap: 0.1rem;
    padding-inline: 1rem 0.9rem;
  }

  .configurator-app .configurator-day-card--today .history-card__date {
    background: color-mix(in srgb, var(--color-primary-soft), transparent 58%);
  }

  .configurator-app .configurator-day-card .history-card__today {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .configurator-app .configurator-day-card .history-card__weekday {
    font-size: clamp(1.02rem, 2.3vw, 1.15rem);
    font-weight: 620;
  }

  .configurator-app .configurator-day-card--today .history-card__weekday {
    color: var(--color-primary);
  }

  .configurator-app .configurator-day-card .history-card__month {
    color: var(--color-muted);
    font-size: clamp(0.82rem, 1.6vw, 0.95rem);
    font-weight: 700;
  }

  .configurator-app .configurator-day-card .history-card__day-number {
    font-size: clamp(1.95rem, 4vw, 2.25rem);
    line-height: 0.92;
  }

  .configurator-app .configurator-day-card .day-meal-row {
    border-radius: var(--radius-lg);
    padding: 0;
  }

  .configurator-app .configurator-day-card .day-meal-row span {
    font-size: 0.78rem;
  }

  .configurator-app .configurator-day-card .day-meal-row strong {
    font-size: clamp(0.98rem, 2.3vw, 1.12rem);
    font-weight: 760;
    line-height: 1.14;
  }

  .configurator-app .configurator-day-card .meal-participants-summary {
    min-height: 1.45rem;
    padding: 0.18rem 0.6rem;
    font-size: 0.72rem;
  }

  .configurator-app .configurator-day-card .day-card-primary-action--edit {
    width: 2.2rem;
    height: 2.2rem;
  }

  .configurator-app__load-more {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .configurator-app__load-more .button {
    min-width: min(100%, 14rem);
  }

  @media (min-width: 720px) {
    .configurator-page-header .button {
      margin-top: 0.15rem;
    }
  }

  @media (max-width: 520px) {
    .configurator-app .history-card.configurator-day-card {
      min-height: 7.4rem;
    }

    .configurator-app .configurator-day-card .history-card__date {
      padding-inline: 0.85rem 0.7rem;
    }
  }
</style>

<script>
  import { installDetailsMenuAutoClose } from '../lib/ui/details-menu';
  import '../scripts/configurator-app.ts';

  installDetailsMenuAutoClose(document);
</script>
