---
import type { Locale } from '../config/site';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  configure: t('dashboard.configure'),
  configureHint: t('dashboard.configureHint'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  noMeal: t('dashboard.noMeal'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  offlineReadOnly: t('pwa.offlineReadOnly'),
  tuppers: tt('nav'),
  homePath,
};
---

<section class="configurator-app" data-configurator-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <section id="configurador" class="dashboard-section">
      <div class="section-heading section-heading--simple">
        <div>
          <p class="menu-app__eyebrow">{labels.configureHint}</p>
          <h1>{labels.configure}</h1>
        </div>
        <a class="button button--ghost button--small" href={tuppersPath}>{labels.tuppers}</a>
      </div>
      <div class="menu-days menu-days--cards" data-config-days></div>
    </section>
  </div>
</section>

<style is:global>
  .configurator-app .plate-row {
    align-items: start;
  }

  .configurator-app .plate-row label {
    position: relative;
    gap: 0.35rem;
  }

  .configurator-app .dish-combobox {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2.85rem;
    width: 100%;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff, transparent 90%);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .configurator-app .dish-combobox:focus-within {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 28%);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--color-primary), transparent 82%),
      inset 0 1px 0 color-mix(in srgb, #fff, transparent 92%);
  }

  .configurator-app .dish-combobox input {
    min-height: 3rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0.72rem 0.9rem;
    font-size: 1rem;
    font-weight: 850;
    outline: 0;
  }

  .configurator-app .dish-combobox__toggle {
    display: grid;
    min-width: 2.85rem;
    place-items: center;
    border: 0;
    border-left: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    background: color-mix(in srgb, var(--color-surface-raised), var(--color-surface-soft) 42%);
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 950;
    transition:
      background var(--transition-base),
      color var(--transition-base);
  }

  .configurator-app .dish-combobox__toggle:hover,
  .configurator-app .dish-combobox__toggle:focus-visible {
    background: var(--color-primary-soft);
    color: var(--color-primary);
    outline: 0;
  }

  .configurator-app .dish-suggestions {
    position: relative;
    z-index: 20;
    display: grid;
    gap: 0.1rem;
    width: 100%;
    max-height: 11rem;
    overflow-y: auto;
    margin-top: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--color-primary), var(--color-border) 74%);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    box-shadow: 0 16px 34px rgb(15 23 42 / 0.14);
    padding: 0.3rem;
  }

  .configurator-app .dish-suggestions[hidden] {
    display: none;
  }

  .configurator-app .dish-suggestions button {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 2.55rem;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text);
    padding: 0.58rem 0.72rem;
    text-align: left;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .configurator-app .dish-suggestions button:hover,
  .configurator-app .dish-suggestions button:focus-visible {
    background: var(--color-primary-soft);
    color: var(--color-primary);
    outline: 0;
  }
</style>
