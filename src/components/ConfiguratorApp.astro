---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { usePlanningTranslations } from '../i18n/planning';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import '../styles/history.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const planningPath = getLocalizedPath('/planificador-ai', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  configure: t('dashboard.configure'),
  configureHint: t('dashboard.configureHint'),
  configureDescription: t('dashboard.configureDescription'),
  planning: tp('nav'),
  planningTitle: tp('title'),
  planningHint: tp('hint'),
  cancel: t('dashboard.cancel'),
  save: t('dashboard.save'),
  deleteDay: t('dashboard.deleteDay'),
  editDay: t('dashboard.editDay'),
  loadMoreDays: t('dashboard.nextSeven'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  todayEmpty: t('dashboard.todayEmpty'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  noMeal: t('dashboard.noMeal'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  participants: t('group.members'),
  participantsAll: t('history.statusAll'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  offlineReadOnly: t('pwa.offlineReadOnly'),
  tuppers: tt('nav'),
  shopping: t('appNav.shopping'),
  dashboard: t('appNav.dashboard'),
  planningPath,
  homePath,
};
---

<section class="configurator-app" data-configurator-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <header class="configurator-page-header">
      <div class="configurator-page-header__copy">
        <h1>{labels.configure}</h1>
        <p>{labels.configureDescription}</p>
      </div>
      <a class="button button--primary" href={planningPath}>{labels.planning}</a>
    </header>

    <section id="configurador" class="dashboard-section app-panel configurator-planner-panel">
      <div class="menu-days menu-days--cards" data-config-days></div>
      <div class="configurator-app__load-more">
        <button class="button button--secondary" type="button" data-config-load-more>
          {labels.loadMoreDays}
        </button>
      </div>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.configureHint}
    title={labels.configure}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .configurator-app .plate-row {
    align-items: start;
  }

  .configurator-app .plate-row label {
    position: relative;
    gap: 0.35rem;
  }

  .configurator-page-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .configurator-page-header__copy {
    display: grid;
    gap: 0.55rem;
  }

  .configurator-page-header h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 0.94;
    letter-spacing: -0.07em;
  }

  .configurator-page-header p {
    margin: 0;
    max-width: 72ch;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.4vw, 1.15rem);
    line-height: var(--surface-copy-line-height);
    letter-spacing: var(--surface-copy-letter-spacing);
  }

  .configurator-planner-panel {
    display: grid;
    gap: 1rem;
    background: var(--panel-background);
  }

  .configurator-planner-panel .menu-days--cards {
    gap: 1rem;
  }

  .configurator-app__load-more {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .configurator-app__load-more .button {
    min-width: min(100%, 14rem);
  }

  @media (min-width: 720px) {
    .configurator-page-header {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }

    .configurator-page-header .button {
      margin-top: 0.15rem;
    }
  }
</style>

<script>
  import { installDetailsMenuAutoClose } from '../lib/ui/details-menu';
  import '../scripts/configurator-app.ts';

  installDetailsMenuAutoClose(document);
</script>