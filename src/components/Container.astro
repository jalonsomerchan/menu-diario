---
interface Props {
  class?: string;
  size?: 'page' | 'content' | 'narrow';
}

const { class: className = '', size = 'page' } = Astro.props;

const sizeClass =
  size === 'narrow'
    ? 'container-shell--narrow'
    : size === 'content'
      ? 'container-shell--content'
      : 'container-shell--page';
---

<div class:list={['container-shell', sizeClass, className]}>
  <slot />
</div>
