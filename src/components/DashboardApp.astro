---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import '../styles/history.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  enableNotifications: t('menu.enableNotifications'),
  notificationsEnabled: t('menu.notificationsEnabled'),
  notificationsDenied: t('menu.notificationsDenied'),
  dashboardTitle: t('dashboard.title'),
  loading: t('dashboard.loading'),
  hello: t('dashboard.hello'),
  todayForLunch: t('dashboard.todayForLunch'),
  weekSummary: t('dashboard.weekSummary'),
  daysWithMenu: t('dashboard.daysWithMenu'),
  daysWithoutMenu: t('dashboard.daysWithoutMenu'),
  averagePeople: t('dashboard.averagePeople'),
  nextMeal: t('dashboard.nextMeal'),
  viewSummary: t('dashboard.viewSummary'),
  collapseSummary: t('dashboard.collapseSummary'),
  expandSummary: t('dashboard.expandSummary'),
  plannedStatus: t('dashboard.plannedStatus'),
  viewBeyondWeek: t('dashboard.viewBeyondWeek'),
  todayEmpty: t('dashboard.todayEmpty'),
  todayShort: t('dashboard.todayShort'),
  nextSeven: t('dashboard.nextSeven'),
  configure: t('dashboard.configure'),
  configureDescription: t('dashboard.configureDescription'),
  editDay: t('dashboard.editDay'),
  quickEdit: t('dashboard.quickEdit'),
  deleteDay: t('dashboard.deleteDay'),
  deleteMenu: t('dashboard.deleteMenu'),
  moreActions: t('dashboard.moreActions'),
  save: t('dashboard.save'),
  cancel: t('dashboard.cancel'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  discardChangesTitle: t('menu.discardChangesTitle'),
  discardChangesDescription: t('menu.discardChangesDescription'),
  discardChangesAction: t('menu.discardChangesAction'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  dailyOptionsTitle: t('dailyOptions.dayTitle'),
  dailyOptionsDescription: t('dailyOptions.dayDescription'),
  dailyOptionsSummary: t('dailyOptions.summaryLabel'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  participants: t('group.members'),
  participantsAll: t('history.statusAll'),
  skipSummary: t('dashboard.skipSummary'),
  updated: t('menu.updated'),
  updatedBody: t('menu.updatedBody'),
  permissionsError: t('menu.permissionsError'),
  'errors.permissionDenied': t('errors.permissionDenied'),
  'errors.unavailable': t('errors.unavailable'),
  'errors.generic': t('errors.generic'),
  'errors.firebaseMissingConfig': t('errors.firebaseMissingConfig'),
  'errors.groupNotFound': t('errors.groupNotFound'),
  'errors.inviteNotFound': t('errors.inviteNotFound'),
  'errors.appCheckUnavailable': t('errors.appCheckUnavailable'),
  guestSession: t('menu.guestSession'),
  tuppers: tt('nav'),
  tuppersExpiryAlert: tt('expiryAlert'),
  homePath,
};
---

<section class="dashboard-app dashboard-app--compact" data-dashboard-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div class="dashboard-app__content" data-content hidden>
    <section class="week-overview app-panel" data-week-overview data-collapsed="false" aria-labelledby="week-overview-title" aria-live="polite">
      <div class="week-overview__header">
        <div class="week-overview__title-block">
          <div class="week-overview__title">
            <h2 id="week-overview-title">{labels.weekSummary}</h2>
          </div>
          <div class="week-overview__meta">
            <span class="week-overview__range">
              <Icon name="mdi:calendar-blank-outline" aria-hidden="true" />
              <span data-week-range></span>
              <Icon name="mdi:chevron-down" aria-hidden="true" />
            </span>
            <a class="week-overview__summary-link" href={summaryPath}>
              <span>{labels.viewSummary}</span>
              <Icon name="mdi:chevron-right" aria-hidden="true" />
            </a>
          </div>
        </div>
        <button
          class="week-overview__toggle"
          type="button"
          data-overview-toggle
          aria-expanded="true"
          aria-controls="week-overview-body"
          aria-label={labels.collapseSummary}
        >
          <Icon name="mdi:chevron-up" aria-hidden="true" />
        </button>
      </div>

      <div id="week-overview-body" class="week-overview__body" data-overview-body>
        <div class="week-overview__grid" aria-label={labels.weekSummary}>
          <div class="week-overview__stats">
            <div class="week-overview__stat">
              <span class="week-overview__stat-icon week-overview__stat-icon--success" aria-hidden="true">
                <Icon name="mdi:check-circle" />
              </span>
              <strong data-week-planned>0</strong>
              <span>{labels.daysWithMenu}</span>
            </div>
            <div class="week-overview__stat">
              <span class="week-overview__stat-icon week-overview__stat-icon--warning" aria-hidden="true">
                <Icon name="mdi:progress-clock" />
              </span>
              <strong data-week-empty>0</strong>
              <span>{labels.daysWithoutMenu}</span>
            </div>
            <div class="week-overview__stat">
              <span class="week-overview__stat-icon" aria-hidden="true">
                <Icon name="mdi:account-group-outline" />
              </span>
              <strong data-week-people>0</strong>
              <span>{labels.averagePeople}</span>
            </div>
          </div>

          <div class="week-overview__next">
            <div class="week-overview__next-copy">
              <span>{labels.nextMeal}</span>
              <small data-week-next-meta></small>
              <strong data-week-next-dish>{labels.todayEmpty}</strong>
              <em data-week-next-people></em>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="expiry-banner" data-expiry-banner hidden role="status" aria-live="polite">
      <strong>{labels.tuppersExpiryAlert}</strong>
      <a class="button button--ghost button--small" href={tuppersPath}>{labels.tuppers}</a>
    </section>

    <section class="dashboard-section">
      <button class="dashboard-notifications-control" type="button" data-notifications hidden>{labels.enableNotifications}</button>
      <div class="next-days next-days--timeline" data-next-days></div>
      <a class="dashboard-week-more" href={getLocalizedPath('/planificador', locale)}>
        <span>{labels.viewBeyondWeek}</span>
        <Icon name="mdi:chevron-down" aria-hidden="true" />
      </a>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.quickEdit}
    title={labels.quickEdit}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .dashboard-app__content {
    display: grid;
    gap: 0;
  }

  .week-overview.app-panel {
    display: grid;
    gap: 1.1rem;
    border: 0;
    border-radius: 0;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    padding: clamp(1rem, 2.7vw, 1.35rem) 0 clamp(1.15rem, 2.8vw, 1.45rem);
    box-shadow: none;
  }

  .week-overview__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 0.75rem;
  }

  .week-overview__title-block {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .week-overview__title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .week-overview__meta {
    display: grid;
    gap: 0.45rem;
    align-items: start;
    justify-items: start;
  }

  .week-overview h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.05rem, 2.8vw, 1.38rem);
    font-weight: 560;
    letter-spacing: -0.035em;
    line-height: 1.1;
  }

  .week-overview__range,
  .week-overview__summary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-muted);
    font-size: clamp(0.88rem, 2vw, 1rem);
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .week-overview__toggle {
    display: inline-grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-muted);
    padding: 0;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base), transform var(--transition-base);
  }

  .week-overview__toggle:hover,
  .week-overview__toggle:focus-visible {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 38%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    outline: 0;
  }

  .week-overview__toggle svg {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform var(--transition-base);
  }

  .week-overview[data-collapsed='true'] .week-overview__toggle svg {
    transform: rotate(180deg);
  }

  .week-overview__body {
    display: grid;
    gap: 0;
  }

  .week-overview__range svg {
    width: 1.15rem;
    height: 1.15rem;
    color: var(--color-text);
  }

  .week-overview__summary-link {
    flex: 0 0 auto;
    color: var(--color-primary);
    font-weight: 520;
  }

  .week-overview__summary-link svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .week-overview__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .week-overview__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding-block: 0.35rem 0.7rem;
  }

  .week-overview__stat,
  .week-overview__next {
    display: grid;
    align-content: start;
    gap: 0.4rem;
    min-width: 0;
    padding-inline: clamp(0.55rem, 2vw, 1.15rem);
    color: var(--color-muted);
    font-size: clamp(0.92rem, 2vw, 1rem);
    font-weight: 420;
    line-height: 1.18;
  }

  .week-overview__stat + .week-overview__stat,
  .week-overview__next {
    border-left: 1px solid var(--color-border);
  }

  .week-overview__next {
    border-top: 1px solid var(--color-border);
    border-left: 0;
    padding-top: 0.9rem;
  }

  .week-overview__stat strong {
    color: var(--color-text);
    font-size: clamp(1.7rem, 4.6vw, 2rem);
    font-weight: 650;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .week-overview__stat-icon {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: var(--radius-full);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 950;
  }

  .week-overview__stat-icon svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .week-overview__stat-icon--success {
    background: var(--color-success-soft);
    color: var(--color-success);
  }

  .week-overview__stat-icon--warning {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .week-overview__next-copy {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
  }

  .week-overview__next-copy > span,
  .week-overview__next small,
  .week-overview__next em {
    color: var(--color-muted);
    font-style: normal;
    font-weight: 420;
  }

  .week-overview__next small {
    color: var(--color-primary);
    font-size: 0.96rem;
    font-weight: 520;
  }

  .week-overview__next-copy > strong {
    display: block;
    color: var(--color-text);
    font-size: clamp(0.98rem, 2.4vw, 1.14rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }

  .week-overview__next em:empty {
    display: none;
  }

  .today-hero__notes {
    flex-basis: 100%;
  }

  .dashboard-section {
    margin-bottom: 0;
    padding-top: 0.9rem;
  }

  .dashboard-section .section-heading {
    align-items: center;
    margin-bottom: 0.7rem;
  }

  .dashboard-section .section-heading h2 {
    font-size: clamp(1.25rem, 3.4vw, 1.85rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .next-days--timeline {
    margin-bottom: 0;
  }

  .next-days--timeline .history-card.dashboard-day-card {
    min-height: 7.75rem;
    overflow: visible;
    border-color: var(--color-border);
    background: var(--color-surface);
    box-shadow: none;
  }

  .next-days--timeline .history-card.dashboard-day-card--today {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 52%);
    background: color-mix(in srgb, var(--color-primary-soft), var(--color-surface) 92%);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-primary), transparent 72%);
  }

  .next-days--timeline .history-card__body {
    gap: 0.5rem;
  }

  .dashboard-day-card .history-card__date {
    align-content: center;
    gap: 0.1rem;
    padding-inline: 1rem 0.9rem;
  }

  .dashboard-day-card--today .history-card__date {
    background: color-mix(in srgb, var(--color-primary-soft), transparent 58%);
  }

  .dashboard-day-card .history-card__today {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .dashboard-day-card .history-card__weekday {
    font-size: clamp(1.02rem, 2.3vw, 1.15rem);
    font-weight: 620;
  }

  .dashboard-day-card--today .history-card__weekday {
    color: var(--color-primary);
  }

  .dashboard-day-card .history-card__month {
    color: var(--color-muted);
    font-size: clamp(0.82rem, 1.6vw, 0.95rem);
    font-weight: 700;
  }

  .dashboard-day-card .history-card__day-number {
    font-size: clamp(1.95rem, 4vw, 2.25rem);
    line-height: 0.92;
  }

  .next-days--timeline .day-meal-row {
    border-radius: var(--radius-lg);
    padding: 0;
  }

  .dashboard-day-card .day-meal-row span {
    font-size: 0.78rem;
  }

  .dashboard-day-card .day-meal-row strong {
    font-size: clamp(0.98rem, 2.3vw, 1.12rem);
    font-weight: 760;
    line-height: 1.14;
  }

  .dashboard-day-card .meal-participants-summary {
    min-height: 1.45rem;
    padding: 0.18rem 0.6rem;
    font-size: 0.72rem;
  }

  .dashboard-day-card .day-card-primary-action--edit {
    width: 2.2rem;
    height: 2.2rem;
  }

  .planner-day-card__notes {
    display: grid;
    gap: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--color-accent), var(--color-border) 58%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-accent-soft), transparent 24%);
    padding: 0.7rem 0.8rem;
  }

  .dashboard-day-card .planner-day-card__notes {
    display: none;
  }

  .dashboard-week-more {
    display: inline-flex;
    align-items: center;
    justify-self: center;
    gap: 0.35rem;
    margin-block: 1.15rem 0.2rem;
    color: var(--color-primary);
    font-size: clamp(0.92rem, 2.2vw, 1rem);
    font-weight: 500;
    text-decoration: none;
  }

  .dashboard-week-more svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .planner-day-card__notes-label {
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .planner-day-card__notes ul {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text);
    font-size: 0.92rem;
    line-height: 1.42;
  }

  .planner-day-card__notes li {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow-wrap: anywhere;
  }

  @media (min-width: 768px) {
    .week-overview__meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.8rem 1rem;
    }

    .week-overview__grid {
      grid-template-columns: minmax(0, 1fr) minmax(13.25rem, 0.48fr);
    }

    .week-overview__next {
      border-top: 0;
      border-left: 1px solid var(--color-border);
      padding-top: 0;
    }
  }

  @media (min-width: 1024px) {
    .dashboard-app.dashboard-app--compact {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-width: 520px) {
    .week-overview.app-panel {
      gap: 1.15rem;
      padding-block: 1rem 1.2rem;
    }

    .week-overview__header {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.5rem;
    }

    .week-overview__title,
    .week-overview__meta {
      align-items: flex-start;
      display: grid;
      gap: 0.55rem;
    }

    .week-overview__stats {
      padding-block: 0.2rem 0.8rem;
    }

    .week-overview__stat {
      padding-inline: 0.65rem;
    }

    .week-overview__next {
      padding-inline: 0.65rem;
      padding-top: 0.85rem;
    }

    .next-days--timeline .history-card.dashboard-day-card {
      min-height: 7.4rem;
    }

    .dashboard-day-card .history-card__date {
      padding-inline: 0.85rem 0.7rem;
    }

    .next-days--timeline .day-actions[data-day-actions] summary {
      width: 2.5rem;
      height: 2.5rem;
    }

  }
</style>

<script>
  import { installDetailsMenuAutoClose } from '../lib/ui/details-menu';
  import '../scripts/dashboard-app.ts';

  installDetailsMenuAutoClose(document);
</script>
