---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { useTupperTranslations } from '../i18n/tuppers';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import '../styles/history.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  enableNotifications: t('menu.enableNotifications'),
  notificationsEnabled: t('menu.notificationsEnabled'),
  notificationsDenied: t('menu.notificationsDenied'),
  dashboardTitle: t('dashboard.title'),
  loading: t('dashboard.loading'),
  hello: t('dashboard.hello'),
  todayForLunch: t('dashboard.todayForLunch'),
  todayEmpty: t('dashboard.todayEmpty'),
  nextSeven: t('dashboard.nextSeven'),
  configure: t('dashboard.configure'),
  configureDescription: t('dashboard.configureDescription'),
  editDay: t('dashboard.editDay'),
  quickEdit: t('dashboard.quickEdit'),
  deleteDay: t('dashboard.deleteDay'),
  deleteMenu: t('dashboard.deleteMenu'),
  moreActions: t('dashboard.moreActions'),
  save: t('dashboard.save'),
  cancel: t('dashboard.cancel'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  dailyOptionsTitle: t('dailyOptions.dayTitle'),
  dailyOptionsDescription: t('dailyOptions.dayDescription'),
  dailyOptionsSummary: t('dailyOptions.summaryLabel'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  participants: t('group.members'),
  participantsAll: t('history.statusAll'),
  skipSummary: t('dashboard.skipSummary'),
  updated: t('menu.updated'),
  updatedBody: t('menu.updatedBody'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  offlineTitle: t('pwa.offlineTitle'),
  offlineCached: t('pwa.offlineCached'),
  offlineReadOnly: t('pwa.offlineReadOnly'),
  offlineNoCache: t('pwa.offlineNoCache'),
  backOnline: t('pwa.backOnline'),
  tuppers: tt('nav'),
  tuppersExpiryAlert: tt('expiryAlert'),
  homePath,
};
---

<section class="dashboard-app dashboard-app--compact" data-dashboard-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="offline-banner" data-offline-banner hidden role="status" aria-live="polite">
    <strong data-offline-title>{labels.offlineTitle}</strong>
    <span data-offline-message>{labels.offlineReadOnly}</span>
  </div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div class="dashboard-app__content" data-content hidden>
    <section class="today-hero app-panel" aria-live="polite">
      <div class="today-hero__topline">
        <p class="today-hero__hello" data-user-label>{labels.hello}</p>
        <button class="button button--ghost button--small today-hero__edit" type="button" data-today-edit>{labels.editDay}</button>
      </div>
      <div class="today-hero__content">
        <h2>{labels.todayForLunch}</h2>
        <ul data-today-summary></ul>
        <div class="today-hero__notes" data-today-notes hidden></div>
      </div>
    </section>

    <section class="expiry-banner" data-expiry-banner hidden role="status" aria-live="polite">
      <strong>{labels.tuppersExpiryAlert}</strong>
      <a class="button button--ghost button--small" href={tuppersPath}>{labels.tuppers}</a>
    </section>

    <section class="dashboard-section">
      <div class="section-heading section-heading--simple">
        <h2>{labels.nextSeven}</h2>
        <button class="button button--ghost button--small" type="button" data-notifications>{labels.enableNotifications}</button>
      </div>
      <div class="next-days next-days--timeline" data-next-days></div>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.quickEdit}
    title={labels.quickEdit}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .today-hero.app-panel {
    position: relative;
    display: grid;
    align-content: start;
    gap: clamp(1.05rem, 2.4vw, 1.65rem);
    overflow: hidden;
    border-color: color-mix(in srgb, var(--color-border), var(--color-primary) 12%);
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--color-primary), transparent 91%), transparent 18rem),
      linear-gradient(135deg, color-mix(in srgb, var(--color-surface), transparent 0%), color-mix(in srgb, var(--color-surface-soft), transparent 62%));
    padding: clamp(1.35rem, 4.5vw, 2.6rem);
    box-shadow: var(--shadow-sm);
  }

  .today-hero__topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .today-hero__hello {
    margin: 0;
    max-width: min(100%, 58rem);
    color: var(--color-primary);
    font-size: clamp(1.05rem, 2.5vw, 2rem);
    font-weight: 380;
    letter-spacing: -0.045em;
    line-height: 1.05;
    text-transform: none;
  }

  .today-hero__edit {
    flex: 0 0 auto;
    min-height: 2.4rem;
    border-color: color-mix(in srgb, var(--color-border), transparent 8%);
    background: color-mix(in srgb, var(--color-surface-raised), transparent 6%);
    box-shadow: none;
  }

  .today-hero__content {
    display: grid;
    gap: 0.35rem;
  }

  .today-hero h2 {
    margin: 0 0 0.05rem;
    max-width: 100%;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.6vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .today-hero ul[data-today-summary] {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .today-hero ul[data-today-summary] li {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
    color: var(--color-text);
    font-size: clamp(2rem, 5.3vw, 4rem);
    font-weight: 680;
    letter-spacing: -0.075em;
    line-height: 0.95;
    overflow-wrap: anywhere;
  }

  .today-hero ul[data-today-summary] .meal-participants-summary {
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    letter-spacing: 0;
  }

  .today-hero__notes {
    margin-top: 0.45rem;
  }

  .planner-day-card__notes {
    display: grid;
    gap: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--color-accent), var(--color-border) 58%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-accent-soft), transparent 24%);
    padding: 0.7rem 0.8rem;
  }

  .planner-day-card__notes-label {
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .planner-day-card__notes ul {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text);
    font-size: 0.92rem;
    line-height: 1.42;
  }

  .planner-day-card__notes li {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow-wrap: anywhere;
  }

  @media (min-width: 768px) {
    .today-hero.app-panel {
      min-height: clamp(15rem, 24vw, 20rem);
      align-content: center;
      padding-inline: clamp(2rem, 5vw, 4rem);
    }
  }

  @media (min-width: 1024px) {
    .dashboard-app.dashboard-app--compact {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-width: 520px) {
    .today-hero__topline {
      display: grid;
    }

    .today-hero__edit {
      width: fit-content;
    }
  }
</style>

<script>
  import { installDetailsMenuAutoClose } from '../lib/ui/details-menu';
  import '../scripts/dashboard-app.ts';

  installDetailsMenuAutoClose(document);
</script>
