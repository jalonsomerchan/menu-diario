---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  signOut: t('menu.signOut'),
  enableNotifications: t('menu.enableNotifications'),
  notificationsEnabled: t('menu.notificationsEnabled'),
  notificationsDenied: t('menu.notificationsDenied'),
  dashboardTitle: t('dashboard.title'),
  loading: t('dashboard.loading'),
  hello: t('dashboard.hello'),
  todayLunch: t('dashboard.todayLunch'),
  todayNoLunch: t('dashboard.todayNoLunch'),
  todayEmpty: t('dashboard.todayEmpty'),
  nextSeven: t('dashboard.nextSeven'),
  configure: t('dashboard.configure'),
  addDish: t('dashboard.addDish'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  suggestions: t('dashboard.suggestions'),
  noLunch: t('dashboard.noLunch'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  saveHint: t('menu.saveHint'),
  updated: t('menu.updated'),
  updatedBody: t('menu.updatedBody'),
  today: t('menu.today'),
  days: t('menu.days'),
  homePath,
};
---

<section class="dashboard-app" data-dashboard-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div class="dashboard-app__content" data-content hidden>
    <header class="dashboard-header">
      <div>
        <p class="menu-app__eyebrow">{labels.saveHint}</p>
        <h1>{labels.dashboardTitle}</h1>
        <p data-user-label></p>
      </div>
      <div class="menu-toolbar__actions">
        <button class="button button--ghost" type="button" data-notifications>{labels.enableNotifications}</button>
        <button class="button button--secondary" type="button" data-logout>{labels.signOut}</button>
      </div>
    </header>

    <section class="today-card" aria-live="polite">
      <p class="menu-app__eyebrow">{labels.today}</p>
      <h2 data-today-summary>{labels.loading}</h2>
    </section>

    <section class="dashboard-section">
      <h2>{labels.nextSeven}</h2>
      <div class="next-days" data-next-days></div>
    </section>

    <section class="dashboard-section">
      <h2>{labels.configure}</h2>
      <div class="menu-days" data-config-days></div>
    </section>
  </div>
</section>

<script>
  import '../scripts/dashboard-app.ts';
</script>
