---
import '../styles/meal-participants.css';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  cancelLabel: string;
  saveLabel: string;
  clearLabel: string;
  saveHint: string;
  savePendingLabel: string;
}

const { eyebrow, title, subtitle = '', cancelLabel, saveLabel, clearLabel, saveHint, savePendingLabel } = Astro.props;
---

<dialog
  class="app-dialog app-dialog--editor quick-edit-modal quick-edit-modal--day day-edit-modal"
  data-day-edit-modal
  aria-labelledby="day-edit-modal-title"
  aria-describedby="day-edit-modal-description"
>
  <form method="dialog" class="app-dialog__surface quick-edit-modal__box day-edit-modal__box" data-day-edit-form>
    <header class="day-edit-modal__header">
      <div class="day-edit-modal__heading">
        <p class="sr-only" data-day-edit-eyebrow>{eyebrow}</p>
        <span class="sr-only" data-day-edit-number></span>
        <h2 id="day-edit-modal-title" data-day-edit-title>{title}</h2>
        <p id="day-edit-modal-description" class="sr-only" data-day-edit-subtitle>{subtitle}</p>
      </div>
      <button class="day-edit-modal__close" type="button" data-day-edit-cancel aria-label={cancelLabel}>
        <span aria-hidden="true">×</span>
      </button>
    </header>

    <div class="day-edit-modal__body" data-day-edit-fields></div>

    <footer class="day-edit-modal__footer">
      <p class="day-edit-modal__hint" data-day-edit-save-state role="status" aria-live="polite" data-idle-label={saveHint} data-pending-label={savePendingLabel} hidden>{saveHint}</p>
      <div class="day-edit-modal__actions">
        <button class="button button--ghost button--small" type="button" data-day-edit-cancel-footer>
          <span class="day-edit-modal__action-icon" aria-hidden="true">✕</span>
          <span class="day-edit-modal__action-label">{cancelLabel}</span>
        </button>
        <button class="button button--ghost button--small" type="button" data-day-edit-clear>
          <span class="day-edit-modal__action-icon" aria-hidden="true">⌫</span>
          <span class="day-edit-modal__action-label">{clearLabel}</span>
        </button>
        <button class="button button--primary" value="save" type="submit" data-day-edit-save>
          <span class="day-edit-modal__action-icon" aria-hidden="true">✓</span>
          <span class="day-edit-modal__action-label">{saveLabel}</span>
        </button>
      </div>
    </footer>
  </form>
</dialog>

<style is:global>
  .day-edit-modal {
    width: min(96vw, 48rem);
    margin: auto;
  }

  .day-edit-modal::backdrop {
    background:
      radial-gradient(circle at 50% 20%, color-mix(in srgb, var(--color-primary), transparent 78%), transparent 26rem),
      linear-gradient(180deg, rgb(2 6 23 / 0.68), rgb(15 23 42 / 0.86));
    backdrop-filter: blur(10px);
  }

  .day-edit-modal__box {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-height: min(94dvh, 52rem);
    overflow: hidden;
    padding: 0;
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 68%);
    background: var(--color-surface);
    box-shadow: 0 28px 86px rgb(15 23 42 / 0.32);
  }

  .day-edit-modal__header {
    flex: 0 0 auto;
    display: grid !important;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.85rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 14%);
    background: color-mix(in srgb, var(--color-surface), var(--color-surface-raised) 36%);
    padding: 1rem var(--surface-padding);
  }

  .day-edit-modal__heading {
    display: grid;
    min-width: 0;
    gap: 0.2rem;
  }

  .day-edit-modal__heading h2 {
    margin: 0;
    overflow: hidden;
    color: var(--color-text);
    font-size: clamp(1.35rem, 5vw, 2rem);
    font-weight: 950;
    letter-spacing: -0.04em;
    line-height: 1.05;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .day-edit-modal__close {
    display: grid;
    place-items: center;
    width: 2.55rem;
    height: 2.55rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-raised), transparent 4%);
    color: var(--color-muted);
    font-size: 1.55rem;
    font-weight: 900;
    line-height: 1;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base),
      border-color var(--transition-base);
  }

  .day-edit-modal__close:hover {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 45%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .day-edit-modal__close:active {
    transform: scale(0.96);
  }

  .day-edit-modal__body {
    display: grid;
    flex: 1 1 auto;
    gap: 1rem;
    min-height: min(54vh, 28rem);
    overflow: auto;
    overscroll-behavior: contain;
    padding: var(--surface-padding);
  }

  .day-edit-modal__footer {
    flex: 0 0 auto;
    display: grid !important;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 12%);
    background: color-mix(in srgb, var(--color-surface), var(--color-surface-raised) 42%);
    padding: 0.72rem var(--surface-padding) calc(0.72rem + env(safe-area-inset-bottom));
  }

  .day-edit-modal__hint {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 850;
    line-height: 1.2;
  }

  .day-edit-modal__hint[hidden] {
    display: none;
  }

  .day-edit-modal__hint[data-variant='saving'] {
    color: var(--color-primary);
  }

  .day-edit-modal__hint[data-variant='pending'] {
    color: var(--color-warning);
  }

  .day-edit-modal__hint[data-variant='saved'] {
    color: var(--color-success);
  }

  .day-edit-modal__hint[data-variant='error'] {
    color: var(--color-danger);
  }

  .day-edit-modal__actions {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(2.9rem, auto);
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .day-edit-modal__actions .button {
    min-width: 0;
    min-height: 2.9rem;
    padding: 0.65rem 0.75rem;
    box-shadow: none;
  }

  .day-edit-modal__actions .button--primary {
    min-width: 3.3rem;
  }

  .day-edit-modal__action-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .day-edit-modal__action-label {
    display: none;
  }

  .day-edit-modal .day-edit-card__content {
    gap: 0.9rem;
  }

  .day-edit-modal .day-card[data-day-mode='skipped'] .day-edit-card__content {
    align-content: start;
    min-height: clamp(20rem, 46vh, 30rem);
  }

  .day-edit-modal .day-edit-block {
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 8%);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface-soft), var(--color-primary-soft) 10%), color-mix(in srgb, var(--color-surface-soft), transparent 10%));
    padding: 0.92rem;
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff, transparent 94%);
  }

  .day-edit-modal .day-card--compact-editor {
    border: 0;
    background: transparent;
    padding: 0;
    box-shadow: none;
  }

  .day-edit-modal .day-card__header {
    display: none;
  }

  .day-edit-modal .meal-editor {
    gap: 0.82rem;
  }

  .day-edit-modal .plate-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 0.85rem;
    min-width: 0;
  }

  .day-edit-modal .plate-row label {
    position: relative;
    min-width: 0;
    gap: 0.45rem;
  }

  .day-edit-modal .meal-editor__header {
    align-items: center;
  }

  .day-edit-modal .meal-editor__title {
    display: grid;
    min-width: 0;
    gap: 0.18rem;
  }

  .day-edit-modal .meal-editor h4 {
    font-size: 0.92rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .day-edit-modal .plate-list {
    gap: 0.7rem;
  }

  .day-edit-modal .plate-row .icon-button--danger {
    width: 2.85rem;
    height: 3.2rem;
    align-self: stretch;
    background: color-mix(in srgb, var(--color-danger-soft), transparent 8%);
  }

  .day-edit-modal .button--primary[aria-busy='true'] {
    opacity: 0.82;
  }

  .day-edit-modal .dish-combobox {
    grid-template-columns: minmax(0, 1fr) 3rem;
    width: 100%;
    min-width: 0;
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--color-surface-raised), var(--color-surface) 35%);
  }

  .day-edit-modal .dish-combobox input {
    min-height: 3.3rem;
    padding: 0.82rem 1rem;
    font-size: 1rem;
    font-weight: 850;
    min-width: 0;
  }

  .day-edit-modal .dish-combobox__toggle {
    min-width: 3rem;
    font-size: 1rem;
  }

  .day-edit-modal .dish-suggestions {
    gap: 0.5rem;
    padding-bottom: 0.2rem;
  }

  .day-edit-modal .dish-suggestions button {
    padding: 0.52rem 0.82rem;
    border-radius: 999px;
    font-size: 0.84rem;
  }

  .day-edit-modal .day-edit-field {
    gap: 0.5rem;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .day-edit-modal .day-edit-field textarea,
  .day-edit-modal .day-edit-field select {
    width: 100%;
  }

  .day-edit-modal .day-edit-field select {
    min-height: 3.15rem;
    padding-right: 2.6rem;
  }

  .day-edit-modal .day-edit-field textarea {
    min-height: 7rem;
    border-radius: 1.15rem;
    background: color-mix(in srgb, var(--color-surface-raised), var(--color-surface) 35%);
    padding: 1rem;
    line-height: 1.55;
  }

  .day-edit-modal .day-edit-field--textarea textarea {
    resize: vertical;
  }

  .day-edit-modal .day-edit-toggle-card {
    display: flex !important;
    align-items: center;
    gap: 0.8rem;
    border-style: dashed;
    background: color-mix(in srgb, var(--color-surface-soft), transparent 6%);
    padding: 0.88rem 0.95rem;
  }

  .day-edit-modal .day-edit-toggle-card input {
    width: 1.2rem;
    height: 1.2rem;
    accent-color: var(--color-primary);
  }

  .day-edit-modal .day-edit-toggle-card:has(input:checked) {
    border-color: color-mix(in srgb, var(--color-warning), var(--color-border) 35%);
    background: color-mix(in srgb, var(--color-warning-soft), transparent 25%);
  }

  @media (min-width: 480px) {
    .day-edit-modal__action-label {
      display: inline;
    }

    .day-edit-modal__actions .button {
      gap: 0.45rem;
      padding-inline: 0.9rem;
    }
  }

  @media (min-width: 640px) {
    .day-edit-modal__actions {
      grid-auto-flow: column;
      grid-auto-columns: auto;
      justify-content: end;
      align-items: center;
      gap: 0.65rem;
    }

    .day-edit-modal__actions .button--primary {
      min-width: 11rem;
    }
  }

  @media (max-width: 520px) {
    .day-edit-modal__body {
      min-height: min(58vh, 30rem);
    }

    .day-edit-modal__footer {
      grid-template-columns: minmax(0, 1fr) auto;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .day-edit-modal__footer::-webkit-scrollbar {
      display: none;
    }

    .day-edit-modal__actions {
      justify-content: end;
      min-width: max-content;
    }

    .day-edit-modal__actions .button {
      width: auto;
      min-width: 2.65rem;
    }
  }
</style>
