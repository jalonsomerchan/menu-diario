---
interface Props {
  dialogId?: string;
  cancelLabel: string;
  saveLabel: string;
  archiveLabel: string;
  duplicateLabel: string;
}

const { dialogId = 'dish-editor-dialog', cancelLabel, saveLabel, archiveLabel, duplicateLabel } = Astro.props;
const titleId = `${dialogId}-title`;
const descriptionId = `${dialogId}-description`;
---

<dialog
  class="app-dialog app-dialog--editor dish-editor-dialog"
  data-dish-editor-dialog
  role="dialog"
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={descriptionId}
>
  <form class="app-dialog__surface dish-editor-dialog__surface" data-dish-editor-form>
    <header class="dish-editor-dialog__header">
      <div class="dish-editor-dialog__icon" aria-hidden="true" data-dish-editor-icon>🍽</div>
      <div class="dish-editor-dialog__heading">
        <p class="menu-app__eyebrow" data-dish-editor-eyebrow></p>
        <h2 id={titleId} data-dish-editor-title></h2>
        <p id={descriptionId} class="dish-editor-dialog__description" data-dish-editor-description></p>
      </div>
      <button class="dish-editor-dialog__close" type="button" data-dish-editor-cancel aria-label={cancelLabel}>
        <span aria-hidden="true">×</span>
      </button>
    </header>

    <div class="app-dialog__body dish-editor-dialog__body" data-dish-editor-body></div>

    <footer class="app-dialog__footer dish-editor-dialog__footer">
      <button class="button button--ghost" type="button" data-dish-editor-cancel>{cancelLabel}</button>
      <button class="button button--danger" type="button" data-dish-editor-archive hidden>{archiveLabel}</button>
      <button class="button button--secondary" type="button" data-dish-editor-duplicate hidden>{duplicateLabel}</button>
      <button class="button button--primary" type="submit" data-dish-editor-save>{saveLabel}</button>
    </footer>
  </form>
</dialog>

<style is:global>
  .dish-editor-dialog__surface {
    gap: 0;
    max-height: min(94dvh, 52rem);
    overflow: hidden;
    padding: 0;
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 68%);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-primary-soft), transparent 58%), transparent 18rem),
      var(--color-surface);
    box-shadow: 0 28px 86px rgb(15 23 42 / 0.32);
  }

  .dish-editor-dialog__header {
    position: sticky;
    top: 0;
    z-index: 4;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.85rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 14%);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface), var(--color-primary-soft) 10%), var(--color-surface));
    padding: calc(var(--surface-padding) + 0.1rem) var(--surface-padding) var(--surface-padding);
  }

  .dish-editor-dialog__icon {
    display: grid;
    place-items: center;
    width: clamp(2.9rem, 13vw, 4.5rem);
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--color-primary), var(--color-border) 55%);
    border-radius: 1.15rem;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: clamp(1.4rem, 5vw, 1.9rem);
    line-height: 1;
  }

  .dish-editor-dialog__heading {
    display: grid;
    min-width: 0;
    gap: 0.2rem;
  }

  .dish-editor-dialog__heading h2 {
    margin: 0;
    font-size: clamp(1.35rem, 5.5vw, 1.9rem);
    line-height: 1;
    letter-spacing: -0.05em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dish-editor-dialog__description {
    min-height: 1em;
    margin: 0;
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dish-editor-dialog__close {
    display: grid;
    place-items: center;
    width: 2.7rem;
    height: 2.7rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-raised), transparent 4%);
    color: var(--color-muted);
    font-size: 1.7rem;
    font-weight: 900;
    line-height: 1;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base),
      border-color var(--transition-base);
  }

  .dish-editor-dialog__close:hover {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 45%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .dish-editor-dialog__close:active {
    transform: scale(0.96);
  }

  .dish-editor-dialog .app-dialog__body {
    overflow: auto;
    overscroll-behavior: contain;
    padding: var(--surface-padding);
    padding-bottom: calc(5.6rem + env(--safe-area-inset-bottom, 0px));
  }
</style>
