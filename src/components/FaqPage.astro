---
import Button from './Button.astro';
import Breadcrumb from './Breadcrumb.astro';
import Container from './Container.astro';
import { type Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { getPublicFaqItems, usePublicPageCopy } from '../i18n/public-pages';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tp = usePublicPageCopy(locale);
const t = useTranslations(locale);
const faqItems = getPublicFaqItems(locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
---

<Container class="public-faq-container" size="page">
  <Breadcrumb locale={locale} rootItem={{ label: t('nav.home'), href: getLocalizedPath('/', locale) }} items={[{ label: tp('faqTitle') }]} />
  <article class="faq-page">
    <header class="faq-page__hero">
      <p class="faq-page__eyebrow">{tp('faqEyebrow')}</p>
      <h1>{tp('faqTitle')}</h1>
      <p>{tp('faqIntro')}</p>
    </header>

    <section class="faq-page__list" aria-label={tp('faqTitle')}>
      {faqItems.map((item) => (
        <section class="faq-page__item">
          <h2>{item.question}</h2>
          <p>{item.answer}</p>
        </section>
      ))}
    </section>

    <section class="faq-page__cta" aria-labelledby="faq-cta-title">
      <div>
        <h2 id="faq-cta-title">{tp('faqCtaTitle')}</h2>
        <p>{tp('faqCtaDescription')}</p>
      </div>
      <Button href={dashboardPath}>{tp('faqPrimaryCta')}</Button>
    </section>
  </article>
</Container>

<style>
  .public-faq-container {
    padding-block: clamp(2rem, 7vw, 4.5rem);
  }

  .faq-page {
    display: grid;
    gap: clamp(1rem, 3vw, 1.5rem);
  }

  .faq-page__hero,
  .faq-page__item,
  .faq-page__cta {
    border: 1px solid var(--panel-border);
    border-radius: clamp(1.3rem, 4vw, 2.35rem);
    background: var(--panel-background);
    box-shadow: var(--shadow-sm);
  }

  .faq-page__hero {
    display: grid;
    justify-items: center;
    gap: 1.2rem;
    padding: clamp(2.8rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    text-align: center;
  }

  .faq-page__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    font-weight: 380;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .faq-page h1,
  .faq-page h2,
  .faq-page p {
    margin: 0;
  }

  .faq-page h1 {
    max-width: 12ch;
    color: var(--color-text);
    font-size: clamp(2.75rem, 8vw, 5.2rem);
    font-weight: 620;
    line-height: 0.95;
    letter-spacing: -0.085em;
  }

  .faq-page__hero > p {
    max-width: 46rem;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 420;
    letter-spacing: -0.035em;
    line-height: 1.42;
  }

  .faq-page h2 {
    color: var(--color-text);
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    font-weight: 650;
    line-height: 1.05;
    letter-spacing: -0.065em;
  }

  .faq-page p {
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.7vw, 1.08rem);
    font-weight: 420;
    letter-spacing: -0.025em;
    line-height: 1.55;
  }

  .faq-page__list {
    display: grid;
    gap: 1rem;
  }

  .faq-page__item {
    display: grid;
    gap: 0.75rem;
    padding: clamp(1.25rem, 3vw, 1.65rem);
  }

  .faq-page__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  .faq-page__cta div {
    display: grid;
    gap: 0.55rem;
    min-width: min(100%, 24rem);
  }
</style>
