---
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { getCookingSeoIndexLabel, getCookingSeoIndexRoute } from '../data/public-cooking-seo-pages';
import { getPublicSeoPages } from '../data/public-seo-pages';
import { usePublicPageCopy } from '../i18n/public-pages';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePublicPageCopy(locale);
const currentYear = new Date().getFullYear();
const publicLinks = [
  { href: getLocalizedPath('/', locale), label: t('nav.home') },
  { href: getLocalizedPath('/como-funciona', locale), label: t('public.howItWorks.nav') },
  { href: getLocalizedPath('/acerca-de', locale), label: tp('footerAbout') },
  { href: getLocalizedPath('/faq', locale), label: tp('footerFaq') },
  { href: getLocalizedPath(getCookingSeoIndexRoute(locale), locale), label: getCookingSeoIndexLabel(locale) },
  ...getPublicSeoPages(locale).map((page) => ({
    href: getLocalizedPath(`/${page.slug}`, locale),
    label: page.navLabel,
  })),
];
---

<footer class="site-footer">
  <Container>
    <div class="site-footer__grid site-footer__public-pages">
      <div class="site-footer__brand">
        <a href={getLocalizedPath('/', locale)} class="site-footer__logo">
          {siteConfig.name}
        </a>
        <p>{t('site.description')}</p>
        <p class="site-footer__copyright">
          &copy; {currentYear} {siteConfig.name}.
        </p>
      </div>

      <nav class="site-footer__section" aria-label={siteConfig.name}>
        <span class="site-footer__title">{siteConfig.name}</span>
        <ul>
          {publicLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-surface-soft), transparent 50%));
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.875rem;
    margin-top: 0;
    padding: 3rem 0 calc(3rem + env(safe-area-inset-bottom));
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .site-footer__brand,
  .site-footer__section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .site-footer__brand {
    max-width: 15rem;
  }

  .site-footer__logo {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .site-footer__logo:hover,
  .site-footer__logo:focus-visible {
    opacity: 0.8;
  }

  .site-footer p {
    margin: 0;
  }

  .site-footer__brand p {
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.75rem;
    line-height: 1.65;
  }

  .site-footer__copyright {
    width: fit-content;
    margin-top: 0.75rem !important;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
    font-size: 0.625rem !important;
    opacity: 0.7;
  }

  .site-footer__title {
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    opacity: 0.85;
    text-transform: uppercase;
  }

  .site-footer ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.75rem;
  }

  .site-footer a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--color-text);
  }

  @media (min-width: 640px) {
    .site-footer__grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
      align-items: start;
      gap: 2rem;
    }
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 4rem 0;
    }
  }
</style>
