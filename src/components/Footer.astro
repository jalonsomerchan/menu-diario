---
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { getPublicSeoPages } from '../data/public-seo-pages';
import { footerGames, footerTools, formatProjectLabel, getFooterLabels } from '../i18n/footer-projects';
import { usePublicPageCopy } from '../i18n/public-pages';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getFooterLabels(locale);
const t = useTranslations(locale);
const tp = usePublicPageCopy(locale);
const currentYear = new Date().getFullYear();
const seoLinks = getPublicSeoPages(locale).map((page) => ({
  href: getLocalizedPath(`/${page.slug}`, locale),
  label: page.navLabel,
}));
const appLinks = [
  { href: getLocalizedPath('/', locale), label: t('nav.home') },
  { href: getLocalizedPath('/dashboard', locale), label: t('appNav.dashboard') },
  { href: getLocalizedPath('/planificador', locale), label: t('appNav.planning') },
  { href: getLocalizedPath('/como-funciona', locale), label: t('public.howItWorks.nav') },
  { href: getLocalizedPath('/acerca-de', locale), label: tp('footerAbout') },
  { href: getLocalizedPath('/faq', locale), label: tp('footerFaq') },
  ...seoLinks,
];
const projectGroups = [
  { title: labels.tools, projects: footerTools },
  { title: labels.games, projects: footerGames },
];
---

<footer class="site-footer">
  <Container>
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <a href={getLocalizedPath('/', locale)} class="site-footer__logo">
          {siteConfig.name}
        </a>
        <p>{labels.copy}</p>
        <p class="site-footer__copyright">
          &copy; {currentYear} {siteConfig.name}.
        </p>
      </div>

      <nav class="site-footer__section" aria-label={siteConfig.name}>
        <span class="site-footer__title">{siteConfig.name}</span>
        <ul>
          {appLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
          <li>
            <a href={siteConfig.repositoryUrl} target="_blank" rel="noopener noreferrer" class="site-footer__external">
              {labels.repository}
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </li>
        </ul>
      </nav>

      {projectGroups.map((group) => (
        <nav class="site-footer__section" aria-label={group.title}>
          <span class="site-footer__title">{group.title}</span>
          <ul>
            {group.projects.map((project) => (
              <li>
                <a href={project.href} target="_blank" rel="noopener noreferrer" class="site-footer__project" aria-label={formatProjectLabel(labels.openProject, project.name)}>
                  <span>{project.name}</span>
                  <small>{new URL(project.href).hostname}</small>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}

      <div class="site-footer__section">
        <span class="site-footer__title">{labels.portfolio}</span>
        <ul>
          <li>
            <a href="https://alon.one" target="_blank" rel="noopener noreferrer" class="site-footer__project site-footer__external">
              <span>
                alon.one
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
              <small>{siteConfig.author}</small>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-surface-soft), transparent 50%));
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.875rem;
    margin-top: 0;
    padding: 3rem 0 calc(3rem + env(safe-area-inset-bottom));
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .site-footer__brand,
  .site-footer__section,
  .site-footer__project {
    display: flex;
    flex-direction: column;
  }

  .site-footer__brand,
  .site-footer__section {
    gap: 0.75rem;
  }

  .site-footer__brand {
    max-width: 15rem;
  }

  .site-footer__logo {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .site-footer__logo:hover,
  .site-footer__logo:focus-visible {
    opacity: 0.8;
  }

  .site-footer p {
    margin: 0;
  }

  .site-footer__brand p {
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.75rem;
    line-height: 1.65;
  }

  .site-footer__copyright {
    width: fit-content;
    margin-top: 0.75rem !important;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
    font-size: 0.625rem !important;
    opacity: 0.7;
  }

  .site-footer__title {
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    opacity: 0.85;
    text-transform: uppercase;
  }

  .site-footer ul {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.75rem;
  }

  .site-footer a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--color-text);
  }

  .site-footer__external,
  .site-footer__project span {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .site-footer svg {
    width: 0.75rem;
    height: 0.75rem;
    opacity: 0.6;
  }

  .site-footer__project {
    gap: 0.125rem;
  }

  .site-footer__project span {
    color: inherit;
    font-weight: 700;
  }

  .site-footer__project:hover span,
  .site-footer__project:focus-visible span {
    color: var(--color-text);
  }

  .site-footer__project small {
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.625rem;
    line-height: 1.35;
    opacity: 0.8;
    transition: opacity 0.15s ease;
  }

  .site-footer__project:hover small,
  .site-footer__project:focus-visible small {
    opacity: 1;
  }

  @media (min-width: 640px) {
    .site-footer__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 4rem 0;
    }

    .site-footer__grid {
      grid-template-columns: minmax(0, 1.2fr) repeat(4, minmax(0, 1fr));
      gap: 2rem;
    }
  }
</style>
