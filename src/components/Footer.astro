---
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { footerGames, footerTools, formatProjectLabel, getFooterLabels } from '../i18n/footer-projects';
import { usePublicPageCopy } from '../i18n/public-pages';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePublicPageCopy(locale);
const labels = getFooterLabels(locale);
const projectGroups = [
  { title: labels.tools, projects: footerTools },
  { title: labels.games, projects: footerGames },
];
const publicLinks = [
  { href: getLocalizedPath('/como-funciona', locale), label: t('public.howItWorks.nav') },
  { href: getLocalizedPath('/acerca-de', locale), label: tp('footerAbout') },
  { href: getLocalizedPath('/faq', locale), label: tp('footerFaq') },
];
---

<footer class="site-footer">
  <Container class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="eyebrow">{labels.eyebrow}</p>
      <h2>{labels.title}</h2>
      <p>{labels.copy}</p>
      <strong>{siteConfig.name}</strong>
    </div>

    <div class="site-footer__projects" aria-label={labels.title}>
      {projectGroups.map((group) => (
        <section class="site-footer__group" aria-labelledby={`footer-${group.title.toLowerCase().replaceAll(' ', '-')}`}>
          <h3 id={`footer-${group.title.toLowerCase().replaceAll(' ', '-')}`}>{group.title}</h3>
          <ul>
            {group.projects.map((project) => (
              <li>
                <a href={project.href} target="_blank" rel="noopener noreferrer" aria-label={formatProjectLabel(labels.openProject, project.name)}>
                  <span>{project.name}</span>
                  <small>{new URL(project.href).hostname}</small>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </Container>

  <Container class="site-footer__legal">
    <nav class="site-footer__public-links" aria-label={t('nav.main')}>
      {publicLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </Container>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: clamp(2rem, 6vw, 3.5rem) 0 calc(5.5rem + env(safe-area-inset-bottom));
    background: radial-gradient(circle at top left, color-mix(in srgb, var(--color-primary), transparent 82%), transparent 26rem), var(--color-bg);
  }

  .site-footer__inner {
    display: grid;
    gap: 1rem;
  }

  .site-footer__brand,
  .site-footer__group {
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 15%);
    background: color-mix(in srgb, var(--color-bg), var(--color-primary) 3%);
    box-shadow: 0 20px 55px rgb(15 23 42 / 0.08);
  }

  .site-footer__brand {
    display: grid;
    gap: 0.75rem;
    border-radius: 2rem;
    padding: clamp(1.25rem, 4vw, 2.5rem);
  }

  .site-footer .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .site-footer h2,
  .site-footer h3,
  .site-footer p {
    margin: 0;
  }

  .site-footer h2 {
    max-width: 12ch;
    font-size: clamp(2.4rem, 11vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.08em;
  }

  .site-footer p {
    max-width: 42rem;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.5vw, 1.2rem);
  }

  .site-footer__brand strong {
    margin-top: 0.35rem;
    color: var(--color-primary);
    font-weight: 950;
  }

  .site-footer__projects {
    display: grid;
    gap: 1rem;
  }

  .site-footer__group {
    display: grid;
    gap: 0.85rem;
    border-radius: 1.5rem;
    padding: 1rem;
  }

  .site-footer__group h3 {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .site-footer__group ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__group a {
    display: grid;
    min-height: 3.15rem;
    align-content: center;
    gap: 0.08rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    padding: 0.62rem 0.9rem;
    color: var(--color-text);
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .site-footer__group a span,
  .site-footer__group a small {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .site-footer__group a small {
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .site-footer__group a:hover,
  .site-footer__group a:focus-visible {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 30%);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .site-footer__legal {
    margin-top: 1rem;
  }

  .site-footer__public-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .site-footer__public-links a {
    color: inherit;
    text-decoration: none;
    text-underline-offset: 0.18em;
  }

  .site-footer__public-links a:hover,
  .site-footer__public-links a:focus-visible {
    color: var(--color-primary);
    text-decoration: underline;
  }

  @media (min-width: 720px) {
    .site-footer {
      padding-bottom: clamp(2.4rem, 6vw, 3.8rem);
    }

    .site-footer__inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.35fr);
      align-items: stretch;
      gap: 1.1rem;
    }

    .site-footer__projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-footer__brand {
      align-content: start;
    }
  }
</style>