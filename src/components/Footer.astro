---
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { usePublicPageCopy } from '../i18n/public-pages';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePublicPageCopy(locale);
const aboutPath = getLocalizedPath('/acerca-de', locale);
---

<footer class="site-footer">
  <Container class="site-footer__container">
    <div class="site-footer__content">
      <p class="site-footer__brand">{siteConfig.name}</p>
      <p class="site-footer__copy">© {new Date().getFullYear()} {siteConfig.name}. {t('footer.createdWith')}</p>
      <nav class="site-footer__links" aria-label={t('nav.main')}>
        <a href={aboutPath}>{tp('footerAbout')}</a>
      </nav>
    </div>
  </Container>
</footer>
