---
import Container from './Container.astro';
import { siteConfig, type Locale } from '../config/site';
import { footerGames, footerTools, formatProjectLabel, getFooterLabels } from '../i18n/footer-projects';
import { usePublicPageCopy } from '../i18n/public-pages';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const labels = getFooterLabels(locale);
const t = useTranslations(locale);
const tp = usePublicPageCopy(locale);
const appLinks = [
  { href: getLocalizedPath('/como-funciona', locale), label: t('public.howItWorks.nav') },
  { href: getLocalizedPath('/acerca-de', locale), label: tp('footerAbout') },
  { href: getLocalizedPath('/faq', locale), label: tp('footerFaq') },
];
const projectGroups = [
  { title: labels.tools, projects: footerTools },
  { title: labels.games, projects: footerGames },
];
---

<footer class="site-footer">
  <Container class="site-footer__inner">
    <section class="site-footer__brand" aria-labelledby="site-footer-title">
      <p class="site-footer__eyebrow">{labels.eyebrow}</p>
      <h2 id="site-footer-title">{labels.title}</h2>
      <p>{labels.copy}</p>
      <strong>{siteConfig.name}</strong>
      <nav class="site-footer__links" aria-label={siteConfig.name}>
        {appLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    </section>

    <nav class="site-footer__projects" aria-label={labels.title}>
      {projectGroups.map((group) => (
        <section class="site-footer__group" aria-labelledby={`footer-${group.title.toLowerCase().replaceAll(' ', '-')}`}>
          <h3 id={`footer-${group.title.toLowerCase().replaceAll(' ', '-')}`}>{group.title}</h3>
          <ul>
            {group.projects.map((project) => (
              <li>
                <a href={project.href} target="_blank" rel="noopener noreferrer" aria-label={formatProjectLabel(labels.openProject, project.name)}>
                  <span>{project.name}</span>
                  <small>{new URL(project.href).hostname}</small>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </nav>
  </Container>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: clamp(2rem, 6vw, 4rem);
    border-top: 1px solid color-mix(in srgb, var(--color-border), transparent 8%);
    background:
      radial-gradient(circle at 98% 92%, color-mix(in srgb, var(--color-primary), transparent 72%), transparent 11rem),
      linear-gradient(135deg, color-mix(in srgb, var(--color-primary), transparent 90%), transparent 42%),
      color-mix(in srgb, var(--color-bg), var(--color-primary) 3%);
    overflow: hidden;
    padding: clamp(2.1rem, 6vw, 3.8rem) 0 calc(5.5rem + env(safe-area-inset-bottom));
  }

  .site-footer::before {
    content: '';
    position: absolute;
    inset: auto -5rem -6rem auto;
    width: 15rem;
    height: 15rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary), transparent 82%);
    pointer-events: none;
  }

  .site-footer__inner {
    position: relative;
    display: grid;
    gap: 1.35rem;
  }

  .site-footer__brand {
    display: grid;
    gap: 0.55rem;
    max-width: 36rem;
  }

  .site-footer__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .site-footer h2,
  .site-footer h3,
  .site-footer p {
    margin: 0;
  }

  .site-footer h2 {
    font-size: clamp(2rem, 8vw, 3.45rem);
    line-height: 0.96;
    letter-spacing: -0.08em;
  }

  .site-footer__brand p:not(.site-footer__eyebrow) {
    max-width: 38rem;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.4vw, 1.18rem);
    font-weight: 800;
    line-height: 1.45;
  }

  .site-footer__brand strong {
    margin-top: 0.35rem;
    color: var(--color-primary);
    font-size: 1.02rem;
    font-weight: 950;
  }

  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 0.95rem;
    margin-top: 0.15rem;
  }

  .site-footer__links a {
    color: var(--color-primary);
    font-weight: 900;
    text-decoration: none;
  }

  .site-footer__links a:hover,
  .site-footer__links a:focus-visible {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .site-footer small {
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .site-footer__projects {
    display: grid;
    gap: 1rem;
  }

  .site-footer__group {
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 8%);
    border-radius: 1.35rem;
    background: color-mix(in srgb, var(--color-bg), transparent 4%);
    box-shadow: 0 18px 45px rgb(15 23 42 / 0.08);
    padding: 1rem;
  }

  .site-footer__group h3 {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__group ul {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__group a {
    display: grid;
    gap: 0.12rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-bg), var(--color-primary) 4%);
    padding: 0.75rem 0.85rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      background var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .site-footer__group a:hover,
  .site-footer__group a:focus-visible {
    background: color-mix(in srgb, var(--color-primary), transparent 88%);
    color: var(--color-text);
    transform: translateY(-1px);
    outline: 0;
    box-shadow: 0 12px 28px color-mix(in srgb, var(--color-primary), transparent 88%);
  }

  .site-footer__group span {
    font-size: 1.02rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .site-footer__group small {
    overflow: hidden;
    color: var(--color-muted);
    font-weight: 800;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 720px) {
    .site-footer {
      padding-bottom: clamp(2.6rem, 6vw, 4rem);
    }

    .site-footer__inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      align-items: start;
      gap: clamp(1.5rem, 4vw, 3rem);
    }

    .site-footer__projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .site-footer__group {
      box-shadow: 0 18px 45px rgb(0 0 0 / 0.28);
    }
  }

  :root[data-theme='dark'] .site-footer__group {
    box-shadow: 0 18px 45px rgb(0 0 0 / 0.28);
  }
</style>
