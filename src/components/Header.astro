---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { useDishRecommenderTranslations } from '../i18n/dish-recommender';
import { usePlanningTranslations } from '../i18n/planning';
import { useStatisticsTranslations } from '../i18n/statistics';
import { useTupperTranslations } from '../i18n/tuppers';
import { getAlternateLocales, getLocalizedEquivalentPath, getLocalizedPath, useTranslations } from '../i18n/ui';
import { stripBasePath } from '../utils/paths';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const td = useDishRecommenderTranslations(locale);
const ts = useStatisticsTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/planificador', locale);
const planningPath = getLocalizedPath('/planificador-ai', locale);
// Legacy aliases remain available through redirects: getLocalizedPath('/configurar', locale) and getLocalizedPath('/planificacion', locale).
const dishRecommenderPath = getLocalizedPath('/recomendador-platos', locale);
const shoppingListsPath = getLocalizedPath('/compras', locale);
const shoppingAiPath = getLocalizedPath('/compra', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);
const statisticsPath = getLocalizedPath('/estadisticas', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const adminDishesPath = getLocalizedPath('/admin/platos', locale);
const historyPath = getLocalizedPath('/historico', locale);
const settingsPath = getLocalizedPath('/ajustes', locale);
const alternateLocales = getAlternateLocales(locale);
const panelId = 'site-navigation-panel';
const normalizeNavigationPath = (path: string) => {
  if (path === '/platos') return '/mis-platos';
  if (path === `/${locale}/platos`) return `/${locale}/mis-platos`;
  return path;
};
const currentPath = normalizeNavigationPath(stripBasePath(Astro.url.pathname).replace(/\/$/, '') || '/');
const isCurrentHref = (href: string) => {
  const itemPath = normalizeNavigationPath(
    stripBasePath(new URL(href, Astro.url).pathname).replace(/\/$/, '') || '/'
  );
  return itemPath === currentPath;
};
const labels = {
  guestSession: t('menu.guestSession'),
  openMenu: t('appNav.openMenu'),
  closeMenu: t('appNav.closeMenu'),
};

const primaryItems = [
  { href: dashboardPath, icon: 'mdi:home-outline', label: t('appNav.dashboard') },
  { href: configurePath, icon: 'mdi:calendar-edit', label: t('appNav.planning') },
  { href: summaryPath, icon: 'mdi:chart-box-outline', label: t('appNav.summary') },
] as const;

const moreItems = [
  { href: shoppingListsPath, icon: 'mdi:cart-outline', label: t('appNav.shoppingLists') },
  { href: shoppingAiPath, icon: 'mdi:creation-outline', label: t('appNav.shoppingAi') },
  { href: tuppersPath, icon: 'mdi:food-takeout-box-outline', label: tt('nav') },
  { href: dishesPath, icon: 'mdi:silverware-fork-knife', label: t('appNav.dishes') },
  { href: planningPath, icon: 'mdi:creation-outline', label: tp('nav') },
  { href: dishRecommenderPath, icon: 'mdi:chef-hat', label: td('nav') },
  { href: statisticsPath, icon: 'mdi:chart-line', label: ts('title') },
  { href: historyPath, icon: 'mdi:history', label: t('appNav.history') },
  { href: settingsPath, icon: 'mdi:cog-outline', label: t('appNav.settings') },
] as const;
---

<header class="site-header app-header" data-site-header data-labels={JSON.stringify(labels)}>
  <Container class="header-inner">
    <a class="site-brand" href={homePath} aria-label={siteConfig.name}>
      <span class="site-brand__mark">
        <Icon name="mdi:silverware-fork-knife" aria-hidden="true" />
      </span>
      <span class="site-brand__copy">
        <span class="site-brand__text">{siteConfig.name}</span>
        <span class="site-brand__subtitle">{t('home.eyebrow')}</span>
      </span>
    </a>

    <nav aria-label={t('nav.main')} class="main-nav main-nav--desktop">
      {primaryItems.map((item) => (
        <a class:list={{ 'is-current': isCurrentHref(item.href) }} href={item.href} aria-current={isCurrentHref(item.href) ? 'page' : undefined}>
          <Icon name={item.icon} aria-hidden="true" />
          <span>{item.label}</span>
        </a>
      ))}

      <details class:list={['nav-dropdown', 'site-header__more', { 'has-current': moreItems.some((item) => isCurrentHref(item.href)) }]}>
        <summary>
          <Icon name="mdi:dots-horizontal-circle-outline" aria-hidden="true" />
          <span>{t('appNav.more')}</span>
        </summary>
        <div class="nav-dropdown__list site-header__more-panel">
          {moreItems.map((item) => (
            <a class:list={{ 'is-current': isCurrentHref(item.href) }} href={item.href} aria-current={isCurrentHref(item.href) ? 'page' : undefined}>
              <Icon name={item.icon} aria-hidden="true" />
              <span>{item.label}</span>
            </a>
          ))}
          <a href={adminDishesPath} data-admin-link hidden>
            <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
            <span>{t('appNav.adminDishes')}</span>
          </a>
        </div>
      </details>

      <details class="nav-dropdown nav-dropdown--settings">
        <summary aria-label={t('appNav.browserTheme')} class="theme-toggle-summary">
          <Icon name="mdi:white-balance-sunny" aria-hidden="true" />
          <span class="sr-only">{t('appNav.browserTheme')}</span>
        </summary>
        <div class="nav-dropdown__list nav-dropdown__list--settings">
          <label>
            <span>{t('appNav.browserTheme')}</span>
            <select data-global-theme aria-label={t('dashboard.theme')}>
              <option value="system">{t('dashboard.themeSystem')}</option>
              <option value="light">{t('dashboard.themeLight')}</option>
              <option value="dark">{t('dashboard.themeDark')}</option>
            </select>
          </label>
          <button class="settings-trigger" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
        </div>
      </details>

      <details class="locale-menu">
        <summary>
          <Icon name="mdi:web" aria-hidden="true" />
          <span>{locale.toUpperCase()}</span>
        </summary>
        <div class="locale-menu__list">
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
      </details>

    </nav>

    <details class="mobile-menu" data-mobile-menu>
      <summary data-site-menu-toggle aria-expanded="false" aria-label={t('appNav.openMenu')} aria-controls={panelId}>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div id={panelId} class="mobile-menu__panel" data-site-menu-panel>
        <div class="mobile-menu__head">
          <strong>{t('nav.main')}</strong>
          <small>{localeLabels[locale]}</small>
        </div>
        <nav aria-label={t('nav.main')} class="mobile-menu__nav">
          {primaryItems.map((item) => (
            <a class:list={{ 'is-current': isCurrentHref(item.href) }} href={item.href} aria-current={isCurrentHref(item.href) ? 'page' : undefined}>
              <span>
                <Icon name={item.icon} aria-hidden="true" />
                {item.label}
              </span>
            </a>
          ))}
          <details class:list={['mobile-menu__section', { 'has-current': moreItems.some((item) => isCurrentHref(item.href)) }]}>
            <summary>{t('appNav.more')}</summary>
            <div>
              {moreItems.map((item) => (
                <a class:list={{ 'is-current': isCurrentHref(item.href) }} href={item.href} aria-current={isCurrentHref(item.href) ? 'page' : undefined}>
                  <span>
                    <Icon name={item.icon} aria-hidden="true" />
                    {item.label}
                  </span>
                </a>
              ))}
              <a href={adminDishesPath} data-admin-link hidden>
                <span>
                  <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
                  {t('appNav.adminDishes')}
                </span>
              </a>
            </div>
          </details>
        </nav>
        <div class="mobile-menu__languages" aria-label={t('appNav.language')}>
          <strong>{t('appNav.language')}</strong>
          <div>
            {alternateLocales.map((alternateLocale) => (
              <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
            ))}
          </div>
        </div>
        <label class="mobile-menu__theme">
          <span>{t('appNav.browserTheme')}</span>
          <select data-global-theme aria-label={t('dashboard.theme')}>
            <option value="system">{t('dashboard.themeSystem')}</option>
            <option value="light">{t('dashboard.themeLight')}</option>
            <option value="dark">{t('dashboard.themeDark')}</option>
          </select>
        </label>
        <button class="settings-trigger mobile-menu__logout" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
      </div>
    </details>
  </Container>
  <button class="mobile-menu__scrim" type="button" data-site-menu-scrim tabindex="-1" aria-hidden="true"></button>
</header>

<style is:global>
  .app-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    box-shadow: none;
    backdrop-filter: blur(20px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 4.85rem;
    padding-block: calc(0.7rem + env(safe-area-inset-top)) 0.65rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    flex: 1 1 auto;
    gap: clamp(0.7rem, 2.1vw, 1rem);
    min-width: 0;
    color: var(--color-text);
    font-weight: 700;
    letter-spacing: -0.025em;
    text-decoration: none;
  }

  .site-brand__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: clamp(1.95rem, 4.4vw, 2.55rem);
    height: clamp(1.95rem, 4.4vw, 2.55rem);
    border-radius: 0;
    background: transparent;
    color: var(--color-primary);
    box-shadow: none;
  }

  .site-brand__mark svg {
    width: clamp(1.95rem, 4.2vw, 2.45rem);
    height: clamp(1.95rem, 4.2vw, 2.45rem);
  }

  .site-brand__copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .site-brand__text {
    overflow: hidden;
    max-width: 58vw;
    color: var(--color-text);
    font-size: clamp(1.15rem, 4vw, 1.7rem);
    font-weight: 600;
    line-height: 1.1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .site-brand__subtitle {
    display: none;
  }

  .main-nav {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    gap: clamp(0.35rem, 1.4vw, 0.75rem);
    color: var(--color-text-muted, var(--color-muted));
    font-size: 0.875rem;
  }

  .main-nav--desktop {
    display: flex;
    gap: clamp(0.45rem, 2vw, 1rem);
  }

  .main-nav--desktop > a:not(.settings-shortcut),
  .main-nav--desktop > .site-header__more {
    display: none;
  }

  .main-nav > a,
  .nav-dropdown summary,
  .locale-menu summary,
  .settings-shortcut {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 2.45rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted, var(--color-muted));
    cursor: pointer;
    padding: 0.28rem 0.36rem;
    font: inherit;
    font-weight: 600;
    list-style: none;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base);
  }

  .main-nav.main-nav--desktop > a:not(.settings-shortcut),
  .main-nav.main-nav--desktop > .site-header__more {
    display: none;
  }

  .main-nav > a:hover,
  .locale-menu summary:hover,
  .settings-shortcut:hover,
  .nav-dropdown summary:hover,
  .nav-dropdown[open] summary,
  .locale-menu[open] summary {
    background: var(--color-surface-soft);
    color: var(--color-text);
    transform: none;
  }

  .main-nav > a:not(.settings-shortcut) svg,
  .site-header__more > summary svg {
    display: none;
  }

  .locale-menu summary {
    min-width: auto;
    border: 0;
    background: transparent;
    box-shadow: none;
    padding-inline: 0.25rem;
    color: var(--color-text);
    font-size: clamp(0.92rem, 2vw, 1.18rem);
    font-weight: 600;
  }

  .locale-menu summary svg {
    width: clamp(1.5rem, 3.1vw, 2rem);
    height: clamp(1.5rem, 3.1vw, 2rem);
  }

  .nav-dropdown--settings > summary,
  .settings-shortcut {
    width: clamp(2.35rem, 4.3vw, 2.85rem);
    height: clamp(2.35rem, 4.3vw, 2.85rem);
    min-height: clamp(2.35rem, 4.3vw, 2.85rem);
    border: 0;
    background: transparent;
    box-shadow: none;
    padding: 0;
    color: var(--color-text);
  }

  .nav-dropdown--settings > summary svg,
  .settings-shortcut svg {
    width: clamp(1.5rem, 3vw, 2rem);
    height: clamp(1.5rem, 3vw, 2rem);
  }

  .locale-menu,
  .nav-dropdown,
  .mobile-menu {
    position: relative;
  }

  .locale-menu summary::-webkit-details-marker,
  .nav-dropdown summary::-webkit-details-marker,
  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .locale-menu summary::after,
  .nav-dropdown summary::after {
    content: none;
  }

  .locale-menu__list,
  .nav-dropdown__list {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    z-index: 40;
    display: grid;
    gap: 0.25rem;
    min-width: 10rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-md);
    padding: 0.75rem;
  }

  .nav-dropdown__list {
    right: auto;
    left: 0;
    min-width: 14rem;
  }

  .nav-dropdown--settings .nav-dropdown__list {
    right: 0;
    left: auto;
  }

  .nav-dropdown__list--settings {
    min-width: 16rem;
  }

  .nav-dropdown__list a,
  .locale-menu__list a,
  .nav-dropdown__list button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text-muted, var(--color-muted));
    padding: 0.625rem 0.75rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: left;
    text-decoration: none;
    transition: background var(--transition-base), color var(--transition-base);
  }

  .locale-menu__list a:hover,
  .nav-dropdown__list a:hover,
  .nav-dropdown__list button:hover {
    background: var(--color-surface-soft);
    color: var(--color-text);
  }

  .nav-dropdown__list--settings label,
  .mobile-menu__theme {
    display: grid;
    gap: 0.45rem;
    color: var(--color-text-muted, var(--color-muted));
    font-size: 0.82rem;
    font-weight: 700;
  }

  .nav-dropdown__list--settings select,
  .mobile-menu__theme select {
    min-height: 2.7rem;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface-raised);
    color: var(--color-text);
    padding: 0 0.8rem;
    font: inherit;
    font-weight: 700;
  }

  .mobile-menu {
    z-index: 45;
    flex: 0 0 auto;
    display: block;
  }

  .mobile-menu > summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-xs, none);
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    touch-action: manipulation;
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .mobile-menu > summary:hover {
    border-color: var(--color-border-strong, var(--color-border));
    background: var(--color-surface-soft);
  }

  .mobile-menu > summary span {
    display: block;
    width: 1.25rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .mobile-menu > summary {
    display: grid;
    gap: 0.28rem;
  }

  .mobile-menu[open] > summary span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-menu[open] > summary span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] > summary span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu__panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    z-index: 44;
    display: grid;
    gap: 0.75rem;
    width: min(20rem, calc(100vw - 2rem));
    max-height: calc(100dvh - 5.75rem);
    overflow: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-md);
    padding: 0.75rem;
  }

  .mobile-menu__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
    padding: 0 0 0.75rem;
  }

  .mobile-menu__head strong {
    font-size: 1rem;
  }

  .mobile-menu__head small {
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.75rem;
    font-weight: 700;
  }

  .mobile-menu__nav,
  .mobile-menu__section,
  .mobile-menu__section > div {
    display: grid;
    gap: 0.25rem;
  }

  .mobile-menu__panel a,
  .mobile-menu__panel button,
  .mobile-menu__section > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.75rem;
    width: 100%;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text-muted, var(--color-muted));
    padding: 0.625rem 0.75rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    list-style: none;
    text-align: left;
    text-decoration: none;
    transition: background var(--transition-base), color var(--transition-base);
  }

  .mobile-menu__panel a span,
  .mobile-menu__nav a span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .mobile-menu__panel a::after,
  .mobile-menu__panel button::after,
  .mobile-menu__section > summary::after {
    content: '›';
    color: var(--color-text-soft, var(--color-muted));
    font-size: 1.1rem;
    line-height: 1;
  }

  .mobile-menu__panel a:hover,
  .mobile-menu__panel button:hover,
  .mobile-menu__section > summary:hover {
    background: var(--color-surface-soft);
    color: var(--color-text);
  }

  .mobile-menu__section[open] > summary::after {
    transform: rotate(90deg);
  }

  .mobile-menu__section > div {
    padding-left: 0.4rem;
  }

  .mobile-menu__section > div a {
    min-height: 2.5rem;
  }

  .mobile-menu__languages {
    display: grid;
    gap: 0.55rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }

  .mobile-menu__languages > strong {
    color: var(--color-text-soft, var(--color-muted));
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mobile-menu__languages > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .mobile-menu__languages a {
    justify-content: center;
    min-height: 2.4rem;
    width: auto;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .mobile-menu__languages a::after {
    display: none;
  }

  .mobile-menu__logout {
    justify-content: center;
  }

  .mobile-menu__nav svg {
    width: 1rem;
    height: 1rem;
  }

  @media (min-width: 768px) {
    .header-inner {
      min-height: 5.25rem;
      padding-block: 0.72rem;
    }

    .site-brand__mark {
      width: 2.55rem;
      height: 2.55rem;
    }

    .site-brand__text {
      font-size: 1.75rem;
    }

    .site-brand__text,
    .site-brand__subtitle {
      max-width: none;
    }

    .main-nav--desktop {
      display: flex;
    }

    .main-nav.main-nav--desktop > a:not(.settings-shortcut),
    .main-nav.main-nav--desktop > .site-header__more {
      display: inline-flex;
    }

    .settings-shortcut {
      display: none;
    }
  }

  @media (max-width: 420px) {
    .site-brand__text,
    .site-brand__subtitle {
      max-width: 50vw;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .app-header {
      background: color-mix(in srgb, var(--color-surface) 84%, transparent);
    }
  }

  :root[data-theme='dark'] .app-header {
    background: color-mix(in srgb, var(--color-surface) 84%, transparent);
  }

  /* Floating, source-anchored chrome inspired by native Apple navigation. */
  .app-header {
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    padding-top: max(0.5rem, env(safe-area-inset-top));
  }

  .header-inner {
    position: relative;
    z-index: 2;
    min-height: 3.9rem;
    width: min(calc(100% - 1rem), var(--container-page-max));
    border: 1px solid var(--panel-border);
    border-radius: calc(var(--radius-2xl) + 0.25rem);
    background: var(--material-thin);
    padding-block: 0.5rem;
    box-shadow: var(--shadow-sm);
