---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { useDishRecommenderTranslations } from '../i18n/dish-recommender';
import { usePlanningTranslations } from '../i18n/planning';
import { useStatisticsTranslations } from '../i18n/statistics';
import { useTupperTranslations } from '../i18n/tuppers';
import { getAlternateLocales, getLocalizedEquivalentPath, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const td = useDishRecommenderTranslations(locale);
const ts = useStatisticsTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/planificador', locale);
const planningPath = getLocalizedPath('/planificador-ai', locale);
// Legacy aliases remain available through redirects: getLocalizedPath('/configurar', locale) and getLocalizedPath('/planificacion', locale).
const dishRecommenderPath = getLocalizedPath('/recomendador-platos', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);
const statisticsPath = getLocalizedPath('/estadisticas', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const adminDishesPath = getLocalizedPath('/admin/platos', locale);
const historyPath = getLocalizedPath('/historico', locale);
const settingsPath = getLocalizedPath('/ajustes', locale);
const alternateLocales = getAlternateLocales(locale);
const panelId = 'site-navigation-panel';
const labels = {
  guestSession: t('menu.guestSession'),
  openMenu: t('appNav.openMenu'),
  closeMenu: t('appNav.closeMenu'),
};

const primaryItems = [
  { href: dashboardPath, icon: 'mdi:home-outline', label: t('appNav.dashboard') },
  { href: configurePath, icon: 'mdi:calendar-edit', label: t('appNav.planning') },
  { href: summaryPath, icon: 'mdi:chart-box-outline', label: t('appNav.summary') },
] as const;

const moreItems = [
  { href: shoppingPath, icon: 'mdi:cart-outline', label: t('appNav.shopping') },
  { href: tuppersPath, icon: 'mdi:food-takeout-box-outline', label: tt('nav') },
  { href: dishesPath, icon: 'mdi:silverware-fork-knife', label: t('appNav.dishes') },
  { href: planningPath, icon: 'mdi:creation-outline', label: tp('nav') },
  { href: dishRecommenderPath, icon: 'mdi:chef-hat', label: td('nav') },
  { href: statisticsPath, icon: 'mdi:chart-line', label: ts('title') },
  { href: historyPath, icon: 'mdi:history', label: t('appNav.history') },
  { href: settingsPath, icon: 'mdi:cog-outline', label: t('appNav.settings') },
] as const;
---

<header class="site-header app-header" data-site-header data-labels={JSON.stringify(labels)}>
  <Container class="header-inner">
    <a class="site-brand" href={homePath} aria-label={siteConfig.name}>
      <span class="site-brand__mark">MD</span>
      <span class="site-brand__copy">
        <span class="site-brand__text">{siteConfig.name}</span>
        <span class="site-brand__subtitle">{t('home.eyebrow')}</span>
      </span>
    </a>

    <nav aria-label={t('nav.main')} class="main-nav main-nav--desktop">
      {primaryItems.map((item) => (
        <a href={item.href}>
          <Icon name={item.icon} aria-hidden="true" />
          <span>{item.label}</span>
        </a>
      ))}

      <details class="nav-dropdown site-header__more">
        <summary>
          <Icon name="mdi:dots-horizontal-circle-outline" aria-hidden="true" />
          <span>{t('appNav.more')}</span>
        </summary>
        <div class="nav-dropdown__list site-header__more-panel">
          {moreItems.map((item) => (
            <a href={item.href}>
              <Icon name={item.icon} aria-hidden="true" />
              <span>{item.label}</span>
            </a>
          ))}
          <a href={adminDishesPath} data-admin-link hidden>
            <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
            <span>{t('appNav.adminDishes')}</span>
          </a>
        </div>
      </details>

      <details class="locale-menu">
        <summary>{localeLabels[alternateLocales[0] ?? locale]}</summary>
        <div class="locale-menu__list">
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
      </details>

      <details class="nav-dropdown nav-dropdown--settings">
        <summary aria-label={t('appNav.settings')} class="theme-toggle-summary">
          <Icon name="mdi:moon-waning-crescent" aria-hidden="true" />
          <span class="sr-only">{t('appNav.settings')}</span>
        </summary>
        <div class="nav-dropdown__list nav-dropdown__list--settings">
          <label>
            <span>{t('appNav.browserTheme')}</span>
            <select data-global-theme aria-label={t('dashboard.theme')}>
              <option value="system">{t('dashboard.themeSystem')}</option>
              <option value="light">{t('dashboard.themeLight')}</option>
              <option value="dark">{t('dashboard.themeDark')}</option>
            </select>
          </label>
          <button class="settings-trigger" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
        </div>
      </details>
    </nav>

    <details class="mobile-menu" data-mobile-menu>
      <summary data-site-menu-toggle aria-expanded="false" aria-label={t('appNav.openMenu')} aria-controls={panelId}>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div id={panelId} class="mobile-menu__panel" data-site-menu-panel>
        <div class="mobile-menu__head">
          <strong>{t('nav.main')}</strong>
          <small>{localeLabels[locale]}</small>
        </div>
        <nav aria-label={t('nav.main')} class="mobile-menu__nav">
          {primaryItems.map((item) => (
            <a href={item.href}>
              <span>
                <Icon name={item.icon} aria-hidden="true" />
                {item.label}
              </span>
            </a>
          ))}
          <details class="mobile-menu__section">
            <summary>{t('appNav.more')}</summary>
            <div>
              {moreItems.map((item) => (
                <a href={item.href}>
                  <span>
                    <Icon name={item.icon} aria-hidden="true" />
                    {item.label}
                  </span>
                </a>
              ))}
              <a href={adminDishesPath} data-admin-link hidden>
                <span>
                  <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
                  {t('appNav.adminDishes')}
                </span>
              </a>
            </div>
          </details>
        </nav>
        <div class="mobile-menu__languages" aria-label={t('appNav.language')}>
          <strong>{t('appNav.language')}</strong>
          <div>
            {alternateLocales.map((alternateLocale) => (
              <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
            ))}
          </div>
        </div>
        <label class="mobile-menu__theme">
          <span>{t('appNav.browserTheme')}</span>
          <select data-global-theme aria-label={t('dashboard.theme')}>
            <option value="system">{t('dashboard.themeSystem')}</option>
            <option value="light">{t('dashboard.themeLight')}</option>
            <option value="dark">{t('dashboard.themeDark')}</option>
          </select>
        </label>
        <button class="settings-trigger mobile-menu__logout" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
      </div>
    </details>
  </Container>
</header>

<style is:global>
  .app-header {
    border-bottom: 1px solid color-mix(in srgb, var(--color-border), transparent 22%);
    background: color-mix(in srgb, var(--color-bg), transparent 3%);
    box-shadow: 0 0.65rem 1.75rem rgb(15 23 42 / 0.04);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    min-height: 5.8rem;
    padding-block: 0.8rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-brand__mark {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: clamp(3.3rem, 9vw, 4.25rem);
    height: clamp(3.3rem, 9vw, 4.25rem);
    border-radius: 1.35rem;
    background: linear-gradient(135deg, var(--color-primary), color-mix(in srgb, var(--color-primary), #063b34 18%));
    color: #fff;
    font-size: clamp(1rem, 3vw, 1.55rem);
    font-weight: 950;
    letter-spacing: -0.08em;
    box-shadow: 0 1.15rem 2.6rem color-mix(in srgb, var(--color-primary), transparent 72%);
  }

  .site-brand__copy {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
  }

  .site-brand__text {
    overflow: hidden;
    max-width: 58vw;
    color: var(--color-text);
    font-size: clamp(1.1rem, 4.5vw, 1.55rem);
    font-weight: 950;
    letter-spacing: -0.055em;
    line-height: 1.05;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .site-brand__subtitle {
    overflow: hidden;
    max-width: 58vw;
    color: var(--color-muted);
    font-size: clamp(0.86rem, 2.4vw, 1rem);
    font-weight: 800;
    line-height: 1.15;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 2vw, 1.45rem);
    color: var(--color-muted);
    font-size: 1rem;
  }

  .main-nav--desktop {
    display: none;
  }

  .main-nav > a,
  .nav-dropdown summary,
  .locale-menu summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.38rem;
    min-height: 2.8rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: color-mix(in srgb, var(--color-text), var(--color-muted) 28%);
    cursor: pointer;
    padding: 0.45rem 0.25rem;
    font: inherit;
    font-weight: 850;
    list-style: none;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
  }

  .main-nav > a:hover,
  .locale-menu summary:hover,
  .nav-dropdown summary:hover,
  .nav-dropdown[open] summary,
  .locale-menu[open] summary {
    background: transparent;
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .main-nav > a :global(svg),
  .site-header__more > summary :global(svg) {
    display: none;
  }

  .locale-menu summary {
    min-width: 6.1rem;
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 4%);
    background: color-mix(in srgb, var(--color-surface), transparent 4%);
    box-shadow: 0 0.7rem 1.6rem rgb(15 23 42 / 0.05);
    padding-inline: 1.1rem;
    color: var(--color-text);
  }

  .nav-dropdown--settings > summary {
    width: 3.35rem;
    height: 3.35rem;
    min-height: 3.35rem;
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 3%);
    background: color-mix(in srgb, var(--color-surface), transparent 3%);
    box-shadow: 0 0.85rem 1.8rem rgb(15 23 42 / 0.09);
    padding: 0;
    color: var(--color-text);
  }

  .nav-dropdown--settings > summary :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .locale-menu,
  .nav-dropdown {
    position: relative;
  }

  .locale-menu summary::-webkit-details-marker,
  .nav-dropdown summary::-webkit-details-marker,
  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .locale-menu summary::after,
  .nav-dropdown summary::after {
    content: none;
  }

  .locale-menu__list,
  .nav-dropdown__list {
    position: absolute;
    top: calc(100% + 0.55rem);
    right: 0;
    z-index: 40;
    display: grid;
    gap: 0.2rem;
    min-width: 10rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-bg);
    box-shadow: 0 18px 42px rgb(15 23 42 / 0.16);
    padding: 0.45rem;
  }

  .nav-dropdown__list {
    right: auto;
    left: 0;
    min-width: 13rem;
  }

  .nav-dropdown--settings .nav-dropdown__list {
    right: 0;
    left: auto;
  }

  .nav-dropdown__list--settings {
    min-width: 16rem;
  }

  .nav-dropdown__list a,
  .locale-menu__list a,
  .nav-dropdown__list button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: 100%;
    border: 0;
    border-radius: 0.75rem;
    background: transparent;
    color: var(--color-text);
    padding: 0.55rem 0.7rem;
    font: inherit;
    font-weight: 800;
    text-align: left;
    text-decoration: none;
  }

  .locale-menu__list a:hover,
  .nav-dropdown__list a:hover,
  .nav-dropdown__list button:hover {
    background: color-mix(in srgb, var(--color-primary), transparent 88%);
  }

  .nav-dropdown__list--settings label,
  .mobile-menu__theme {
    display: grid;
    gap: 0.4rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .nav-dropdown__list--settings select,
  .mobile-menu__theme select {
    min-height: 2.7rem;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-text);
    padding: 0 0.8rem;
    font: inherit;
    font-weight: 750;
  }

  .mobile-menu {
    position: relative;
    z-index: 45;
    flex: 0 0 auto;
  }

  .mobile-menu > summary {
    display: grid;
    place-items: center;
    gap: 0.22rem;
    width: 3.15rem;
    height: 3.15rem;
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 4%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface), transparent 2%);
    box-shadow: 0 0.85rem 1.8rem rgb(15 23 42 / 0.08);
    cursor: pointer;
    list-style: none;
    touch-action: manipulation;
  }

  .mobile-menu > summary span {
    display: block;
    width: 1.12rem;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text);
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .mobile-menu[open] > summary span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu[open] > summary span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] > summary span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu__panel {
    position: fixed;
    top: 5.85rem;
    right: 0.75rem;
    left: 0.75rem;
    z-index: 44;
    display: grid;
    gap: 0.7rem;
    max-height: calc(100dvh - 6.8rem);
    overflow: auto;
    border: 1px solid var(--color-border);
    border-radius: 1.35rem;
    background: color-mix(in srgb, var(--color-bg), var(--color-primary) 2%);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.24);
    padding: 0.8rem;
  }

  .mobile-menu__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
    padding: 0.25rem 0.3rem 0.55rem;
  }

  .mobile-menu__head strong {
    font-size: 1.05rem;
  }

  .mobile-menu__head small {
    color: var(--color-primary);
    font-weight: 900;
  }

  .mobile-menu__nav,
  .mobile-menu__section,
  .mobile-menu__section > div {
    display: grid;
    gap: 0.35rem;
  }

  .mobile-menu__panel a,
  .mobile-menu__panel button,
  .mobile-menu__section > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 3rem;
    width: 100%;
    border: 0;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-bg), transparent 0%);
    color: var(--color-text);
    padding: 0.75rem 0.9rem;
    font: inherit;
    font-weight: 900;
    list-style: none;
    text-align: left;
    text-decoration: none;
  }

  .mobile-menu__panel a span,
  .mobile-menu__nav a span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .mobile-menu__panel a::after,
  .mobile-menu__panel button::after,
  .mobile-menu__section > summary::after {
    content: '›';
    color: var(--color-muted);
    font-size: 1.25rem;
    line-height: 1;
  }

  .mobile-menu__panel a:hover,
  .mobile-menu__panel button:hover,
  .mobile-menu__section > summary:hover {
    background: color-mix(in srgb, var(--color-primary), transparent 88%);
  }

  .mobile-menu__section[open] > summary::after {
    transform: rotate(90deg);
  }

  .mobile-menu__section > div {
    padding-left: 0.7rem;
  }

  .mobile-menu__section > div a {
    min-height: 2.7rem;
    color: var(--color-muted);
  }

  .mobile-menu__languages {
    display: grid;
    gap: 0.55rem;
    margin-top: 0.1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.7rem;
  }

  .mobile-menu__languages > strong {
    padding: 0 0.3rem;
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mobile-menu__languages > div {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .mobile-menu__languages a {
    justify-content: center;
    min-height: 2.55rem;
    padding: 0.55rem 0.5rem;
    font-size: 0.9rem;
  }

  .mobile-menu__languages a::after {
    display: none;
  }

  .mobile-menu__logout {
    justify-content: center;
  }

  .mobile-menu__nav :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  @media (min-width: 760px) {
    .site-brand__text,
    .site-brand__subtitle {
      max-width: none;
    }

    .header-inner {
      min-height: 7.1rem;
      padding-block: 1rem;
    }
  }

  @media (min-width: 980px) {
    .main-nav--desktop {
      display: flex;
    }

    .mobile-menu {
      display: none;
    }
  }

  @media (max-width: 420px) {
    .header-inner {
      min-height: 5.45rem;
    }

    .site-brand {
      gap: 0.65rem;
    }

    .site-brand__text,
    .site-brand__subtitle {
      max-width: 50vw;
    }

    .site-brand__mark {
      border-radius: 1.1rem;
    }

    .mobile-menu__languages > div {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .app-header {
      background: color-mix(in srgb, var(--color-bg), transparent 4%);
      box-shadow: 0 0.8rem 2rem rgb(0 0 0 / 0.28);
    }

    :root:not([data-theme='light']) .mobile-menu__panel {
      box-shadow: 0 24px 70px rgb(0 0 0 / 0.42);
    }
  }

  :root[data-theme='dark'] .app-header {
    background: color-mix(in srgb, var(--color-bg), transparent 4%);
    box-shadow: 0 0.8rem 2rem rgb(0 0 0 / 0.28);
  }

  :root[data-theme='dark'] .mobile-menu__panel {
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.42);
  }
</style>

<script>
  import '../scripts/app-header.ts';
</script>