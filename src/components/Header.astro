---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { useDishRecommenderTranslations } from '../i18n/dish-recommender';
import { usePlanningTranslations } from '../i18n/planning';
import { useStatisticsTranslations } from '../i18n/statistics';
import { useTupperTranslations } from '../i18n/tuppers';
import { getAlternateLocales, getLocalizedEquivalentPath, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const td = useDishRecommenderTranslations(locale);
const ts = useStatisticsTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/planificador', locale);
const planningPath = getLocalizedPath('/planificador-ai', locale);
// Legacy aliases remain available through redirects: getLocalizedPath('/configurar', locale) and getLocalizedPath('/planificacion', locale).
const dishRecommenderPath = getLocalizedPath('/recomendador-platos', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);
const statisticsPath = getLocalizedPath('/estadisticas', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const adminDishesPath = getLocalizedPath('/admin/platos', locale);
const historyPath = getLocalizedPath('/historico', locale);
const settingsPath = getLocalizedPath('/ajustes', locale);
const alternateLocales = getAlternateLocales(locale);
const panelId = 'site-navigation-panel';
const labels = {
  guestSession: t('menu.guestSession'),
  openMenu: t('appNav.openMenu'),
  closeMenu: t('appNav.closeMenu'),
};

const primaryItems = [
  { href: dashboardPath, icon: 'mdi:home-outline', label: t('appNav.dashboard') },
  { href: configurePath, icon: 'mdi:calendar-edit', label: t('appNav.planning') },
  { href: tuppersPath, icon: 'mdi:food-takeout-box-outline', label: tt('nav') },
  { href: dishesPath, icon: 'mdi:silverware-fork-knife', label: t('appNav.dishes') },
  { href: shoppingPath, icon: 'mdi:cart-outline', label: t('appNav.shopping') },
] as const;

const moreItems = [
  { href: planningPath, icon: 'mdi:creation-outline', label: tp('nav') },
  { href: dishRecommenderPath, icon: 'mdi:chef-hat', label: td('nav') },
  { href: summaryPath, icon: 'mdi:chart-box-outline', label: t('appNav.summary') },
  { href: statisticsPath, icon: 'mdi:chart-line', label: ts('title') },
  { href: historyPath, icon: 'mdi:history', label: t('appNav.history') },
  { href: settingsPath, icon: 'mdi:cog-outline', label: t('appNav.settings') },
] as const;
---

<header class="site-header app-header" data-site-header data-labels={JSON.stringify(labels)}>
  <Container class="header-inner">
    <a class="site-brand" href={homePath} aria-label={siteConfig.name}>
      <span class="site-brand__mark">MD</span>
      <span class="site-brand__text">{siteConfig.name}</span>
    </a>

    <nav aria-label={t('nav.main')} class="main-nav main-nav--desktop">
      {primaryItems.map((item) => (
        <a href={item.href}>
          <Icon name={item.icon} aria-hidden="true" />
          <span>{item.label}</span>
        </a>
      ))}

      <details class="nav-dropdown site-header__more">
        <summary>
          <Icon name="mdi:dots-horizontal-circle-outline" aria-hidden="true" />
          <span>{t('appNav.more')}</span>
        </summary>
        <div class="nav-dropdown__list site-header__more-panel">
          {moreItems.map((item) => (
            <a href={item.href}>
              <Icon name={item.icon} aria-hidden="true" />
              <span>{item.label}</span>
            </a>
          ))}
          <a href={adminDishesPath} data-admin-link hidden>
            <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
            <span>{t('appNav.adminDishes')}</span>
          </a>
        </div>
      </details>

      <details class="locale-menu">
        <summary>{t('appNav.language')}</summary>
        <div class="locale-menu__list">
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
      </details>

      <details class="nav-dropdown nav-dropdown--settings">
        <summary>{t('appNav.settings')}</summary>
        <div class="nav-dropdown__list nav-dropdown__list--settings">
          <label>
            <span>{t('appNav.browserTheme')}</span>
            <select data-global-theme aria-label={t('dashboard.theme')}>
              <option value="system">{t('dashboard.themeSystem')}</option>
              <option value="light">{t('dashboard.themeLight')}</option>
              <option value="dark">{t('dashboard.themeDark')}</option>
            </select>
          </label>
          <button class="settings-trigger" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
        </div>
      </details>
    </nav>

    <details class="mobile-menu" data-mobile-menu>
      <summary data-site-menu-toggle aria-expanded="false" aria-label={t('appNav.openMenu')} aria-controls={panelId}>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div id={panelId} class="mobile-menu__panel" data-site-menu-panel>
        <div class="mobile-menu__head">
          <strong>{t('nav.main')}</strong>
          <small>{localeLabels[locale]}</small>
        </div>
        <nav aria-label={t('nav.main')} class="mobile-menu__nav">
          {primaryItems.map((item) => (
            <a href={item.href}>
              <span>
                <Icon name={item.icon} aria-hidden="true" />
                {item.label}
              </span>
            </a>
          ))}
          <details class="mobile-menu__section">
            <summary>{t('appNav.more')}</summary>
            <div>
              {moreItems.map((item) => (
                <a href={item.href}>
                  <span>
                    <Icon name={item.icon} aria-hidden="true" />
                    {item.label}
                  </span>
                </a>
              ))}
              <a href={adminDishesPath} data-admin-link hidden>
                <span>
                  <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
                  {t('appNav.adminDishes')}
                </span>
              </a>
            </div>
          </details>
        </nav>
        <div class="mobile-menu__languages" aria-label={t('appNav.language')}>
          <strong>{t('appNav.language')}</strong>
          <div>
            {alternateLocales.map((alternateLocale) => (
              <a href={getLocalizedEquivalentPath(Astro.url.pathname, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
            ))}
          </div>
        </div>
        <label class="mobile-menu__theme">
          <span>{t('appNav.browserTheme')}</span>
          <select data-global-theme aria-label={t('dashboard.theme')}>
            <option value="system">{t('dashboard.themeSystem')}</option>
            <option value="light">{t('dashboard.themeLight')}</option>
            <option value="dark">{t('dashboard.themeDark')}</option>
          </select>
        </label>
        <button class="settings-trigger mobile-menu__logout" type="button" data-global-logout hidden>{t('menu.signOut')}</button>
      </div>
    </details>
  </Container>
</header>

<style is:global>
  .app-header {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg), transparent 7%);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-block: 0.7rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
    min-height: 2.65rem;
    color: var(--color-text);
    font-weight: 950;
    letter-spacing: -0.04em;
    text-decoration: none;
  }

  .site-brand__mark {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.8rem;
    background: linear-gradient(135deg, var(--color-primary), color-mix(in srgb, var(--color-primary), #fff 35%));
    color: #fff;
    font-size: 0.78rem;
    letter-spacing: -0.06em;
    box-shadow: 0 10px 24px color-mix(in srgb, var(--color-primary), transparent 68%);
  }

  .site-brand__text {
    overflow: hidden;
    max-width: 58vw;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.94rem;
  }

  .main-nav--desktop {
    display: none;
  }

  .main-nav > a,
  .nav-dropdown summary,
  .locale-menu summary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2.45rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-primary);
    cursor: pointer;
    padding: 0.45rem 0.8rem;
    font: inherit;
    font-weight: 850;
    list-style: none;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base), transform var(--transition-base);
  }

  .main-nav > a {
    color: var(--color-muted);
  }

  .main-nav > a:hover,
  .main-nav > a:focus-visible,
  .nav-dropdown summary:hover,
  .nav-dropdown summary:focus-visible,
  .locale-menu summary:hover,
  .locale-menu summary:focus-visible {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 35%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    outline: 0;
  }

  .main-nav svg,
  .mobile-menu__nav svg {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
  }

  .nav-dropdown,
  .locale-menu {
    position: relative;
  }

  .nav-dropdown summary::-webkit-details-marker,
  .locale-menu summary::-webkit-details-marker,
  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown__list,
  .locale-menu__list {
    position: absolute;
    right: 0;
    top: calc(100% + 0.45rem);
    z-index: var(--z-dropdown);
    display: grid;
    gap: 0.45rem;
    width: max-content;
    min-width: 13rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
    padding: 0.55rem;
  }

  .nav-dropdown__list a,
  .locale-menu__list a,
  .settings-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 0;
    border-radius: var(--radius-lg);
    background: transparent;
    color: var(--color-text);
    padding: 0.65rem 0.75rem;
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  .nav-dropdown__list a:hover,
  .nav-dropdown__list a:focus-visible,
  .locale-menu__list a:hover,
  .locale-menu__list a:focus-visible,
  .settings-trigger:hover,
  .settings-trigger:focus-visible {
    background: var(--color-surface-soft);
    outline: 0;
  }

  .nav-dropdown__list--settings {
    min-width: 16rem;
  }

  .nav-dropdown__list--settings label {
    display: grid;
    gap: 0.4rem;
    padding: 0.6rem;
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .nav-dropdown__list--settings select,
  .mobile-menu__theme select {
    min-height: 2.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0.55rem 0.7rem;
    font: inherit;
  }

  .mobile-menu {
    position: relative;
  }

  .mobile-menu > summary {
    display: grid;
    place-items: center;
    gap: 0.26rem;
    width: 2.65rem;
    height: 2.65rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu > summary span {
    width: 1.15rem;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text);
  }

  .mobile-menu__panel {
    position: fixed;
    inset: 4.2rem 1rem auto;
    z-index: var(--z-dropdown);
    display: grid;
    gap: 1rem;
    max-height: calc(100dvh - 5.4rem);
    overflow: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-lg);
    padding: 1rem;
  }

  .mobile-menu__head,
  .mobile-menu__languages,
  .mobile-menu__theme {
    display: grid;
    gap: 0.45rem;
  }

  .mobile-menu__head small,
  .mobile-menu__languages strong,
  .mobile-menu__theme span {
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .mobile-menu__nav,
  .mobile-menu__section div,
  .mobile-menu__languages div {
    display: grid;
    gap: 0.45rem;
  }

  .mobile-menu__nav a,
  .mobile-menu__section summary,
  .mobile-menu__languages a,
  .mobile-menu__logout {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface-soft);
    color: var(--color-text);
    padding: 0.82rem 0.9rem;
    font-weight: 850;
    text-decoration: none;
  }

  .mobile-menu__nav a span,
  .mobile-menu__section a span {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .mobile-menu__section {
    display: grid;
    gap: 0.55rem;
  }

  .mobile-menu__section summary {
    cursor: pointer;
    list-style: none;
  }

  @media (min-width: 980px) {
    .main-nav--desktop {
      display: flex;
    }

    .mobile-menu {
      display: none;
    }
  }
</style>
