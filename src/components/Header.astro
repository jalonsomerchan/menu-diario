---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { useTupperTranslations } from '../i18n/tuppers';
import { getAlternateLocales, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const planningPath = getLocalizedPath('/planificacion', locale);
const shoppingPath = getLocalizedPath('/compra', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const adminDishesPath = getLocalizedPath('/admin/platos', locale);
const historyPath = getLocalizedPath('/historico', locale);
const settingsPath = getLocalizedPath('/ajustes', locale);
const alternateLocales = getAlternateLocales(locale);
const panelId = 'site-navigation-panel';
const labels = {
  guestSession: t('menu.guestSession'),
  openMenu: t('appNav.openMenu'),
  closeMenu: t('appNav.closeMenu'),
};

const primaryItems = [
  { href: dashboardPath, icon: 'mdi:home-outline', label: t('appNav.dashboard') },
  { href: planningPath, icon: 'mdi:calendar-edit', label: t('appNav.planning') },
  { href: tuppersPath, icon: 'mdi:food-takeout-box-outline', label: tt('nav') },
  { href: dishesPath, icon: 'mdi:silverware-fork-knife', label: t('appNav.dishes') },
  { href: shoppingPath, icon: 'mdi:cart-outline', label: t('appNav.shopping') },
] as const;

const moreItems = [
  { href: summaryPath, icon: 'mdi:chart-box-outline', label: t('appNav.summary') },
  { href: historyPath, icon: 'mdi:history', label: t('appNav.history') },
  { href: settingsPath, icon: 'mdi:cog-outline', label: t('appNav.settings') },
] as const;
---

<header class="site-header" data-site-header data-labels={JSON.stringify(labels)}>
  <Container class="site-header__container">
    <div class="site-header__bar">
      <a class="site-header__brand" href={homePath} aria-label={siteConfig.name}>{siteConfig.name}</a>
      <button
        class="site-header__toggle"
        type="button"
        data-site-menu-toggle
        aria-expanded="false"
        aria-controls={panelId}
        aria-label={t('appNav.openMenu')}
      >
        <Icon name="mdi:menu" aria-hidden="true" />
      </button>
    </div>

    <div class="site-header__panel" id={panelId} data-site-menu-panel>
      <nav class="site-header__nav" aria-label={t('nav.main')}>
        {primaryItems.map((item) => (
          <a class="site-header__nav-link" href={item.href}>
            <Icon name={item.icon} aria-hidden="true" />
            {item.label}
          </a>
        ))}
        <details class="site-header__more">
          <summary class="site-header__more-trigger">
            <Icon name="mdi:dots-horizontal-circle-outline" aria-hidden="true" />
            {t('appNav.more')}
          </summary>

          <div class="site-header__more-panel">
            <div class="site-header__more-links">
              {moreItems.map((item) => (
                <a class="site-header__nav-link" href={item.href}>
                  <Icon name={item.icon} aria-hidden="true" />
                  {item.label}
                </a>
              ))}
              <a class="site-header__nav-link" href={adminDishesPath} data-admin-link hidden>
                <Icon name="mdi:shield-crown-outline" aria-hidden="true" />
                {t('appNav.adminDishes')}
              </a>
            </div>

            <div class="site-header__more-section">
              <p class="site-header__more-label">{t('appNav.language')}</p>
              <div class="site-header__locales">
                {alternateLocales.map((alternateLocale) => (
                  <a href={getLocalizedPath('/', alternateLocale)} hreflang={alternateLocale}>
                    {localeLabels[alternateLocale]}
                  </a>
                ))}
              </div>
            </div>

            <label class="site-header__more-section">
              <span class="site-header__more-label">{t('appNav.browserTheme')}</span>
              <select data-global-theme aria-label={t('dashboard.theme')}>
                <option value="system">{t('dashboard.themeSystem')}</option>
                <option value="light">{t('dashboard.themeLight')}</option>
                <option value="dark">{t('dashboard.themeDark')}</option>
              </select>
            </label>

            <button class="button button--ghost button--small site-header__logout" type="button" data-global-logout hidden>
              <Icon name="mdi:logout" aria-hidden="true" />
              {t('menu.signOut')}
            </button>
          </div>
        </details>
      </nav>
    </div>
  </Container>
</header>

<script>
  import '../scripts/app-header.ts';
</script>
