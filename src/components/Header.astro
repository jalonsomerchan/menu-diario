---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { usePlanningTranslations } from '../i18n/planning';
import { useTupperTranslations } from '../i18n/tuppers';
import { getAlternateLocales, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tp = usePlanningTranslations(locale);
const tt = useTupperTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/configurar', locale);
const summaryPath = getLocalizedPath('/resumen-semanal', locale);
const tuppersPath = getLocalizedPath('/tuppers', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const historyPath = getLocalizedPath('/historico', locale);
const settingsPath = getLocalizedPath('/ajustes', locale);
const alternateLocales = getAlternateLocales(locale);
const panelId = 'site-navigation-panel';
const labels = {
  guestSession: t('menu.guestSession'),
  openMenu: t('appNav.openMenu'),
  closeMenu: t('appNav.closeMenu'),
};
---

<header class="site-header" data-site-header data-labels={JSON.stringify(labels)}>
  <Container class="site-header__container">
    <div class="site-header__bar">
      <a class="site-header__brand" href={homePath} aria-label={siteConfig.name}>{siteConfig.name}</a>
      <button
        class="site-header__toggle"
        type="button"
        data-site-menu-toggle
        aria-expanded="false"
        aria-controls={panelId}
        aria-label={t('appNav.openMenu')}
      >
        <Icon name="mdi:menu" aria-hidden="true" />
      </button>
    </div>

    <div class="site-header__panel" id={panelId} data-site-menu-panel>
      <nav class="site-header__nav" aria-label={t('nav.main')}>
        <a href={homePath}>{t('nav.home')}</a>
        <a href={dashboardPath}><Icon name="mdi:home-outline" aria-hidden="true" />{t('appNav.dashboard')}</a>
        <a href={configurePath}><Icon name="mdi:calendar-edit" aria-hidden="true" />{tp('nav')}</a>
        <a href={summaryPath}><Icon name="mdi:chart-box-outline" aria-hidden="true" />{t('appNav.summary')}</a>
        <a href={tuppersPath}><Icon name="mdi:food-takeout-box-outline" aria-hidden="true" />{tt('nav')}</a>
        <a href={dishesPath}><Icon name="mdi:silverware-fork-knife" aria-hidden="true" />{t('appNav.dishes')}</a>
        <a href={historyPath}><Icon name="mdi:history" aria-hidden="true" />{t('appNav.history')}</a>
        <a href={settingsPath}><Icon name="mdi:cog-outline" aria-hidden="true" />{t('appNav.settings')}</a>
      </nav>

      <div class="site-header__actions">
        <div class="site-header__locales" aria-label={t('nav.main')}>
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedPath('/', alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
        <select data-global-theme aria-label={t('dashboard.theme')}>
          <option value="system">{t('dashboard.themeSystem')}</option>
          <option value="light">{t('dashboard.themeLight')}</option>
          <option value="dark">{t('dashboard.themeDark')}</option>
        </select>
        <button class="button button--ghost button--small" type="button" data-global-logout hidden>
          <Icon name="mdi:logout" aria-hidden="true" />
          {t('menu.signOut')}
        </button>
      </div>
    </div>
  </Container>
</header>

<script>
  import '../scripts/app-header.ts';
</script>