---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  title: t('history.title'),
  description: t('history.description'),
  from: t('history.from'),
  to: t('history.to'),
  query: t('history.query'),
  queryPlaceholder: t('history.queryPlaceholder'),
  status: t('history.status'),
  statusAll: t('history.statusAll'),
  statusPlanned: t('history.statusPlanned'),
  statusSkipped: t('history.statusSkipped'),
  statusEmpty: t('history.statusEmpty'),
  weekday: t('history.weekday'),
  weekdayAll: t('history.weekdayAll'),
  weekdayMonday: t('history.weekdayMonday'),
  weekdayTuesday: t('history.weekdayTuesday'),
  weekdayWednesday: t('history.weekdayWednesday'),
  weekdayThursday: t('history.weekdayThursday'),
  weekdayFriday: t('history.weekdayFriday'),
  weekdaySaturday: t('history.weekdaySaturday'),
  weekdaySunday: t('history.weekdaySunday'),
  search: t('history.search'),
  empty: t('history.empty'),
  editDay: t('dashboard.editDay'),
  deleteDay: t('dashboard.deleteDay'),
  quickEdit: t('dashboard.quickEdit'),
  moreActions: t('dashboard.moreActions'),
  save: t('dashboard.save'),
  cancel: t('dashboard.cancel'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  addDish: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  todayEmpty: t('dashboard.todayEmpty'),
  skipSummary: t('dashboard.skipSummary'),
  permissionsError: t('menu.permissionsError'),
  offlineReadOnly: t('pwa.offlineReadOnly'),
  guestSession: t('menu.guestSession'),
  homePath,
};
---

<section class="history-app" data-history-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>
  <div data-content hidden>
    <section class="settings-card app-panel">
      <p class="menu-app__eyebrow">{labels.title}</p>
      <h1>{labels.title}</h1>
      <p>{labels.description}</p>
      <form class="history-search" data-history-form>
        <label>{labels.from}<input type="date" data-date-from /></label>
        <label>{labels.to}<input type="date" data-date-to /></label>
        <label>{labels.query}<input type="search" data-history-query placeholder={labels.queryPlaceholder} /></label>
        <label>
          {labels.status}
          <select data-history-status>
            <option value="all">{labels.statusAll}</option>
            <option value="planned">{labels.statusPlanned}</option>
            <option value="skipped">{labels.statusSkipped}</option>
            <option value="empty">{labels.statusEmpty}</option>
          </select>
        </label>
        <label>
          {labels.weekday}
          <select data-history-weekday>
            <option value="all">{labels.weekdayAll}</option>
            <option value="1">{labels.weekdayMonday}</option>
            <option value="2">{labels.weekdayTuesday}</option>
            <option value="3">{labels.weekdayWednesday}</option>
            <option value="4">{labels.weekdayThursday}</option>
            <option value="5">{labels.weekdayFriday}</option>
            <option value="6">{labels.weekdaySaturday}</option>
            <option value="7">{labels.weekdaySunday}</option>
          </select>
        </label>
        <div class="history-search__actions">
          <button class="button button--primary" type="submit">{labels.search}</button>
        </div>
      </form>
    </section>
    <div class="next-days next-days--timeline" data-history-days></div>
  </div>

  <DayEditModal
    eyebrow={labels.quickEdit}
    title={labels.quickEdit}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<script>
  import '../scripts/history-app.ts';
</script>
