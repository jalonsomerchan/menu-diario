---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from './Container.astro';
import AuthGate from './AuthGate.astro';
import { siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';
import '../styles/home-landing.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const copy = {
  title: t('home.landingTitle'),
  subtitle: t('home.landingSubtitle'),
  cards: [
    {
      title: t('home.landingCardWeekTitle'),
      description: t('home.landingCardWeekDescription'),
    },
    {
      title: t('home.landingCardGroupTitle'),
      description: t('home.landingCardGroupDescription'),
    },
    {
      title: t('home.landingCardIdeasTitle'),
      description: t('home.landingCardIdeasDescription'),
    },
  ],
};
---

<BaseLayout title={siteConfig.name} description={t('site.description')} locale={locale}>
  <Container class="home-landing-container" size="page">
    <section class="home-landing-hero" aria-labelledby="home-title">
      <div class="home-landing-hero__copy">
        <p class="home-landing-hero__eyebrow">{t('home.eyebrow')}</p>
        <h1 id="home-title">{copy.title}</h1>
        <p class="home-landing-hero__subtitle">{copy.subtitle}</p>
        <div class="home-landing-hero__auth" id="login">
          <AuthGate locale={locale} showGuest={false} />
        </div>
      </div>

      <div class="home-landing-preview" aria-hidden="true">
        <div class="home-landing-preview__chrome">
          <span></span><span></span><span></span>
        </div>
        <div class="home-landing-preview__week">
          {Array.from({ length: 7 }, (_, index) => (
            <span class:list={{ 'is-selected': index === 2 }}></span>
          ))}
        </div>
        <div class="home-landing-preview__meal home-landing-preview__meal--primary">
          <span></span>
          <div><i></i><i></i></div>
        </div>
        <div class="home-landing-preview__meal home-landing-preview__meal--secondary">
          <span></span>
          <div><i></i><i></i></div>
        </div>
        <div class="home-landing-preview__status"><span></span></div>
      </div>
    </section>

    <section class="home-landing-grid" aria-label={t('home.eyebrow')}>
      {copy.cards.map((card, index) => (
        <article class="home-landing-card">
          <span class="home-landing-card__index" aria-hidden="true">{index + 1}</span>
          <h2>{card.title}</h2>
          <p>{card.description}</p>
        </article>
      ))}
    </section>
  </Container>
</BaseLayout>
