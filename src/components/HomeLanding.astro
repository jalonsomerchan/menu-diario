---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import AuthGate from './AuthGate.astro';
import HomeCookingSeoLinks from './HomeCookingSeoLinks.astro';
import { siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const features = [
  { icon: 'mdi:calendar-week', title: t('home.featureHistory'), description: t('home.featureHistoryDescription') },
  { icon: 'mdi:account-group-outline', title: t('home.featureShare'), description: t('home.featureShareDescription') },
  { icon: 'mdi:creation-outline', title: t('home.featureNotifications'), description: t('home.featureNotificationsDescription') },
] as const;

const previewDays = [
  { day: t('home.previewMonday'), meal: t('home.previewMondayMeal'), tone: 'blue' },
  { day: t('home.previewTuesday'), meal: t('home.previewTuesdayMeal'), tone: 'green' },
  { day: t('home.previewWednesday'), meal: t('home.previewWednesdayMeal'), tone: 'orange' },
] as const;
---

<BaseLayout title={siteConfig.name} description={t('site.description')} locale={locale}>
  <Container class="home-landing-container" size="page">
    <section class="home-landing-hero" aria-labelledby="home-title">
      <div class="home-landing-hero__content">
        <p class="home-landing-hero__eyebrow">
          <span aria-hidden="true"></span>{t('home.eyebrow')}
        </p>
        <h1 id="home-title">{t('home.title')}</h1>
        <p class="home-landing-hero__description">{t('home.description')}</p>
        <div class="home-landing-hero__auth" id="login">
          <AuthGate locale={locale} showGuest={false} />
        </div>
        <p class="home-landing-hero__note">
          <Icon name="mdi:shield-check-outline" aria-hidden="true" />
          {t('home.privacyNote')}
        </p>
      </div>

      <div class="home-preview" aria-label={t('home.previewLabel')}>
        <div class="home-preview__topbar">
          <span aria-hidden="true"></span>
          <strong>{t('home.previewTitle')}</strong>
          <Icon name="mdi:dots-horizontal" aria-hidden="true" />
        </div>
        <div class="home-preview__summary">
          <span>{t('home.previewWeek')}</span>
          <strong>{t('home.previewProgress')}</strong>
        </div>
        <div class="home-preview__days">
          {previewDays.map((item, index) => (
            <article class:list={['home-preview__day', `home-preview__day--${item.tone}`]}>
              <span>{index + 1}</span>
              <div>
                <strong>{item.day}</strong>
                <small>{item.meal}</small>
              </div>
              <Icon name="mdi:chevron-right" aria-hidden="true" />
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-landing-grid" aria-labelledby="home-features-title">
      <header class="home-landing-grid__header">
        <p>{t('home.featuresEyebrow')}</p>
        <h2 id="home-features-title">{t('home.featuresTitle')}</h2>
      </header>
      {features.map((feature) => (
        <article class="home-landing-card">
          <span class="home-landing-card__icon"><Icon name={feature.icon} aria-hidden="true" /></span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </article>
      ))}
    </section>

    <HomeCookingSeoLinks locale={locale} />
  </Container>
</BaseLayout>

<style>
  .home-landing-container {
    padding-block: clamp(1.5rem, 5vw, 4rem) clamp(4rem, 8vw, 7rem);
  }

  .home-landing-hero {
    display: grid;
    align-items: center;
    gap: clamp(2rem, 6vw, 4.5rem);
    border: 1px solid var(--panel-border);
    border-radius: clamp(1.75rem, 4vw, 2.75rem);
    background:
      radial-gradient(circle at 12% 15%, color-mix(in srgb, var(--color-primary-soft), transparent 22%), transparent 19rem),
      var(--panel-background-strong);
    box-shadow: var(--shadow-md);
    padding: clamp(1.4rem, 5vw, 4rem);
    overflow: hidden;
  }

  .home-landing-hero__content {
    display: grid;
    justify-items: start;
    gap: 1.25rem;
    min-width: 0;
  }

  .home-landing-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-primary);
    font-size: 0.82rem;
    font-weight: 720;
    letter-spacing: 0.01em;
  }

  .home-landing-hero__eyebrow span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--color-success);
    box-shadow: 0 0 0 0.3rem var(--color-success-soft);
  }

  .home-landing-hero h1 {
    max-width: 13ch;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.7rem, 7.2vw, 5.15rem);
    font-weight: 720;
    letter-spacing: -0.062em;
    line-height: 0.97;
    text-wrap: balance;
  }

  .home-landing-hero p {
    margin: 0;
  }

  .home-landing-hero__description {
    max-width: 42rem;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    line-height: 1.5;
  }

  .home-landing-hero__auth {
    width: 100%;
    margin-top: 0.35rem;
  }

  .home-landing-hero__note {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-muted);
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .home-landing-hero__note svg {
    width: 1rem;
    height: 1rem;
    color: var(--color-success);
  }

  .home-preview {
    display: grid;
    gap: 1rem;
    width: min(100%, 26rem);
    justify-self: center;
    border: 1px solid color-mix(in srgb, var(--color-border), white 30%);
    border-radius: 2rem;
    background: color-mix(in srgb, var(--color-surface-raised), transparent 4%);
    box-shadow: var(--shadow-lg);
    padding: 0.85rem;
    transform: rotate(1.2deg);
  }

  .home-preview__topbar,
  .home-preview__summary,
  .home-preview__day {
    display: flex;
    align-items: center;
  }

  .home-preview__topbar {
    justify-content: space-between;
    min-height: 2.5rem;
    padding-inline: 0.5rem;
    font-size: 0.82rem;
  }

  .home-preview__topbar > span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .home-preview__topbar svg,
  .home-preview__day > svg {
    width: 1.15rem;
    height: 1.15rem;
    color: var(--color-muted);
  }

  .home-preview__summary {
    justify-content: space-between;
    gap: 1rem;
    border-radius: 1.25rem;
    background: var(--color-primary-soft);
    padding: 1rem;
    color: var(--color-primary);
    font-size: 0.8rem;
  }

  .home-preview__days {
    display: grid;
    gap: 0.55rem;
  }

  .home-preview__day {
    gap: 0.8rem;
    min-height: 4.25rem;
    border: 1px solid var(--color-border);
    border-radius: 1.15rem;
    padding: 0.65rem 0.75rem;
  }

  .home-preview__day > span {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.9rem;
    background: var(--preview-color-soft, var(--color-primary-soft));
    color: var(--preview-color, var(--color-primary));
    font-weight: 760;
  }

  .home-preview__day > div {
    display: grid;
    flex: 1;
    gap: 0.1rem;
    min-width: 0;
  }

  .home-preview__day strong { font-size: 0.9rem; }
  .home-preview__day small { overflow: hidden; color: var(--color-muted); font-size: 0.77rem; text-overflow: ellipsis; white-space: nowrap; }
  .home-preview__day--green { --preview-color: var(--color-success); --preview-color-soft: var(--color-success-soft); }
  .home-preview__day--orange { --preview-color: var(--color-accent); --preview-color-soft: var(--color-accent-soft); }

  .home-landing-grid__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .home-landing-grid__header p,
  .home-landing-grid__header h2 {
    margin: 0;
  }

  .home-landing-grid__header p {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 720;
  }

  .home-landing-grid__header h2 {
    max-width: 16ch;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.052em;
  }

  .home-landing-grid {
    display: grid;
    gap: 1rem;
    margin-top: clamp(3.5rem, 8vw, 6rem);
  }

  .home-landing-card {
    display: grid;
    align-content: start;
    gap: 0.8rem;
    border: 1px solid var(--panel-border);
    border-radius: clamp(1.2rem, 3vw, 1.9rem);
    background: var(--panel-background);
    box-shadow: var(--shadow-xs);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    transition: transform var(--transition-spring), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .home-landing-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-0.2rem);
  }

  .home-landing-card__icon {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    margin-bottom: 0.35rem;
    border-radius: 1rem;
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .home-landing-card__icon svg { width: 1.35rem; height: 1.35rem; }

  .home-landing-card h3 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    font-weight: 680;
    letter-spacing: -0.035em;
    line-height: 1.1;
  }

  .home-landing-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.7vw, 1.08rem);
    font-weight: 420;
    letter-spacing: -0.025em;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .home-landing-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .home-landing-grid__header { grid-column: 1 / -1; }
  }

  @media (min-width: 900px) {
    .home-landing-hero { grid-template-columns: minmax(0, 1.15fr) minmax(19rem, 0.85fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-preview { transform: none; }
    .home-landing-card:hover { transform: none; }
  }
</style>
