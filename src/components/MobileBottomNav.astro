---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { stripBasePath } from '../utils/paths';

interface Props {
  locale: Locale;
}

type NavItem = {
  href: string;
  icon: string;
  label: string;
  match: string[];
};

const { locale } = Astro.props;
const t = useTranslations(locale);
const currentPath = stripBasePath(Astro.url.pathname).replace(/\/$/, '') || '/';
const shoppingLabel = t('appNav.shopping');

const items: NavItem[] = [
  {
    href: getLocalizedPath('/dashboard', locale),
    icon: 'mdi:home-outline',
    label: t('appNav.dashboard'),
    match: ['/dashboard'],
  },
  {
    href: getLocalizedPath('/planificador', locale),
    icon: 'mdi:calendar-edit',
    label: t('appNav.week'),
    match: ['/planificador', '/configurar', '/planificacion'],
  },
  {
    href: getLocalizedPath('/compras', locale),
    icon: 'mdi:cart-outline',
    label: shoppingLabel,
    match: ['/compras'],
  },
  {
    href: getLocalizedPath('/mas', locale),
    icon: 'mdi:dots-horizontal',
    label: t('appNav.more'),
    match: [
      '/mas',
      '/ajustes',
      '/compra',
      '/tuppers',
      '/mis-platos',
      '/historico',
      '/estadisticas',
      '/resumen-semanal',
      '/recomendador-platos',
      '/planificador-ai',
    ],
  },
];

function isActive(item: NavItem) {
  return item.match.some((path) => currentPath === path || currentPath.endsWith(path));
}
---

<nav class="mobile-bottom-nav" aria-label={t('nav.main')}>
  <ul class="mobile-bottom-nav__list">
    {items.map((item) => {
      const active = isActive(item);
      return (
        <li>
          <a
            class:list={['mobile-bottom-nav__link', { 'mobile-bottom-nav__link--active': active }]}
            href={item.href}
            aria-current={active ? 'page' : undefined}
          >
            <Icon name={item.icon} aria-hidden="true" />
            <span>{item.label}</span>
          </a>
        </li>
      );
    })}
  </ul>
</nav>
