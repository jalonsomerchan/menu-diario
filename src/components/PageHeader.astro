---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="page-header">
  {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
  <h1 class="page-header__title">{title}</h1>
  {description && <p class="page-header__description">{description}</p>}
  <slot />
</header>

<style>
  .page-header {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 1.2rem;
    padding: clamp(1.15rem, 3vw, 1.9rem);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-2xl);
    background: var(--panel-background-strong);
    box-shadow: var(--shadow-sm);
  }

  .page-header__eyebrow {
    width: fit-content;
    margin: 0;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 15%);
    color: var(--color-primary);
    padding: 0.28rem 0.72rem;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .page-header__title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 0.94;
    letter-spacing: -0.07em;
  }

  .page-header__description {
    margin: 0;
    max-width: 72ch;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.4vw, 1.15rem);
    line-height: var(--surface-copy-line-height);
    letter-spacing: var(--surface-copy-letter-spacing);
  }
</style>
