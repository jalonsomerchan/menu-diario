---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="page-header">
  {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
  <h1 class="page-header__title">{title}</h1>
  {description && <p class="page-header__description">{description}</p>}
  <slot />
</header>

<style>
  .page-header {
    display: grid;
    gap: 0.45rem;
    margin-bottom: clamp(1.1rem, 2.6vw, 1.55rem);
    max-width: 76ch;
  }

  .page-header__eyebrow {
    width: fit-content;
    margin: 0;
    border-radius: var(--radius-full);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    padding: 0.28rem 0.72rem;
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0;
    text-transform: none;
  }

  .page-header__title {
    margin: 0;
    font-size: clamp(1.65rem, 4.5vw, 2.25rem);
    font-weight: 560;
    line-height: 1.08;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .page-header__description {
    margin: 0;
    max-width: 72ch;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 2.2vw, 1.08rem);
    line-height: var(--surface-copy-line-height);
    letter-spacing: var(--surface-copy-letter-spacing);
  }
</style>
