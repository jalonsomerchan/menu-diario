---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="page-header">
  {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
  <h1 class="page-header__title">{title}</h1>
  {description && <p class="page-header__description">{description}</p>}
  <slot />
</header>

<style>
  .page-header {
    display: grid;
    gap: 0.6rem;
    margin-bottom: clamp(1.4rem, 3.4vw, 2.2rem);
    max-width: 76ch;
  }

  .page-header__eyebrow {
    width: fit-content;
    margin: 0;
    border-radius: var(--radius-full);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    padding: 0.34rem 0.72rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.035em;
    text-transform: none;
  }

  .page-header__title {
    margin: 0;
    font-size: clamp(2.2rem, 7vw, 4.6rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.062em;
    text-wrap: balance;
  }

  .page-header__description {
    margin: 0;
    max-width: 72ch;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.2vw, 1.16rem);
    line-height: var(--surface-copy-line-height);
    letter-spacing: var(--surface-copy-letter-spacing);
  }
</style>
