---
import type { Locale } from '../config/site';
import DayEditModal from './DayEditModal.astro';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const configurePath = getLocalizedPath('/configurar', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const headingCopy = {
  title: t('planningAi.title'),
  description: t('planningAi.description'),
};

const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  eyebrow: t('planningAi.eyebrow'),
  title: headingCopy.title,
  description: headingCopy.description,
  formTitle: t('planningAi.formTitle'),
  formDescription: t('planningAi.formDescription'),
  quickTitle: t('planningAi.quickTitle'),
  presetShort: t('planningAi.presetShort'),
  presetWeek: t('planningAi.presetWeek'),
  presetLong: t('planningAi.presetLong'),
  start: t('planningAi.start'),
  end: t('planningAi.end'),
  meals: t('planningAi.meals'),
  recommendationCount: t('planningAi.recommendationCount'),
  recommendationHint: t('planningAi.recommendationHint'),
  mode: t('planningAi.mode'),
  modeOwn: t('planningAi.modeOwn'),
  modeOwnHint: t('planningAi.modeOwnHint'),
  modeNew: t('planningAi.modeNew'),
  modeNewHint: t('planningAi.modeNewHint'),
  modeMix: t('planningAi.modeMix'),
  modeMixHint: t('planningAi.modeMixHint'),
  summaryTitle: t('planningAi.summaryTitle'),
  summaryRange: t('planningAi.summaryRange'),
  summaryMeals: t('planningAi.summaryMeals'),
  summaryMode: t('planningAi.summaryMode'),
  summaryIdeas: t('planningAi.summaryIdeas'),
  daysSingular: t('planningAi.daysSingular'),
  daysPlural: t('planningAi.daysPlural'),
  mealsSingular: t('planningAi.mealsSingular'),
  mealsPlural: t('planningAi.mealsPlural'),
  ideasSuffix: t('planningAi.ideasSuffix'),
  submit: t('planningAi.submit'),
  pendingTitle: t('planningAi.pendingTitle'),
  pendingDescription: t('planningAi.pendingDescription'),
  pendingEmpty: t('planningAi.pendingEmpty'),
  resultsTitle: t('planningAi.resultsTitle'),
  resultsDescription: t('planningAi.resultsDescription'),
  generateOnNext: t('planningAi.generateOnNext'),
  resultsEmpty: t('planningAi.resultsEmpty'),
  resultsNotGenerated: t('planningAi.resultsNotGenerated'),
  foodIntolerancesTitle: t('settings.foodIntolerancesTitle'),
  foodIntolerancesDescription: t('settings.foodIntolerancesDescription'),
  foodIntolerancesLabel: t('settings.foodIntolerancesLabel'),
  foodIntolerancesPlaceholder: t('settings.foodIntolerancesPlaceholder'),
  openManual: t('planningAi.openManual'),
  manageDishes: t('planningAi.manageDishes'),
  applySelection: t('planningAi.applySelection'),
  addDish: t('planningAi.addDish'),
  added: t('planningAi.added'),
  applied: t('planningAi.applied'),
  reasonLabel: t('planningAi.reasonLabel'),
  originGlobal: t('planningAi.originGlobal'),
  originGroup: t('planningAi.originGroup'),
  originUser: t('planningAi.originUser'),
  originNew: t('planningAi.originNew'),
  newBadge: t('planningAi.newBadge'),
  noOwnDishes: t('planningAi.noOwnDishes'),
  invalidRange: t('planningAi.invalidRange'),
  loadingSlots: t('planningAi.loadingSlots'),
  loadingPlan: t('planningAi.loadingPlan'),
  generated: t('planningAi.generated'),
  wizardBack: t('menu.previous'),
  wizardNext: t('menu.next'),
  aiLoading: t('ai.loading'),
  aiError: t('ai.error'),
  aiMissingConfig: t('ai.missingConfig'),
  'ai.loading': t('ai.loading'),
  'ai.error': t('ai.error'),
  'ai.quotaExhausted': t('ai.quotaExhausted'),
  'ai.missingConfig': t('ai.missingConfig'),
  'ai.appCheckUnavailable': t('ai.appCheckUnavailable'),
  'ai.invalidResponse': t('ai.invalidResponse'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  cancel: t('dashboard.cancel'),
  save: t('dashboard.save'),
  deleteDay: t('dashboard.deleteDay'),
  saveHint: t('menu.saveHint'),
  savePending: t('menu.savePending'),
  discardChangesTitle: t('menu.discardChangesTitle'),
  discardChangesDescription: t('menu.discardChangesDescription'),
  discardChangesAction: t('menu.discardChangesAction'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  addDishLabel: t('dashboard.addDish'),
  addPlate: t('dashboard.addPlate'),
  removePlate: t('dashboard.removePlate'),
  showDishOptions: t('dashboard.showDishOptions'),
  dishSuggestions: t('dashboard.dishSuggestions'),
  dishPlaceholder: t('dashboard.dishPlaceholder'),
  dailyOptionsTitle: t('dailyOptions.dayTitle'),
  dailyOptionsDescription: t('dailyOptions.dayDescription'),
  dailyOptionsSummary: t('dailyOptions.summaryLabel'),
  noMeal: t('dashboard.noMeal'),
  noDay: t('dashboard.noDay'),
  reason: t('dashboard.reason'),
  reasonAway: t('dashboard.reasonAway'),
  reasonEatingOut: t('dashboard.reasonEatingOut'),
  reasonNotHungry: t('dashboard.reasonNotHungry'),
  reasonOther: t('dashboard.reasonOther'),
  reasonDescription: t('dashboard.reasonDescription'),
  notes: t('menu.notes'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  homePath,
};

const wizardSteps = [
  labels.quickTitle,
  labels.meals,
  labels.pendingTitle,
  labels.foodIntolerancesTitle,
  labels.recommendationCount,
  labels.mode,
  labels.summaryTitle,
  labels.resultsTitle,
];
---

<section class="planning-ai-app" data-planning-ai-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <section class="planning-ai-intro app-page-intro app-panel" aria-labelledby="planning-ai-title">
      <div class="app-page-intro__copy">
        <span class="app-page-intro__eyebrow">{labels.eyebrow}</span>
        <h1 id="planning-ai-title">{labels.title}</h1>
        <p>{labels.description}</p>
      </div>
      <div class="app-page-intro__actions">
        <a class="button button--ghost" href={configurePath}>{labels.openManual}</a>
        <a class="button button--secondary" href={dishesPath}>{labels.manageDishes}</a>
      </div>
    </section>

    <section class="planning-ai-panel app-panel" aria-labelledby="planning-ai-form-title" data-plan-scroll-target>
      <h2 id="planning-ai-form-title" class="sr-only">{labels.title}</h2>

      <form class="planning-ai-form" data-plan-form data-plan-wizard>
        <ol class="planning-ai-wizard-progress" aria-label={labels.formTitle}>
          {wizardSteps.map((step, index) => (
            <li>
              <button type="button" class="planning-ai-wizard-step" data-plan-step-indicator={index} aria-current={index === 0 ? 'step' : undefined}>
                <span>{index + 1}</span>
                <strong>{step}</strong>
              </button>
            </li>
          ))}
        </ol>

        <section class="planning-ai-section-card" data-plan-step="0">
          <div class="planning-ai-section-heading">
            <h3>{labels.quickTitle}</h3>
          </div>

          <div class="planning-ai-preset-row" role="group" aria-label={labels.quickTitle}>
            <button class="planning-ai-chip-button" type="button" data-plan-preset="3">{labels.presetShort}</button>
            <button class="planning-ai-chip-button" type="button" data-plan-preset="7">{labels.presetWeek}</button>
            <button class="planning-ai-chip-button" type="button" data-plan-preset="14">{labels.presetLong}</button>
          </div>

          <label class="planning-ai-date-range-field">
            <span>{labels.start} / {labels.end}</span>
            <input type="text" inputmode="none" aria-describedby="planning-ai-date-range-error" data-plan-date-range />
          </label>
          <p
            id="planning-ai-date-range-error"
            class="planning-ai-results-status"
            data-plan-range-error
            data-variant="error"
            role="alert"
            hidden
          ></p>
          <input type="hidden" data-plan-start />
          <input type="hidden" data-plan-end />
        </section>

        <section class="planning-ai-section-card" data-plan-step="1" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.meals}</h3>
          </div>

          <fieldset class="planning-ai-form__meals">
            <legend class="sr-only">{labels.meals}</legend>
            <label class="planning-ai-toggle-card"><input type="checkbox" value="breakfast" data-plan-meal /> <span>{labels.breakfast}</span></label>
            <label class="planning-ai-toggle-card"><input type="checkbox" value="lunch" data-plan-meal /> <span>{labels.lunch}</span></label>
            <label class="planning-ai-toggle-card"><input type="checkbox" value="dinner" data-plan-meal /> <span>{labels.dinner}</span></label>
          </fieldset>
        </section>

        <section class="planning-ai-section-card" data-plan-step="2" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.pendingTitle}</h3>
            <p>{labels.pendingDescription}</p>
          </div>
          <div class="planning-ai-pending" data-plan-pending>
            <p class="planning-ai-empty">{labels.resultsNotGenerated}</p>
          </div>
        </section>

        <section class="planning-ai-section-card" data-plan-step="3" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.foodIntolerancesTitle}</h3>
            <p>{labels.foodIntolerancesDescription}</p>
          </div>
          <label class="planning-ai-textarea-field">
            <span>{labels.foodIntolerancesLabel}</span>
            <textarea rows="5" maxlength="1000" data-plan-intolerances placeholder={labels.foodIntolerancesPlaceholder}></textarea>
          </label>
        </section>

        <section class="planning-ai-section-card" data-plan-step="4" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.recommendationCount}</h3>
            <p>{labels.recommendationHint}</p>
          </div>

          <div class="planning-ai-count-row" role="group" aria-label={labels.recommendationCount}>
            <button class="planning-ai-chip-button" type="button" data-plan-count-option="1">1</button>
            <button class="planning-ai-chip-button" type="button" data-plan-count-option="2">2</button>
            <button class="planning-ai-chip-button" type="button" data-plan-count-option="3" aria-pressed="true">3</button>
            <button class="planning-ai-chip-button" type="button" data-plan-count-option="4">4</button>
            <button class="planning-ai-chip-button" type="button" data-plan-count-option="5">5</button>
          </div>
          <input type="hidden" value="3" data-plan-count />
        </section>

        <section class="planning-ai-section-card" data-plan-step="5" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.mode}</h3>
          </div>

          <fieldset class="planning-ai-form__modes">
            <legend class="sr-only">{labels.mode}</legend>
            <label class="planning-ai-mode-card">
              <input type="radio" name="planning-mode" value="own" data-plan-mode />
              <strong>{labels.modeOwn}</strong>
              <span>{labels.modeOwnHint}</span>
            </label>
            <label class="planning-ai-mode-card">
              <input type="radio" name="planning-mode" value="new" data-plan-mode />
              <strong>{labels.modeNew}</strong>
              <span>{labels.modeNewHint}</span>
            </label>
            <label class="planning-ai-mode-card">
              <input type="radio" name="planning-mode" value="mix" data-plan-mode checked />
              <strong>{labels.modeMix}</strong>
              <span>{labels.modeMixHint}</span>
            </label>
          </fieldset>
        </section>

        <section class="planning-ai-request-card" aria-live="polite" data-plan-step="6" data-plan-generate-step="true" hidden>
          <div class="planning-ai-section-heading">
            <h3>{labels.summaryTitle}</h3>
            <p>{labels.generateOnNext}</p>
          </div>
          <div class="planning-ai-request-summary" data-plan-summary></div>
        </section>

        <section class="planning-ai-request-card" aria-live="polite" data-plan-step="7" hidden>
          <section class="planning-ai-results-panel" aria-labelledby="planning-ai-results-title">
            <div class="planning-ai-section-heading">
              <h3 id="planning-ai-results-title">{labels.resultsTitle}</h3>
              <p>{labels.resultsDescription}</p>
            </div>
            <div class="planning-ai-results-status" data-ai-status role="status" aria-live="polite"></div>
            <div class="planning-ai-results" data-plan-results>
              <p class="planning-ai-empty">{labels.resultsNotGenerated}</p>
            </div>
          </section>
        </section>

        <div class="planning-ai-wizard-actions">
          <button class="button button--ghost" type="button" data-plan-wizard-back>{labels.wizardBack}</button>
          <button class="button button--secondary" type="button" data-plan-wizard-next>{labels.wizardNext}</button>
          <button class="button button--primary planning-ai-submit" type="submit" data-plan-submit hidden>{labels.submit}</button>
        </div>
      </form>
    </section>
  </div>

  <DayEditModal
    eyebrow={labels.eyebrow}
    title={labels.title}
    cancelLabel={labels.cancel}
    saveLabel={labels.save}
    clearLabel={labels.deleteDay}
    saveHint={labels.saveHint}
    savePendingLabel={labels.savePending}
  />
</section>

<style is:global>
  .planning-ai-app {
    display: grid;
    gap: 0.9rem;
  }

  .planning-ai-panel {
    display: grid;
    gap: 0.9rem;
    background: var(--panel-background);
  }

  .planning-ai-form,
  .planning-ai-form__dates,
  .planning-ai-form__meals,
  .planning-ai-form__modes,
  .planning-ai-pending,
  .planning-ai-results {
    display: grid;
    gap: 0.85rem;
  }

  .planning-ai-wizard-progress {
    display: flex;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .planning-ai-wizard-progress::-webkit-scrollbar { display: none; }

  .planning-ai-wizard-progress li {
    flex: 0 0 7.5rem;
  }

  .planning-ai-wizard-step {
    display: grid;
    gap: 0.22rem;
    width: 100%;
    min-height: 3.55rem;
    align-content: center;
    padding: 0.7rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    color: var(--color-muted);
    font: inherit;
    text-align: left;
    box-shadow: none;
  }

  .planning-ai-wizard-step span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    justify-self: start;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 5%);
    color: var(--color-text);
    font-size: 0.74rem;
    font-weight: 900;
  }

  .planning-ai-wizard-step strong {
    overflow: hidden;
    font-size: 0.76rem;
    font-weight: 820;
    line-height: 1.2;
    text-wrap: balance;
  }

  .planning-ai-wizard-step[aria-current='step'] {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 16%);
    color: var(--color-primary);
  }

  .planning-ai-wizard-step[aria-current='step'] span {
    background: var(--color-primary);
    color: var(--color-on-primary, #fff);
  }

  .planning-ai-wizard-actions {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    justify-content: flex-end;
    padding-top: 0.15rem;
  }

  .planning-ai-wizard-actions .button {
    flex: 1 1 0;
    min-width: 0;
  }

  .planning-ai-section-card,
  .planning-ai-request-card {
    display: grid;
    gap: 0.8rem;
    padding: var(--surface-padding-tight);
    padding-bottom: max(var(--surface-padding-tight), 1rem);
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 4%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface), transparent 2%);
    box-shadow: none;
  }

  .planning-ai-results-panel {
    display: grid;
    gap: 0.8rem;
  }

  .planning-ai-section-heading {
    display: grid;
    gap: 0.3rem;
  }

  .planning-ai-section-heading h3 {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .planning-ai-section-heading p {
    margin: 0;
  }

  .planning-ai-form__dates {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .planning-ai-form label,
  .planning-ai-form legend {
    font-weight: 800;
    color: var(--color-text);
  }

  .planning-ai-form label:not(.planning-ai-toggle-card):not(.planning-ai-mode-card) span {
    display: inline-flex;
    margin-bottom: 0.45rem;
    line-height: var(--surface-copy-line-height);
  }

  .planning-ai-date-range-field,
  .planning-ai-textarea-field {
    display: grid;
    gap: 0.45rem;
  }

  .planning-ai-date-range-field input,
  .planning-ai-textarea-field textarea {
    width: 100%;
  }

  .planning-ai-textarea-field textarea {
    resize: vertical;
  }

  body .flatpickr-calendar {
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    color: var(--color-text);
    box-shadow: var(--shadow-md);
    font-family: inherit;
  }

  body .flatpickr-calendar.arrowTop::before {
    border-bottom-color: var(--color-border);
  }

  body .flatpickr-calendar.arrowTop::after {
    border-bottom-color: var(--color-surface-raised);
  }

  body .flatpickr-months .flatpickr-month,
  body .flatpickr-current-month .flatpickr-monthDropdown-months,
  body .flatpickr-current-month input.cur-year,
  body span.flatpickr-weekday {
    background: transparent;
    color: var(--color-text);
  }

  body .flatpickr-months .flatpickr-prev-month,
  body .flatpickr-months .flatpickr-next-month {
    color: var(--color-muted);
    fill: currentColor;
  }

  body .flatpickr-day {
    color: var(--color-text);
  }

  body .flatpickr-day.prevMonthDay,
  body .flatpickr-day.nextMonthDay {
    color: var(--color-muted);
  }

  body .flatpickr-day.flatpickr-disabled,
  body .flatpickr-day.flatpickr-disabled:hover {
    color: color-mix(in srgb, var(--color-muted), transparent 48%);
  }

  body .flatpickr-day:hover,
  body .flatpickr-day:focus {
    border-color: var(--color-border);
    background: var(--color-surface-soft);
  }

  body .flatpickr-day.today {
    border-color: var(--color-primary);
  }

  body .flatpickr-day.selected,
  body .flatpickr-day.startRange,
  body .flatpickr-day.endRange {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #fff;
  }

  body .flatpickr-day.inRange {
    border-color: transparent;
    background: var(--color-primary-soft);
    box-shadow:
      -5px 0 0 var(--color-primary-soft),
      5px 0 0 var(--color-primary-soft);
  }

  .planning-ai-form input[type='date'],
  .planning-ai-form select {
    width: 100%;
  }

  .planning-ai-form__meals {
    padding: 0;
    border: 0;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .planning-ai-toggle-card {
    display: flex;
    min-width: 0;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.85rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    color: var(--color-text);
    font-weight: 760;
    text-align: center;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .planning-ai-toggle-card input {
    margin: 0;
    flex: 0 0 auto;
  }

  .planning-ai-toggle-card:has(input:checked) {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 10%);
    color: var(--color-primary);
  }

  .planning-ai-form__modes {
    padding: 0;
    border: 0;
  }

  .planning-ai-preset-row,
  .planning-ai-count-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .planning-ai-chip-button {
    display: inline-flex;
    min-height: 2.8rem;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface), transparent 3%);
    color: var(--color-text);
    font-weight: 850;
    line-height: 1;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .planning-ai-chip-button[aria-pressed='true'] {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 28%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .planning-ai-mode-card {
    display: grid;
    gap: 0.35rem;
    min-height: auto;
    padding: var(--surface-padding-tight) var(--surface-padding);
    padding-bottom: max(var(--surface-padding-tight), 1rem);
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .planning-ai-mode-card strong {
    font-size: 1rem;
    line-height: 1.2;
  }

  .planning-ai-mode-card span {
    color: var(--color-muted);
    font-weight: 600;
    line-height: 1.45;
  }

  .planning-ai-mode-card:has(input:checked) {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 20%);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 18%);
    box-shadow: none;
    transform: none;
  }

  .planning-ai-empty {
    margin: 0;
