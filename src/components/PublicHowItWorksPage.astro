---
import Button from './Button.astro';
import Breadcrumb from './Breadcrumb.astro';
import Container from './Container.astro';
import { type Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const steps = [
  {
    title: t('public.howItWorks.stepGroupTitle'),
    description: t('public.howItWorks.stepGroupDescription'),
  },
  {
    title: t('public.howItWorks.stepPlanTitle'),
    description: t('public.howItWorks.stepPlanDescription'),
  },
  {
    title: t('public.howItWorks.stepReviewTitle'),
    description: t('public.howItWorks.stepReviewDescription'),
  },
];

const benefits = [
  t('public.howItWorks.benefitMobile'),
  t('public.howItWorks.benefitShared'),
  t('public.howItWorks.benefitHistory'),
];
---

<Container class="public-landing-container" size="page">
  <Breadcrumb locale={locale} rootItem={{ label: t('nav.home'), href: getLocalizedPath('/', locale) }} items={[{ label: t('public.howItWorks.title') }]} />
  <article class="public-landing-page public-how-page">
    <header class="public-landing-hero">
      <p class="public-landing-eyebrow">{t('public.howItWorks.eyebrow')}</p>
      <h1>{t('public.howItWorks.heroTitle')}</h1>
      <p>{t('public.howItWorks.heroDescription')}</p>
      <div class="public-landing-actions">
        <Button href={getLocalizedPath('/', locale)}>{t('public.howItWorks.primaryCta')}</Button>
        <Button href={getLocalizedPath('/dashboard', locale)} variant="secondary">
          {t('public.howItWorks.secondaryCta')}
        </Button>
      </div>
    </header>

    <section class="public-landing-grid" aria-label={t('public.howItWorks.stepsTitle')}>
      {steps.map((step, index) => (
        <article class="public-landing-card public-step-card">
          <span>0{index + 1}</span>
          <h2>{step.title}</h2>
          <p>{step.description}</p>
        </article>
      ))}
    </section>

    <section class="public-landing-panel" aria-labelledby="how-benefits-title">
      <div class="public-landing-panel__copy">
        <p class="public-landing-eyebrow">{t('home.eyebrow')}</p>
        <h2 id="how-benefits-title">{t('public.howItWorks.benefitsTitle')}</h2>
        <p>{t('public.howItWorks.description')}</p>
      </div>
      <div class="public-landing-mini-grid">
        {benefits.map((benefit) => (
          <p>{benefit}</p>
        ))}
      </div>
    </section>

    <section class="public-landing-cta" aria-labelledby="how-final-title">
      <div>
        <h2 id="how-final-title">{t('public.howItWorks.finalTitle')}</h2>
        <p>{t('public.howItWorks.finalDescription')}</p>
      </div>
      <Button href={getLocalizedPath('/', locale)}>{t('public.howItWorks.primaryCta')}</Button>
    </section>
  </article>
</Container>

<style>
  .public-landing-container {
    padding-block: clamp(2rem, 7vw, 4.5rem);
  }

  .public-landing-page {
    display: grid;
    gap: clamp(1rem, 3vw, 1.5rem);
  }

  .public-landing-hero,
  .public-landing-card,
  .public-landing-panel,
  .public-landing-cta {
    border: 1px solid var(--panel-border);
    border-radius: clamp(1.3rem, 4vw, 2.35rem);
    background: var(--panel-background);
    box-shadow: var(--shadow-sm);
  }

  .public-landing-hero {
    display: grid;
    justify-items: center;
    gap: 1.2rem;
    padding: clamp(2.8rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    text-align: center;
  }

  .public-landing-eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    font-weight: 380;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .public-landing-hero h1,
  .public-landing-panel h2,
  .public-landing-cta h2,
  .public-landing-card h2,
  .public-landing-hero p,
  .public-landing-panel p,
  .public-landing-cta p,
  .public-landing-card p {
    margin: 0;
  }

  .public-landing-hero h1 {
    max-width: 13ch;
    color: var(--color-text);
    font-size: clamp(2.75rem, 8vw, 5.2rem);
    font-weight: 620;
    letter-spacing: -0.085em;
    line-height: 0.95;
  }

  .public-landing-hero > p {
    max-width: 46rem;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 420;
    letter-spacing: -0.035em;
    line-height: 1.42;
  }

  .public-landing-actions,
  .public-landing-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .public-landing-grid,
  .public-landing-mini-grid {
    display: grid;
    gap: 1rem;
  }

  .public-landing-card {
    display: grid;
    gap: 1rem;
    padding: clamp(1.25rem, 3vw, 1.65rem);
  }

  .public-step-card span {
    color: var(--color-primary);
    font-size: 0.95rem;
    font-weight: 420;
    letter-spacing: -0.055em;
  }

  .public-landing-card h2 {
    margin-top: auto;
    color: var(--color-text);
    font-size: clamp(1.25rem, 2.8vw, 1.7rem);
    font-weight: 650;
    letter-spacing: -0.065em;
    line-height: 1.03;
  }

  .public-landing-card p,
  .public-landing-panel p,
  .public-landing-cta p {
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.7vw, 1.08rem);
    font-weight: 420;
    letter-spacing: -0.025em;
    line-height: 1.55;
  }

  .public-landing-panel {
    display: grid;
    gap: 1.25rem;
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  .public-landing-panel__copy {
    display: grid;
    gap: 0.65rem;
  }

  .public-landing-panel h2,
  .public-landing-cta h2 {
    color: var(--color-text);
    font-size: clamp(1.9rem, 5vw, 3.4rem);
    font-weight: 610;
    letter-spacing: -0.08em;
    line-height: 0.95;
  }

  .public-landing-mini-grid p {
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 14%);
    color: var(--color-text);
    padding: 1rem;
  }

  .public-landing-cta {
    align-items: center;
    justify-content: space-between;
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  .public-landing-cta > div {
    display: grid;
    gap: 0.55rem;
    min-width: min(100%, 24rem);
  }

  @media (min-width: 768px) {
    .public-landing-grid,
    .public-landing-mini-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
