---
import type { Locale } from '../config/site';
import ShoppingApp from './ShoppingApp.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="shopping-ai-only">
  <ShoppingApp locale={locale} />
</div>

<style is:global>
  .shopping-ai-only .shopping-saved-panel {
    display: none !important;
  }
</style>