---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import '../styles/shopping-planning-wizard.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/configurar', locale);

const labels = {
  title: t('shopping.title'),
  description: t('shopping.description'),
  loginTitle: t('shopping.loginTitle'),
  loginDescription: t('shopping.loginDescription'),
  signInGoogle: t('menu.signInGoogle'),
  signInGuest: t('menu.signInGuest'),
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  guestSession: t('menu.guestSession'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  dashboardPath,
  configurePath,
  dashboardLabel: t('appNav.dashboard'),
  configureLabel: t('appNav.configure'),
  helper: t('shopping.helper'),
  mealsTitle: t('shopping.mealsTitle'),
  mealsDescription: t('shopping.mealsDescription'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  emptyMeals: t('shopping.emptyMeals'),
  emptyPlannedMeals: t('shopping.emptyPlannedMeals'),
  inventoryHint: t('shopping.inventoryHint'),
  rangeTitle: t('shopping.rangeTitle'),
  rangeDescription: t('shopping.rangeDescription'),
  reviewTitle: t('shopping.reviewTitle'),
  reviewDescription: t('shopping.reviewDescription'),
  selectedDaysNone: t('shopping.selectedDaysNone'),
  selectedDaysSingle: t('shopping.selectedDaysSingle'),
  selectedDaysPlural: t('shopping.selectedDaysPlural'),
  selectedMealsSingle: t('shopping.selectedMealsSingle'),
  selectedMealsPlural: t('shopping.selectedMealsPlural'),
  pendingCountSingle: t('shopping.pendingCountSingle'),
  pendingCountPlural: t('shopping.pendingCountPlural'),
  doneTitle: t('shopping.doneTitle'),
  startByGenerating: t('shopping.startByGenerating'),
  draftTitle: t('shopping.draftTitle'),
  draftDescription: t('shopping.draftDescription'),
  generate: t('shopping.generate'),
  regenerate: t('shopping.regenerate'),
  regenerateConfirm: t('shopping.regenerateConfirm'),
  addManualItem: t('shopping.addManualItem'),
  saveList: t('shopping.saveList'),
  copy: t('shopping.copy'),
  share: t('shopping.share'),
  download: t('shopping.download'),
  copied: t('shopping.copied'),
  shared: t('shopping.shared'),
  exported: t('shopping.exported'),
  saved: t('shopping.saved'),
  updated: t('shopping.updated'),
  generating: t('shopping.generating'),
  invalidResponse: t('shopping.invalidResponse'),
  noToBuyItems: t('shopping.noToBuyItems'),
  previewHint: t('shopping.previewHint'),
  wizardProgress: t('shopping.title'),
  wizardStepRange: t('shopping.rangeTitle'),
  wizardStepMeals: t('shopping.mealsTitle'),
  wizardStepSummary: t('planningAi.summaryTitle'),
  wizardStepResults: t('shopping.reviewTitle'),
  wizardBack: t('menu.previous'),
  wizardNext: t('menu.next'),
  wizardCancel: t('dashboard.cancel'),
  wizardSummaryTitle: t('planningAi.summaryTitle'),
  wizardSummaryDescription: t('shopping.draftDescription'),
  wizardConfirmTitle: t('shopping.generate'),
  wizardConfirmDescription: t('shopping.reviewDescription'),
  wizardRangeRequired: t('shopping.selectedDaysNone'),
  wizardMealsRequired: t('shopping.emptyPlannedMeals'),
  wizardCancelled: t('shopping.updated'),
  markToBuy: t('shopping.markToBuy'),
  markOwned: t('shopping.markOwned'),
  markDismissed: t('shopping.markDismissed'),
  itemName: t('shopping.itemName'),
  itemQuantity: t('shopping.itemQuantity'),
  itemCategory: t('shopping.itemCategory'),
  itemMeals: t('shopping.itemMeals'),
  itemConfidence: t('shopping.itemConfidence'),
  itemStatus: t('shopping.itemStatus'),
  removeItem: t('shopping.removeItem'),
  statusOwned: t('shopping.statusOwned'),
  statusToBuy: t('shopping.statusToBuy'),
  statusDismissed: t('shopping.statusDismissed'),
  sourceAi: t('shopping.sourceAi'),
  sourceManual: t('shopping.sourceManual'),
  confidenceLow: t('shopping.confidenceLow'),
  confidenceMedium: t('shopping.confidenceMedium'),
  confidenceHigh: t('shopping.confidenceHigh'),
  exportTitle: t('shopping.exportTitle'),
  exportEmpty: t('shopping.exportEmpty'),
  groupScope: t('shopping.groupScope'),
  userScope: t('shopping.userScope'),
  aiDisabled: t('ai.disabled'),
  aiMissingConfig: t('ai.missingConfig'),
  aiLoading: t('ai.loading'),
  aiError: t('ai.error'),
  aiQuota: t('ai.quotaExhausted'),
  aiInvalid: t('ai.invalidResponse'),
  aiAppCheck: t('ai.appCheckUnavailable'),
  'ai.disabled': t('ai.disabled'),
  'ai.loading': t('ai.loading'),
  'ai.error': t('ai.error'),
  'ai.quotaExhausted': t('ai.quotaExhausted'),
  'ai.missingConfig': t('ai.missingConfig'),
  'ai.invalidResponse': t('ai.invalidResponse'),
  'ai.appCheckUnavailable': t('ai.appCheckUnavailable'),
  categoryVegetables: t('shopping.categoryVegetables'),
  categoryFruit: t('shopping.categoryFruit'),
  categoryMeat: t('shopping.categoryMeat'),
  categoryFish: t('shopping.categoryFish'),
  categoryDairy: t('shopping.categoryDairy'),
  categoryEggs: t('shopping.categoryEggs'),
  categoryBakery: t('shopping.categoryBakery'),
  categoryPantry: t('shopping.categoryPantry'),
  categoryFrozen: t('shopping.categoryFrozen'),
  categoryDrinks: t('shopping.categoryDrinks'),
  categorySnacks: t('shopping.categorySnacks'),
  categoryHousehold: t('shopping.categoryHousehold'),
  categoryOther: t('shopping.categoryOther'),
  newItemName: t('shopping.newItemName'),
};
---

<section class="shopping-app planning-ai-app" data-shopping-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>

  <div class="menu-app__auth" data-auth-panel>
    <div>
      <p class="menu-app__eyebrow">{labels.title}</p>
      <h2>{labels.loginTitle}</h2>
      <p>{labels.loginDescription}</p>
    </div>
    <div class="menu-app__auth-actions">
      <button class="button button--primary" type="button" data-google-login>{labels.signInGoogle}</button>
      <button class="button button--secondary" type="button" data-guest-login>{labels.signInGuest}</button>
    </div>
  </div>

  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-workspace hidden>
    <section class="planning-ai-panel app-panel" aria-labelledby="shopping-wizard-title" data-shopping-scroll-target>
      <header class="planning-ai-panel-heading">
        <h2 id="shopping-wizard-title">{labels.title}</h2>
        <p>{labels.description}</p>
      </header>

      <div class="planning-ai-form" data-shopping-wizard>
        <ol class="planning-ai-wizard-progress" aria-label={labels.wizardProgress} data-wizard-progress>
          <li data-wizard-progress-step="range">
            <button class="planning-ai-wizard-step" type="button" aria-current="step"><span>1</span><strong>{labels.wizardStepRange}</strong></button>
          </li>
          <li data-wizard-progress-step="meals">
            <button class="planning-ai-wizard-step" type="button"><span>2</span><strong>{labels.wizardStepMeals}</strong></button>
          </li>
          <li data-wizard-progress-step="summary">
            <button class="planning-ai-wizard-step" type="button"><span>3</span><strong>{labels.wizardStepSummary}</strong></button>
          </li>
          <li data-wizard-progress-step="results">
            <button class="planning-ai-wizard-step" type="button"><span>4</span><strong>{labels.wizardStepResults}</strong></button>
          </li>
        </ol>

        <p class="shopping-wizard__error" data-wizard-error role="alert" hidden></p>

        <section class="planning-ai-section-card" aria-labelledby="shopping-range-title" data-wizard-step="range">
          <div class="planning-ai-section-heading">
            <p class="menu-app__eyebrow" data-scope-label>{labels.userScope}</p>
            <h3 id="shopping-range-title">{labels.rangeTitle}</h3>
            <p>{labels.rangeDescription}</p>
          </div>
          <div class="planning-ai-preset-row shopping-range" data-range-picker></div>
          <div class="planning-ai-request-summary" data-selection-summary></div>
          <p class="planning-ai-empty" data-inventory-hint>{labels.inventoryHint}</p>
        </section>

        <section class="planning-ai-section-card" aria-labelledby="shopping-meals-title" data-wizard-step="meals" hidden>
          <div class="planning-ai-section-heading">
            <h3 id="shopping-meals-title">{labels.mealsTitle}</h3>
            <p>{labels.mealsDescription}</p>
          </div>
          <div class="planning-ai-pending shopping-meals" data-meals></div>
        </section>

        <section class="planning-ai-request-card" aria-labelledby="shopping-summary-title" data-wizard-step="summary" hidden>
          <div class="planning-ai-section-heading">
            <h3 id="shopping-summary-title">{labels.wizardSummaryTitle}</h3>
            <p>{labels.wizardSummaryDescription}</p>
          </div>
          <div class="planning-ai-request-summary shopping-wizard__summary" data-wizard-summary></div>

          <section class="planning-ai-results-panel" aria-labelledby="shopping-generate-title">
            <div class="planning-ai-section-heading">
              <h3 id="shopping-generate-title">{labels.wizardConfirmTitle}</h3>
              <p>{labels.wizardConfirmDescription}</p>
            </div>
            <div class="planning-ai-results-status shopping-ai-status" data-ai-status role="status" aria-live="polite"></div>
            <button class="button button--primary planning-ai-submit" type="button" data-generate>{labels.generate}</button>
          </section>
        </section>

        <section class="planning-ai-request-card" aria-labelledby="shopping-draft-title" data-wizard-step="results" hidden>
          <div class="planning-ai-section-heading">
            <h3 id="shopping-draft-title">{labels.reviewTitle}</h3>
            <p>{labels.reviewDescription}</p>
          </div>
          <div class="shopping-toolbar">
            <button class="button button--ghost button--small" type="button" data-share>{labels.share}</button>
            <button class="button button--primary button--small" type="button" data-save>{labels.saveList}</button>
          </div>
          <div class="planning-ai-results shopping-draft" data-draft></div>
        </section>

        <div class="planning-ai-wizard-actions">
          <button class="button button--ghost" type="button" data-wizard-cancel>{labels.wizardCancel}</button>
          <button class="button button--ghost" type="button" data-wizard-prev>{labels.wizardBack}</button>
          <button class="button button--secondary" type="button" data-wizard-next>{labels.wizardNext}</button>
        </div>
      </div>
    </section>
  </div>
</section>

<style is:global>
  .shopping-app[data-shopping-app] {
    display: grid;
    gap: 1rem;
  }

  .shopping-app [data-workspace][hidden],
  .shopping-app [data-auth-panel][hidden],
  .shopping-app [data-wizard-step][hidden] {
    display: none;
  }

  .shopping-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .shopping-range__day,
  .shopping-summary-pill,
  .shopping-summary-empty,
  .shopping-pill {
    display: inline-flex;
    min-height: 2.8rem;
    align-items: center;
    justify-content: center;
    gap: 0.42rem;
    padding: 0.72rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface), transparent 3%);
    color: var(--color-text);
    font-weight: 850;
    line-height: 1;
    text-align: center;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .shopping-range__day {
    flex: 1 1 8rem;
    flex-direction: column;
    border-radius: var(--radius-xl);
  }

  .shopping-range__day strong {
    font-weight: 950;
  }

  .shopping-range__day span,
  .shopping-summary-empty {
    color: var(--color-muted);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .shopping-range__day[data-selected='true'],
  .shopping-summary-pill {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 28%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .shopping-wizard__error {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--color-danger), var(--color-border) 48%);
    border-radius: var(--radius-xl);
    background: var(--color-danger-soft);
    color: var(--color-danger);
    padding: 0.75rem 0.9rem;
    font-weight: 850;
  }

  .shopping-empty,
  .shopping-ai-status,
  .shopping-item__meals {
    margin: 0;
    color: var(--color-muted);
    font-weight: 650;
  }

  .shopping-ai-status[data-variant='error'] {
    color: var(--color-danger);
  }

  .shopping-wizard__summary dl {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
  }

  .shopping-wizard__summary div {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    min-height: 2.3rem;
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 8%);
    color: var(--color-text);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .shopping-wizard__summary dt {
    color: var(--color-muted);
    font-weight: 700;
  }

  .shopping-wizard__summary dd {
    margin: 0;
  }

  .shopping-meal-card,
  .shopping-item {
    display: grid;
    gap: 0.85rem;
    min-height: auto;
    padding: var(--surface-padding);
    padding-bottom: max(var(--surface-padding), 1rem);
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 10%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-raised), transparent 2%);
  }

  .shopping-meal-card h3,
  .shopping-item__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 900;
  }

  .shopping-item__head,
  .shopping-review-group__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .shopping-status,
  .shopping-item__actions,
  .shopping-review-group,
  .shopping-meals,
  .shopping-draft {
    display: grid;
    gap: 0.75rem;
  }

  .shopping-status__button {
    display: inline-flex;
    min-height: 2.8rem;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-surface), transparent 3%);
    color: var(--color-text);
    font-weight: 850;
  }

  .shopping-status__button[data-selected='true'][data-status='to-buy'] {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 28%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .shopping-status__button[data-selected='true'][data-status='owned'] {
    border-color: color-mix(in srgb, var(--color-success), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-success-soft), transparent 12%);
    color: var(--color-success);
  }

  .shopping-status__button[data-selected='true'][data-status='dismissed'] {
    border-color: color-mix(in srgb, var(--color-danger), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-danger-soft), transparent 14%);
    color: var(--color-danger);
  }

  .shopping-review-group[data-variant='reviewed'] .shopping-item {
    opacity: 0.82;
  }

  .shopping-review-group__header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .shopping-review-group__count {
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  @media (max-width: 539px) {
    .shopping-app .planning-ai-wizard-actions .button,
    .shopping-app .planning-ai-submit {
      width: 100%;
    }
  }
</style>

<script>
  import '../scripts/shopping-app.ts';
  import '../scripts/shopping-wizard.ts';
</script>
