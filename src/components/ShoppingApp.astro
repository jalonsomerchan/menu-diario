---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardPath = getLocalizedPath('/dashboard', locale);
const configurePath = getLocalizedPath('/configurar', locale);

const labels = {
  title: t('shopping.title'),
  description: t('shopping.description'),
  loginTitle: t('shopping.loginTitle'),
  loginDescription: t('shopping.loginDescription'),
  signInGoogle: t('menu.signInGoogle'),
  signInGuest: t('menu.signInGuest'),
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  guestSession: t('menu.guestSession'),
  savePending: t('menu.savePending'),
  saveSaving: t('menu.saveSaving'),
  saveSaved: t('menu.saveSaved'),
  permissionsError: t('menu.permissionsError'),
  dashboardPath,
  configurePath,
  dashboardLabel: t('appNav.dashboard'),
  configureLabel: t('appNav.configure'),
  helper: t('shopping.helper'),
  mealsTitle: t('shopping.mealsTitle'),
  mealsDescription: t('shopping.mealsDescription'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
  emptyMeals: t('shopping.emptyMeals'),
  emptyPlannedMeals: t('shopping.emptyPlannedMeals'),
  inventoryHint: t('shopping.inventoryHint'),
  rangeTitle: t('shopping.rangeTitle'),
  rangeDescription: t('shopping.rangeDescription'),
  reviewTitle: t('shopping.reviewTitle'),
  reviewDescription: t('shopping.reviewDescription'),
  selectedDaysNone: t('shopping.selectedDaysNone'),
  selectedDaysSingle: t('shopping.selectedDaysSingle'),
  selectedDaysPlural: t('shopping.selectedDaysPlural'),
  selectedMealsSingle: t('shopping.selectedMealsSingle'),
  selectedMealsPlural: t('shopping.selectedMealsPlural'),
  pendingCountSingle: t('shopping.pendingCountSingle'),
  pendingCountPlural: t('shopping.pendingCountPlural'),
  doneTitle: t('shopping.doneTitle'),
  startByGenerating: t('shopping.startByGenerating'),
  draftTitle: t('shopping.draftTitle'),
  draftDescription: t('shopping.draftDescription'),
  generate: t('shopping.generate'),
  regenerate: t('shopping.regenerate'),
  regenerateConfirm: t('shopping.regenerateConfirm'),
  addManualItem: t('shopping.addManualItem'),
  saveList: t('shopping.saveList'),
  copy: t('shopping.copy'),
  share: t('shopping.share'),
  download: t('shopping.download'),
  copied: t('shopping.copied'),
  shared: t('shopping.shared'),
  exported: t('shopping.exported'),
  saved: t('shopping.saved'),
  updated: t('shopping.updated'),
  generating: t('shopping.generating'),
  invalidResponse: t('shopping.invalidResponse'),
  noToBuyItems: t('shopping.noToBuyItems'),
  previewHint: t('shopping.previewHint'),
  markToBuy: t('shopping.markToBuy'),
  markOwned: t('shopping.markOwned'),
  markDismissed: t('shopping.markDismissed'),
  itemName: t('shopping.itemName'),
  itemQuantity: t('shopping.itemQuantity'),
  itemCategory: t('shopping.itemCategory'),
  itemMeals: t('shopping.itemMeals'),
  itemConfidence: t('shopping.itemConfidence'),
  itemStatus: t('shopping.itemStatus'),
  removeItem: t('shopping.removeItem'),
  statusOwned: t('shopping.statusOwned'),
  statusToBuy: t('shopping.statusToBuy'),
  statusDismissed: t('shopping.statusDismissed'),
  sourceAi: t('shopping.sourceAi'),
  sourceManual: t('shopping.sourceManual'),
  confidenceLow: t('shopping.confidenceLow'),
  confidenceMedium: t('shopping.confidenceMedium'),
  confidenceHigh: t('shopping.confidenceHigh'),
  exportTitle: t('shopping.exportTitle'),
  exportEmpty: t('shopping.exportEmpty'),
  groupScope: t('shopping.groupScope'),
  userScope: t('shopping.userScope'),
  aiDisabled: t('ai.disabled'),
  aiMissingConfig: t('ai.missingConfig'),
  aiLoading: t('ai.loading'),
  aiError: t('ai.error'),
  aiQuota: t('ai.quotaExhausted'),
  aiInvalid: t('ai.invalidResponse'),
  aiAppCheck: t('ai.appCheckUnavailable'),
  'ai.disabled': t('ai.disabled'),
  'ai.loading': t('ai.loading'),
  'ai.error': t('ai.error'),
  'ai.quotaExhausted': t('ai.quotaExhausted'),
  'ai.missingConfig': t('ai.missingConfig'),
  'ai.invalidResponse': t('ai.invalidResponse'),
  'ai.appCheckUnavailable': t('ai.appCheckUnavailable'),
  categoryVegetables: t('shopping.categoryVegetables'),
  categoryFruit: t('shopping.categoryFruit'),
  categoryMeat: t('shopping.categoryMeat'),
  categoryFish: t('shopping.categoryFish'),
  categoryDairy: t('shopping.categoryDairy'),
  categoryEggs: t('shopping.categoryEggs'),
  categoryBakery: t('shopping.categoryBakery'),
  categoryPantry: t('shopping.categoryPantry'),
  categoryFrozen: t('shopping.categoryFrozen'),
  categoryDrinks: t('shopping.categoryDrinks'),
  categorySnacks: t('shopping.categorySnacks'),
  categoryHousehold: t('shopping.categoryHousehold'),
  categoryOther: t('shopping.categoryOther'),
  newItemName: t('shopping.newItemName'),
};
---

<section class="shopping-app" data-shopping-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>

  <div class="menu-app__auth" data-auth-panel>
    <div>
      <p class="menu-app__eyebrow">{labels.title}</p>
      <h1>{labels.loginTitle}</h1>
      <p>{labels.loginDescription}</p>
    </div>
    <div class="menu-app__auth-actions">
      <button class="button button--primary" type="button" data-google-login>{labels.signInGoogle}</button>
      <button class="button button--secondary" type="button" data-guest-login>{labels.signInGuest}</button>
    </div>
  </div>

  <div class="shopping-app__loading" data-loading>{labels.loading}</div>

  <div class="shopping-app__workspace" data-workspace hidden>
    <section class="shopping-hero app-panel" aria-labelledby="shopping-title">
      <header class="shopping-panel__header">
        <div>
          <p class="menu-app__eyebrow">{labels.helper}</p>
          <h1 id="shopping-title">{labels.title}</h1>
          <p>{labels.description}</p>
        </div>
        <div class="shopping-hero__actions">
          <a class="button button--ghost button--small" href={dashboardPath}>{labels.dashboardLabel}</a>
          <a class="button button--ghost button--small" href={configurePath}>{labels.configureLabel}</a>
        </div>
      </header>
      <div class="shopping-flow card-container">
        <section class="shopping-step" aria-labelledby="shopping-range-title">
          <header class="shopping-step__header">
            <div>
              <p class="menu-app__eyebrow" data-scope-label>{labels.userScope}</p>
              <h2 id="shopping-range-title">{labels.rangeTitle}</h2>
              <p>{labels.rangeDescription}</p>
            </div>
            <span class="shopping-panel__badge" data-inventory-hint>{labels.inventoryHint}</span>
          </header>
          <div class="shopping-range" data-range-picker></div>
          <div class="shopping-selection-summary" data-selection-summary></div>
          <div class="shopping-meals" data-meals></div>
          <div class="shopping-generate">
            <button class="button button--primary" type="button" data-generate>{labels.generate}</button>
            <p class="shopping-ai-status" data-ai-status role="status" aria-live="polite"></p>
          </div>
        </section>

        <section class="shopping-step shopping-step--draft" aria-labelledby="shopping-draft-title">
          <header class="shopping-step__header">
            <div>
              <p class="menu-app__eyebrow">{labels.previewHint}</p>
              <h2 id="shopping-draft-title">{labels.reviewTitle}</h2>
              <p>{labels.reviewDescription}</p>
            </div>
            <div class="shopping-toolbar">
              <button class="button button--ghost button--small" type="button" data-share>{labels.share}</button>
              <button class="button button--primary button--small" type="button" data-save>{labels.saveList}</button>
            </div>
          </header>
          <div class="shopping-draft" data-draft></div>
        </section>
      </div>
    </section>
  </div>
</section>

<style is:global>
  .shopping-app {
    display: grid;
    gap: 1rem;
  }

  .shopping-app__loading[hidden],
  .shopping-app__workspace[hidden],
  .shopping-app__auth[hidden] {
    display: none;
  }

  .shopping-app__loading {
    color: var(--color-muted);
    font-weight: 700;
  }

  .shopping-hero,
  .shopping-panel {
    display: grid;
    gap: 1rem;
  }

  .shopping-hero {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 68%);
    background: var(--panel-background-strong);
  }

  .shopping-flow {
    gap: 1rem;
    padding-top: 0;
  }

  .shopping-step {
    display: grid;
    gap: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 10%);
    border-radius: var(--radius-2xl);
    background: color-mix(in srgb, var(--color-surface-raised), transparent 4%);
    padding: var(--surface-padding);
  }

  .shopping-step--draft {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface-raised), var(--color-primary-soft) 8%), color-mix(in srgb, var(--color-surface-raised), transparent 4%));
  }

  .shopping-hero__actions,
  .shopping-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .shopping-panel__header {
    display: grid;
    gap: 0.9rem;
    align-items: start;
  }

  .shopping-panel__badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.35rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--color-primary), var(--color-border) 52%);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    padding: 0.42rem 0.8rem;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .shopping-meals,
  .shopping-draft {
    display: grid;
    gap: 0.9rem;
  }

  .shopping-range {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .shopping-range__day {
    display: grid;
    gap: 0.2rem;
    min-height: 4.5rem;
    justify-items: start;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 7%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 5%);
    padding: 0.9rem;
    text-align: left;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .shopping-range__day strong {
    font-size: 1rem;
    font-weight: 900;
  }

  .shopping-range__day span {
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .shopping-range__day[data-selected='true'] {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 34%);
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-primary-soft), transparent 12%), color-mix(in srgb, var(--color-surface-raised), transparent 6%));
    box-shadow: 0 14px 34px color-mix(in srgb, var(--color-primary), transparent 86%);
  }

  .shopping-range__day:active {
    transform: scale(0.98);
  }

  .shopping-selection-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .shopping-summary-pill,
  .shopping-summary-empty {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-full);
    padding: 0.5rem 0.8rem;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .shopping-summary-pill {
    border: 1px solid color-mix(in srgb, var(--color-primary), var(--color-border) 48%);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 18%);
    color: var(--color-primary);
  }

  .shopping-summary-empty {
    border: 1px dashed color-mix(in srgb, var(--color-border), var(--color-text) 8%);
    color: var(--color-muted);
  }

  .shopping-empty,
  .shopping-ai-status {
    margin: 0;
    color: var(--color-muted);
  }

  .shopping-ai-status[data-variant='error'] {
    color: var(--color-danger);
  }

  .shopping-generate {
    display: grid;
    gap: 0.65rem;
  }

  .shopping-meal-card,
  .shopping-item {
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 8%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-raised), transparent 3%);
    box-shadow: var(--shadow-xs);
  }

  .shopping-meal-card {
    padding: 1rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-surface-raised), var(--color-primary-soft) 10%),
      color-mix(in srgb, var(--color-surface-raised), transparent 4%)
    );
  }

  .shopping-meal-card h3,
  .shopping-item__title {
    font-weight: 900;
  }

  .shopping-item {
    display: grid;
    gap: 0.85rem;
    padding: 0.95rem;
  }

  .shopping-item__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .shopping-item__title {
    margin: 0;
    font-size: 1.02rem;
  }

  .shopping-pill {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 5%);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 6%);
    color: var(--color-muted);
    padding: 0.3rem 0.7rem;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .shopping-item__meals {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .shopping-item__actions {
    display: grid;
    gap: 0.75rem;
  }

  .shopping-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .shopping-status__button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--color-border), transparent 4%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface-soft), transparent 3%);
    padding: 0.7rem 0.95rem;
    font-weight: 800;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      color var(--transition-base);
  }

  .shopping-status__button[data-selected='true'][data-status='to-buy'] {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 12%);
    color: var(--color-primary);
  }

  .shopping-status__button[data-selected='true'][data-status='owned'] {
    border-color: color-mix(in srgb, var(--color-success), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-success-soft), transparent 12%);
    color: var(--color-success);
  }

  .shopping-status__button[data-selected='true'][data-status='dismissed'] {
    border-color: color-mix(in srgb, var(--color-danger), var(--color-border) 30%);
    background: color-mix(in srgb, var(--color-danger-soft), transparent 14%);
    color: var(--color-danger);
  }

  .shopping-review-group {
    display: grid;
    gap: 0.85rem;
  }

  .shopping-review-group__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .shopping-review-group__header h3 {
    margin: 0;
    font-size: 1rem;
  }

  .shopping-review-group__count {
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .shopping-review-group[data-variant='reviewed'] .shopping-item {
    opacity: 0.82;
  }

  @media (min-width: 48rem) {
    .shopping-panel__header {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .shopping-flow {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    }

    .shopping-range {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .shopping-generate {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
    }
  }
</style>

<script>
  import '../scripts/shopping-app.ts';
</script>
