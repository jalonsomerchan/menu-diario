---
import ConfirmDialog from './ConfirmDialog.astro';
import type { Locale } from '../config/site';
import { useTupperTranslations } from '../i18n/tuppers';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tt = useTupperTranslations(locale);
const labels = {
  configMissing: t('menu.configMissing'),
  loading: t('dashboard.loading'),
  title: tt('title'),
  description: tt('description'),
  expiryAlert: tt('expiryAlert'),
  openCreate: tt('openCreate'),
  createTitle: tt('createTitle'),
  createDescription: tt('createDescription'),
  edit: tt('edit'),
  editTitle: tt('editTitle'),
  editDescription: tt('editDescription'),
  name: tt('name'),
  namePlaceholder: tt('namePlaceholder'),
  dish: tt('dish'),
  freeTextDish: tt('freeTextDish'),
  preparedAt: tt('preparedAt'),
  expiresAt: tt('expiresAt'),
  portions: tt('portions'),
  location: tt('location'),
  locationFridge: tt('locationFridge'),
  locationFreezer: tt('locationFreezer'),
  locationOther: tt('locationOther'),
  notes: tt('notes'),
  create: tt('create'),
  created: tt('created'),
  update: tt('update'),
  updated: tt('updated'),
  filters: tt('filters'),
  filterAll: tt('filterAll'),
  filterExpiring: tt('filterExpiring'),
  filterExpired: tt('filterExpired'),
  filterFreezer: tt('filterFreezer'),
  filterFridge: tt('filterFridge'),
  filterDone: tt('filterDone'),
  empty: tt('empty'),
  expiring: tt('expiring'),
  expired: tt('expired'),
  fresh: tt('fresh'),
  done: tt('done'),
  assignTitle: tt('assignTitle'),
  assignDay: tt('assignDay'),
  assignMeal: tt('assignMeal'),
  assign: tt('assign'),
  reassign: tt('reassign'),
  unassign: tt('unassign'),
  assigned: tt('assigned'),
  unassigned: tt('unassigned'),
  assignedTo: tt('assignedTo'),
  appendConfirmTitle: tt('appendConfirmTitle'),
  cancel: t('dashboard.cancel'),
  appendConfirm: tt('appendConfirm'),
  moveConfirmTitle: tt('moveConfirmTitle'),
  moveConfirm: tt('moveConfirm'),
  unassignConfirmTitle: tt('unassignConfirmTitle'),
  unassignConfirm: tt('unassignConfirm'),
  discardConfirmTitle: tt('discardConfirmTitle'),
  discardConfirm: tt('discardConfirm'),
  archiveConfirmTitle: tt('archiveConfirmTitle'),
  archiveConfirm: tt('archiveConfirm'),
  alreadyAssigned: tt('alreadyAssigned'),
  assignmentBlocked: tt('assignmentBlocked'),
  assignmentBlockedDay: tt('assignmentBlockedDay'),
  assignmentBlockedMeal: tt('assignmentBlockedMeal'),
  assignmentBlockedDuplicate: tt('assignmentBlockedDuplicate'),
  consume: tt('consume'),
  discard: tt('discard'),
  freeze: tt('freeze'),
  defrost: tt('defrost'),
  archive: tt('archive'),
  moreActions: tt('moreActions'),
  consumed: tt('consumed'),
  discarded: tt('discarded'),
  frozen: tt('frozen'),
  defrosted: tt('defrosted'),
  archived: tt('archived'),
  breakfast: t('dashboard.breakfast'),
  lunch: t('dashboard.lunch'),
  dinner: t('dashboard.dinner'),
};
---

<section class="tuppers-app" data-tuppers-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status hidden aria-live="polite"></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div data-content hidden>
    <header class="tuppers-page-header app-page-intro app-panel">
      <div class="tuppers-page-header__copy app-page-intro__copy">
        <h1>{labels.title}</h1>
        <p>{labels.description}</p>
      </div>
      <div class="app-page-intro__actions">
        <button class="button button--primary" type="button" data-open-create>{labels.openCreate}</button>
      </div>
    </header>

    <section class="expiry-banner" data-expiry-alert hidden role="status" aria-live="polite">
      <strong>{labels.expiryAlert}</strong>
    </section>

    <section class="dashboard-section" aria-labelledby="tuppers-list-title">
      <div class="section-heading section-heading--simple">
        <h3 id="tuppers-list-title">{labels.filters}</h3>
      </div>
      <div class="tupper-filters" data-filters role="group" aria-label={labels.filters}>
        <button type="button" data-filter="all" aria-pressed="true">{labels.filterAll}</button>
        <button type="button" data-filter="expiring">{labels.filterExpiring}</button>
        <button type="button" data-filter="expired">{labels.filterExpired}</button>
        <button type="button" data-filter="freezer">{labels.filterFreezer}</button>
        <button type="button" data-filter="fridge">{labels.filterFridge}</button>
        <button type="button" data-filter="done">{labels.filterDone}</button>
      </div>
      <div class="tupper-list" data-tupper-list></div>
    </section>
  </div>

  <dialog
    class="app-dialog app-dialog--editor tuppers-create-dialog"
    data-create-dialog
    aria-labelledby="tuppers-create-title"
    aria-describedby="tuppers-create-description"
  >
    <form method="dialog" class="app-dialog__surface tuppers-create-dialog__surface" data-tupper-form>
      <header class="app-dialog__header">
        <div class="app-dialog__heading">
          <p class="menu-app__eyebrow">{labels.title}</p>
          <h2 id="tuppers-create-title" data-dialog-title>{labels.createTitle}</h2>
          <p id="tuppers-create-description" data-dialog-description>{labels.createDescription}</p>
        </div>
        <button class="app-dialog__dismiss" type="button" data-close-create aria-label={labels.cancel}>
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="app-dialog__body">
        <div class="tuppers-form">
          <label>
            <span>{labels.dish}</span>
            <select data-dish-select>
              <option value="">{labels.freeTextDish}</option>
            </select>
          </label>
          <label>
            <span>{labels.name}</span>
            <input name="name" data-name required minlength="2" placeholder={labels.namePlaceholder} autocomplete="off" />
          </label>
          <label>
            <span>{labels.preparedAt}</span>
            <input name="preparedAt" data-prepared type="date" required />
          </label>
          <label>
            <span>{labels.expiresAt}</span>
            <input name="expiresAt" data-expires type="date" required />
          </label>
          <label>
            <span>{labels.portions}</span>
            <input name="portions" data-portions type="number" min="1" step="1" inputmode="numeric" />
          </label>
          <label>
            <span>{labels.location}</span>
            <select name="location" data-location>
              <option value="fridge">{labels.locationFridge}</option>
              <option value="freezer">{labels.locationFreezer}</option>
              <option value="other">{labels.locationOther}</option>
            </select>
          </label>
          <label class="tuppers-form__wide">
            <span>{labels.notes}</span>
            <textarea name="notes" data-notes rows="4"></textarea>
          </label>
        </div>
      </div>
      <footer class="app-dialog__footer">
        <button class="button button--ghost" type="button" data-close-create>{labels.cancel}</button>
        <button class="button button--primary" type="submit" data-submit-label>{labels.create}</button>
      </footer>
    </form>
  </dialog>

  <ConfirmDialog
    dialogId="tuppers-confirm"
    cancelLabel={labels.cancel}
    confirmLabel={labels.assign}
  />
</section>

<script>
  import '../scripts/tuppers-app.ts';
</script>
