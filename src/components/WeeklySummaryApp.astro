---
import type { Locale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/', locale);
const dishesPath = getLocalizedPath('/mis-platos', locale);
const configurePath = getLocalizedPath('/configurar', locale);

const labels = {
  configMissing: t('menu.configMissing'),
  permissionsError: t('menu.permissionsError'),
  guestSession: t('menu.guestSession'),
  loading: t('dashboard.loading'),
  saveSaved: t('menu.saveSaved'),
  title: t('summary.title'),
  description: t('summary.description'),
  eyebrow: t('summary.eyebrow'),
  weekLabel: t('summary.weekLabel'),
  plannedMeals: t('summary.plannedMeals'),
  emptyMeals: t('summary.emptyMeals'),
  eatingOutMeals: t('summary.eatingOutMeals'),
  totalMeals: t('summary.totalMeals'),
  topDishes: t('summary.topDishes'),
  repeatedDishes: t('summary.repeatedDishes'),
  comparison: t('summary.comparison'),
  recommendations: t('summary.recommendations'),
  latestDish: t('summary.latestDish'),
  emptyTopDishes: t('summary.emptyTopDishes'),
  emptyRepeatedDishes: t('summary.emptyRepeatedDishes'),
  notEnoughHistory: t('summary.notEnoughHistory'),
  noLatestDish: t('summary.noLatestDish'),
  noData: t('summary.noData'),
  recommendationDefault: t('summary.recommendationDefault'),
  'recommendation.empty-week': t('summary.recommendation.emptyWeek'),
  'recommendation.repeated-dish': t('summary.recommendation.repeatedDish'),
  'recommendation.stale-dish': t('summary.recommendation.staleDish'),
  'recommendation.balanced-week': t('summary.recommendation.balancedWeek'),
  aiReady: t('summary.aiReady'),
  dishesReady: t('summary.dishesReady'),
  configureReady: t('summary.configureReady'),
  dishesLink: t('summary.dishesLink'),
  configureLink: t('summary.configureLink'),
  homePath,
};
---

<section class="weekly-summary-app" data-weekly-summary-app data-labels={JSON.stringify(labels)}>
  <div class="menu-app__status" data-status role="status" aria-live="polite" hidden></div>
  <div class="dashboard-app__loading" data-loading>{labels.loading}</div>

  <div class="weekly-summary-app__content" data-content hidden>
    <section class="weekly-summary-hero app-panel" aria-labelledby="weekly-summary-title">
      <div>
        <p class="menu-app__eyebrow">{labels.eyebrow}</p>
        <h1 id="weekly-summary-title">{labels.title}</h1>
        <p>{labels.description}</p>
      </div>
      <label class="weekly-summary-week">
        <span>{labels.weekLabel}</span>
        <select data-week-select></select>
      </label>
    </section>

    <section class="weekly-summary-grid" aria-label={labels.title} data-summary-metrics></section>

    <section class="weekly-summary-sections">
      <article class="weekly-summary-panel app-panel">
        <h2>{labels.topDishes}</h2>
        <div data-top-dishes></div>
      </article>

      <article class="weekly-summary-panel app-panel">
        <h2>{labels.repeatedDishes}</h2>
        <div data-repeated-dishes></div>
      </article>

      <article class="weekly-summary-panel app-panel">
        <h2>{labels.comparison}</h2>
        <div data-comparison></div>
      </article>

      <article class="weekly-summary-panel app-panel">
        <h2>{labels.latestDish}</h2>
        <div class="weekly-summary-latest" data-latest-dish></div>
      </article>
    </section>

    <section class="weekly-summary-panel weekly-summary-panel--highlight app-panel" aria-labelledby="weekly-summary-recommendations">
      <div class="weekly-summary-panel__heading">
        <div>
          <p class="menu-app__eyebrow">{labels.aiReady}</p>
          <h2 id="weekly-summary-recommendations">{labels.recommendations}</h2>
        </div>
        <div class="weekly-summary-actions">
          <a class="button button--ghost button--small" href={dishesPath}>{labels.dishesLink}</a>
          <a class="button button--primary button--small" href={configurePath}>{labels.configureLink}</a>
        </div>
      </div>
      <ul class="weekly-summary-recommendations" data-recommendations></ul>
      <div class="weekly-summary-readiness" aria-label={labels.aiReady}>
        <span>{labels.aiReady}</span>
        <span>{labels.dishesReady}</span>
        <span>{labels.configureReady}</span>
      </div>
    </section>
  </div>
</section>

<style is:global>
  .weekly-summary-app {
    max-width: 62rem;
    margin-inline: auto;
  }

  .weekly-summary-app__content,
  .weekly-summary-sections {
    display: grid;
    gap: 1rem;
  }

  .weekly-summary-hero,
  .weekly-summary-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .weekly-summary-hero h1,
  .weekly-summary-panel h2 {
    margin: 0;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .weekly-summary-hero h1 {
    font-size: clamp(2rem, 10vw, 4.5rem);
  }

  .weekly-summary-hero p,
  .weekly-summary-empty {
    margin: 0;
    color: var(--color-muted);
  }

  .weekly-summary-week {
    display: grid;
    gap: 0.45rem;
    color: var(--color-muted);
    font-weight: 850;
  }

  .weekly-summary-week select {
    width: 100%;
    min-height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-raised);
    color: var(--color-text);
    padding: 0.72rem 0.8rem;
    font-weight: 800;
  }

  .weekly-summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .weekly-summary-card {
    display: grid;
    gap: 0.55rem;
    min-height: 8rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-primary) 10%);
    border-radius: var(--radius-2xl);
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface), var(--color-primary-soft) 10%), var(--color-surface));
    padding: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .weekly-summary-card span,
  .weekly-summary-list span,
  .weekly-summary-comparison dt,
  .weekly-summary-latest span {
    color: var(--color-muted);
    font-weight: 850;
  }

  .weekly-summary-card strong {
    color: var(--color-primary);
    font-size: clamp(2.2rem, 12vw, 4rem);
    font-weight: 150;
    letter-spacing: -0.12em;
    line-height: 0.9;
  }

  .weekly-summary-list,
  .weekly-summary-recommendations {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .weekly-summary-list li,
  .weekly-summary-recommendations li,
  .weekly-summary-comparison div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 6%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface), var(--color-surface-soft) 46%);
    padding: 0.8rem;
  }

  .weekly-summary-list strong,
  .weekly-summary-comparison dd {
    min-width: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    padding: 0.25rem 0.65rem;
    text-align: center;
    font-weight: 950;
  }

  .weekly-summary-comparison {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .weekly-summary-comparison dd {
    margin: 0;
  }

  .weekly-summary-latest {
    display: grid;
    gap: 0.25rem;
  }

  .weekly-summary-latest strong {
    font-size: 1.35rem;
  }

  .weekly-summary-panel--highlight {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 56%);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--color-primary-soft), transparent 20%), transparent 22rem),
      var(--color-surface);
  }

  .weekly-summary-panel__heading,
  .weekly-summary-actions,
  .weekly-summary-readiness {
    display: grid;
    gap: 0.75rem;
  }

  .weekly-summary-readiness {
    grid-template-columns: 1fr;
  }

  .weekly-summary-readiness span {
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-primary-soft), transparent 12%);
    color: var(--color-primary);
    padding: 0.45rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 900;
  }

  @media (min-width: 720px) {
    .weekly-summary-hero,
    .weekly-summary-panel__heading {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .weekly-summary-grid,
    .weekly-summary-sections {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .weekly-summary-sections .weekly-summary-panel {
      grid-column: span 2;
    }

    .weekly-summary-actions,
    .weekly-summary-readiness {
      grid-template-columns: repeat(2, auto);
    }

    .weekly-summary-readiness {
      grid-template-columns: repeat(3, auto);
      justify-content: start;
    }
  }
</style>

<script>
  import '../scripts/weekly-summary-app.ts';
</script>
