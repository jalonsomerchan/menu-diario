---
import '../styles/global.css';
import Header from '../components/Header.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';
import { getAbsoluteUrl, stripBasePath, withBasePath } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  locale?: Locale;
}

const {
  title = siteConfig.name,
  image = 'og-image.svg',
  locale = defaultLocale,
} = Astro.props;

const t = useTranslations(locale);
const description = Astro.props.description ?? t('site.description');
const pageTitle = title === siteConfig.name ? title : `${title} · ${siteConfig.name}`;
const routePath = stripBasePath(Astro.url.pathname);
const localeRelativePath = locale !== defaultLocale && routePath.startsWith(`/${locale}`)
  ? routePath.slice(locale.length + 1) || '/'
  : routePath;
const publicPaths = [
  '/',
  '/404',
  '/acerca-de',
  '/como-funciona',
  '/faq',
  '/manual',
  '/organizar-menu-semanal',
  '/planificador-comidas',
  '/politica-privacidad',
];
const normalizedPagePath = localeRelativePath.replace(/\/$/, '') || '/';
const isPublicPage = publicPaths.includes(normalizedPagePath);
const canonicalUrl = getAbsoluteUrl(withBasePath(routePath), siteConfig.url);
const imageUrl = getAbsoluteUrl(withBasePath(image), siteConfig.url);
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f5f5f7" data-theme-color />
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
    <script is:inline>
      (() => {
        try {
          const theme = window.localStorage.getItem('menu-diario-theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          } else {
            document.documentElement.removeAttribute('data-theme');
          }

          const effectiveTheme =
            theme === 'light' || theme === 'dark'
              ? theme
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.querySelector('[data-theme-color]')?.setAttribute(
            'content',
            effectiveTheme === 'dark' ? '#0b0b0d' : '#f5f5f7'
          );
        } catch {
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBasePath('favicon.svg')} />
    <link rel="icon" href={withBasePath('favicon.ico')} />
    <link rel="apple-touch-icon" href={withBasePath('og-image.svg')} />
    <link rel="manifest" href={withBasePath('manifest.webmanifest')} />
    <meta name="color-scheme" content="light dark" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t('accessibility.skipToContent')}</a>
    <Header locale={locale} />
    <main id="main-content" class="site-main" tabindex="-1">
      <slot />
    </main>
    {!isPublicPage && <MobileBottomNav locale={locale} />}
    {isPublicPage && <Footer locale={locale} />}
  </body>
</html>
