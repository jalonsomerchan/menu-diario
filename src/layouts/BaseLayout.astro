---
import '../styles/global.css';
import '../styles/dishes.css';
import '../styles/tuppers.css';
import '../styles/menu-automation-actions.css';
import '../styles/initial-onboarding.css';
import '../styles/wizard-scroll.css';
import '../styles/ai-status-spinner.css';
import '../styles/mobile-bottom-nav.css';
import '../styles/more-page.css';
import '../styles/public-cooking-seo.css';
import '../styles/modals.css';
import '../styles/toasts.css';
import '../styles/apple-tokens.css';
import '../styles/apple-redesign.css';
import '../styles/apple-chrome.css';
import Header from '../components/Header.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, siteConfig, type Locale } from '../config/site';
import { useInitialOnboardingTranslations } from '../i18n/initial-onboarding';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { getAbsoluteUrl, stripBasePath, withBasePath } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  locale?: Locale;
}

const {
  title = siteConfig.name,
  image = 'og-image.svg',
  locale = defaultLocale,
} = Astro.props;

const t = useTranslations(locale);
const onboardingT = useInitialOnboardingTranslations(locale);
const description = Astro.props.description ?? t('site.description');
const pageTitle = title === siteConfig.name ? title : `${title} · ${siteConfig.name}`;
const routePath = stripBasePath(Astro.url.pathname);
const canonicalUrl = getAbsoluteUrl(withBasePath(routePath), siteConfig.url);
const imageUrl = getAbsoluteUrl(withBasePath(image), siteConfig.url);
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';
const normalizedRoutePath = locale === defaultLocale ? routePath : routePath.replace(new RegExp(`^/${locale}(?=/|$)`), '') || '/';
const privateAppSections = new Set([
  'ajustes',
  'compra',
  'compras',
  'configurar',
  'dashboard',
  'estadisticas',
  'historico',
  'mas',
  'mis-platos',
  'planificacion',
  'planificador',
  'planificador-ai',
  'platos',
  'recomendador-platos',
  'resumen-semanal',
  'tuppers',
]);
const currentSection = normalizedRoutePath.replace(/^\//, '').split('/')[0] || '';
const showInitialOnboarding = privateAppSections.has(currentSection);
const onboardingLabels = {
  title: onboardingT('title'),
  description: onboardingT('description'),
  stepMealsTitle: onboardingT('stepMealsTitle'),
  stepMealsDescription: onboardingT('stepMealsDescription'),
  stepDishesTitle: onboardingT('stepDishesTitle'),
  stepDishesDescription: onboardingT('stepDishesDescription'),
  stepTuppersTitle: onboardingT('stepTuppersTitle'),
  stepTuppersDescription: onboardingT('stepTuppersDescription'),
  primaryAction: onboardingT('primaryAction'),
  secondaryAction: onboardingT('secondaryAction'),
  tertiaryAction: onboardingT('tertiaryAction'),
  dismiss: onboardingT('dismiss'),
  finish: onboardingT('finish'),
};
const onboardingPaths = {
  settings: getLocalizedPath('/ajustes', locale),
  dishes: getLocalizedPath('/mis-platos', locale),
  tuppers: getLocalizedPath('/tuppers', locale),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
    <script is:inline>
      (() => {
        try {
          const theme = window.localStorage.getItem('menu-diario-theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <script is:inline>
      var profile = window.profile || {};
      window.profile = profile;
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBasePath('favicon.svg')} />
    <link rel="icon" href={withBasePath('favicon.ico')} />
    <link rel="apple-touch-icon" href={withBasePath('apple-touch-icon.png')} />
    <link rel="manifest" href={withBasePath('manifest.webmanifest')} />
    <meta name="theme-color" content="#f5f5f7" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body class:list={{ 'private-app': showInitialOnboarding }}>
    <a class="skip-link" href="#main-content">{t('a11y.skipToContent')}</a>
    <Header locale={locale} />
    <main id="main-content" class="site-main" tabindex="-1">
      <slot />
    </main>
    {showInitialOnboarding && <div data-initial-onboarding data-labels={JSON.stringify(onboardingLabels)} data-paths={JSON.stringify(onboardingPaths)} hidden></div>}
    <MobileBottomNav locale={locale} />
    <Footer locale={locale} />
    <script>
      if (document.querySelector('[data-initial-onboarding]')) {
        import('../scripts/initial-onboarding.ts');
      }

      if (document.querySelector('[data-dashboard-app], [data-configurator-app]')) {
        import('../scripts/meal-drag-and-drop-app.ts');
      }

      if (document.querySelector('[data-ai-status]')) {
        import('../scripts/ai-status-spinner.ts');
      }

      if (document.querySelector('[data-planning-ai-app], [data-dish-recommender-app]')) {
        import('../scripts/ai-wizard-feedback.ts');
      }

      if (document.querySelector('[data-shopping-app]')) {
        import('../scripts/shopping-whatsapp-export.ts');
      }

      if (document.querySelector('[data-menu-app], [data-tuppers-app], [data-dishes-app]')) {
        import('../scripts/menu-automation-actions.ts');
      }
    </script>
  </body>
</html>
