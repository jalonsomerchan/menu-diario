---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AppPageShell from '../../../components/AppPageShell.astro';
import AdminGlobalDishesApp from '../../../components/AdminGlobalDishesApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../../config/site';
import { isLocale, useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('adminDishes.title')} · ${siteConfig.name}`} description={t('adminDishes.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('adminDishes.title')} description={t('adminDishes.description')}>
    <AdminGlobalDishesApp locale={locale} />
  </AppPageShell>
</BaseLayout>
