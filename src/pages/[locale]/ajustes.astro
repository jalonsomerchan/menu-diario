---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import SettingsApp from '../../components/SettingsApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dashboard.settings')} · ${siteConfig.name}`} description={t('settings.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('settings.title')} description={t('settings.description')} showHeader={false}>
    <SettingsApp locale={locale} />
  </AppPageShell>
</BaseLayout>
