---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicHowItWorksPage from '../../components/PublicHowItWorksPage.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({
      params: { locale },
    }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={t('public.howItWorks.title')} description={t('public.howItWorks.description')} locale={locale}>
  <PublicHowItWorksPage locale={locale} />
</BaseLayout>
