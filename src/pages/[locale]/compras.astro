---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import ShoppingApp from '../../components/ShoppingApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const title = locale === 'en' ? 'Shopping' : 'Compras';
const description = locale === 'en'
  ? 'Check your saved shopping lists and open the one you need to review.'
  : 'Consulta tus listas de la compra guardadas y abre la que necesites revisar.';
---

<BaseLayout title={`${title} · ${siteConfig.name}`} description={description} locale={locale}>
  <AppPageShell locale={locale} title={title} description={description}>
    <ShoppingApp locale={locale} />
  </AppPageShell>
</BaseLayout>