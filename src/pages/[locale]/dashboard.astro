---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import DashboardApp from '../../components/DashboardApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dashboard.title')} · ${siteConfig.name}`} description={t('site.description')} locale={locale}>
  <AppPageShell
    locale={locale}
    title={t('dashboard.title')}
    description={t('dashboard.configureDescription')}
    showHeader={false}
    showBreadcrumb={false}
  >
    <DashboardApp locale={locale} />
  </AppPageShell>
</BaseLayout>
