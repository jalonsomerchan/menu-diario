---
import AppPageShell from '../../components/AppPageShell.astro';
import StatisticsApp from '../../components/StatisticsApp.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { useStatisticsTranslations } from '../../i18n/statistics';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const ts = useStatisticsTranslations(locale);
const title = ts('title');
const description = ts('description');
---

<BaseLayout title={`${title} · ${siteConfig.name}`} description={description} locale={locale}>
  <AppPageShell locale={locale} title={title} description={description} showHeader={false}>
    <StatisticsApp locale={locale} />
  </AppPageShell>
</BaseLayout>
