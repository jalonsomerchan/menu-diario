---
import FaqPage from '../../components/FaqPage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { usePublicPageCopy } from '../../i18n/public-pages';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const tp = usePublicPageCopy(locale);
---

<BaseLayout title={`${tp('faqTitle')} · ${siteConfig.name}`} description={tp('faqDescription')} locale={locale}>
  <FaqPage locale={locale} />
</BaseLayout>
