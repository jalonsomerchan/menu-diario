---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import DishesApp from '../../components/DishesApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dishes.title')} · ${siteConfig.name}`} description={t('dishes.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('dishes.title')} description={t('dishes.description')}>
    <DishesApp locale={locale} />
  </AppPageShell>
</BaseLayout>
