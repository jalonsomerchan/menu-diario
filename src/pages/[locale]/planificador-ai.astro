---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import PlanningAiApp from '../../components/PlanningAiApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { usePlanningTranslations } from '../../i18n/planning';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const tp = usePlanningTranslations(locale);
---

<BaseLayout title={`${tp('title')} · ${siteConfig.name}`} description={tp('description')} locale={locale}>
  <AppPageShell locale={locale} title={tp('title')} description={tp('description')} showHeader={false}>
    <PlanningAiApp locale={locale} />
  </AppPageShell>
</BaseLayout>
