---
import PublicCookingSeoIndexPage from '../../components/PublicCookingSeoIndexPage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { getCookingSeoIndexMeta } from '../../data/public-cooking-seo-pages';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const meta = getCookingSeoIndexMeta(locale);
---

<BaseLayout title={meta.title} description={meta.description} locale={locale}>
  <PublicCookingSeoIndexPage locale={locale} />
</BaseLayout>
