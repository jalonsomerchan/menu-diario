---
import PublicRecipeIndexPage from '../../../components/PublicRecipeIndexPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { getCookingRecipeIndexMeta } from '../../../data/public-cooking-seo-catalog';
import { isLocale } from '../../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const meta = getCookingRecipeIndexMeta(locale);
---

<BaseLayout title={meta.title} description={meta.description} locale={locale}>
  <PublicRecipeIndexPage locale={locale} />
</BaseLayout>
