---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DishRecommenderApp from '../../components/DishRecommenderApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { useDishRecommenderTranslations } from '../../i18n/dish-recommender';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const tr = useDishRecommenderTranslations(locale);
---

<BaseLayout title={`${tr('title')} · ${siteConfig.name}`} description={t('site.description')} locale={locale}>
  <Container class="py-4 sm:py-6">
    <Breadcrumb locale={locale} items={[{ label: tr('title') }]} />
    <DishRecommenderApp locale={locale} />
  </Container>
</BaseLayout>
