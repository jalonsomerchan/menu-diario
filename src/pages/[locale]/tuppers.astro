---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppPageShell from '../../components/AppPageShell.astro';
import TuppersApp from '../../components/TuppersApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { useTupperTranslations } from '../../i18n/tuppers';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const tt = useTupperTranslations(locale);
---

<BaseLayout title={`${tt('title')} · ${siteConfig.name}`} description={tt('description')} locale={locale}>
  <AppPageShell locale={locale} title={tt('title')} description={tt('description')}>
    <TuppersApp locale={locale} />
  </AppPageShell>
</BaseLayout>
