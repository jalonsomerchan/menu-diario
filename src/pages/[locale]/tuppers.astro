---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import TuppersApp from '../../components/TuppersApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('tuppers.title')} · ${siteConfig.name}`} description={t('tuppers.description')} locale={locale}>
  <Container class="py-4 sm:py-6">
    <TuppersApp locale={locale} />
  </Container>
</BaseLayout>
