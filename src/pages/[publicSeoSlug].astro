---
import PublicSeoPage from '../components/PublicSeoPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale } from '../config/site';
import { publicSeoGrowthPageKeys } from '../data/public-seo-growth-pages';
import { getPublicSeoPage, type PublicSeoPageKey } from '../data/public-seo-pages';

interface Props {
  pageKey: PublicSeoPageKey;
}

export function getStaticPaths() {
  return publicSeoGrowthPageKeys.map((pageKey) => {
    const page = getPublicSeoPage(defaultLocale, pageKey);

    return {
      params: { publicSeoSlug: page.slug },
      props: { pageKey },
    };
  });
}

const locale = defaultLocale;
const { pageKey } = Astro.props as Props;
const page = getPublicSeoPage(locale, pageKey);
---

<BaseLayout title={page.title} description={page.description} locale={locale}>
  <PublicSeoPage locale={locale} pageKey={pageKey} />
</BaseLayout>
