---
import AboutPage from '../components/AboutPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { usePublicPageCopy } from '../i18n/public-pages';

const locale = defaultLocale;
const tp = usePublicPageCopy(locale);
---

<BaseLayout title={`${tp('aboutTitle')} · ${siteConfig.name}`} description={tp('aboutDescription')} locale={locale}>
  <AboutPage locale={locale} />
</BaseLayout>
