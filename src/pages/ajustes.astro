---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import SettingsApp from '../components/SettingsApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dashboard.settings')} · ${siteConfig.name}`} description={t('site.description')} locale={locale}>
  <Container class="py-4 sm:py-6">
    <SettingsApp locale={locale} />
  </Container>
</BaseLayout>
