---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import SettingsApp from '../components/SettingsApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dashboard.settings')} · ${siteConfig.name}`} description={t('settings.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('settings.title')} description={t('settings.description')}>
    <SettingsApp locale={locale} />
  </AppPageShell>
</BaseLayout>
