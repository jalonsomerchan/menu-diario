---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import ShoppingListsApp from '../components/ShoppingListsApp.astro';
import { defaultLocale, siteConfig } from '../config/site';

const locale = defaultLocale;
const title = 'Compras';
const description = 'Consulta tus listas de la compra guardadas y abre la que necesites revisar.';
---

<BaseLayout title={`${title} · ${siteConfig.name}`} description={description} locale={locale}>
  <AppPageShell locale={locale} title={title} description={description}>
    <ShoppingListsApp locale={locale} />
  </AppPageShell>
</BaseLayout>