---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import DashboardApp from '../components/DashboardApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('dashboard.title')} · ${siteConfig.name}`} description={t('site.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('dashboard.title')} description={t('dashboard.configureDescription')} showHeader={false}>
    <DashboardApp locale={locale} />
  </AppPageShell>
</BaseLayout>
