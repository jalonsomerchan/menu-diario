---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import HistoryApp from '../components/HistoryApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('history.title')} · ${siteConfig.name}`} description={t('history.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('history.title')} description={t('history.description')}>
    <HistoryApp locale={locale} />
  </AppPageShell>
</BaseLayout>
