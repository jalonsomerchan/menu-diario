---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Container from '../components/Container.astro';
import AuthGate from '../components/AuthGate.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
const homeCopy =
  locale === 'es'
    ? {
        title: 'Menu Diario',
        subtitle: 'Planifica comidas sin ruido: decide, guarda ideas y coordina tu menú con ayuda de IA.',
        eyebrow: 'Webapp de menús con IA',
        sectionsTitle: 'Todo lo importante, sin complicar la comida',
        sectionsSubtitle: 'Una base sencilla para organizar el día a día, reutilizar platos y evitar conversaciones eternas sobre qué comer.',
        features: [
          {
            title: 'Planifica cada momento',
            description: 'Organiza desayunos, comidas y cenas en una vista clara para los próximos días.',
          },
          {
            title: 'Ideas con inteligencia artificial',
            description: 'Recibe propuestas adaptadas a tus preferencias, tiempo disponible e intolerancias.',
          },
          {
            title: 'Reutiliza tus platos',
            description: 'Guarda favoritos y tira de tu propio catálogo cuando no quieras pensar demasiado.',
          },
          {
            title: 'Coordina el grupo',
            description: 'Comparte decisiones, participantes y cambios para que todo el mundo sepa qué toca.',
          },
        ],
      }
    : {
        title: 'Menu Diario',
        subtitle: 'Plan meals without noise: decide, save ideas and coordinate your menu with AI assistance.',
        eyebrow: 'AI meal planning web app',
        sectionsTitle: 'Everything that matters, without overcomplicating meals',
        sectionsSubtitle: 'A simple base to organize everyday meals, reuse dishes and avoid endless conversations about what to eat.',
        features: [
          {
            title: 'Plan every moment',
            description: 'Organize breakfasts, lunches and dinners in a clear view for the next few days.',
          },
          {
            title: 'Ideas with artificial intelligence',
            description: 'Get suggestions adapted to your preferences, available time and intolerances.',
          },
          {
            title: 'Reuse your dishes',
            description: 'Save favorites and rely on your own catalog when you do not want to think too much.',
          },
          {
            title: 'Coordinate the group',
            description: 'Share decisions, participants and changes so everyone knows what is coming.',
          },
        ],
      };
---

<BaseLayout title={homeCopy.title} description={homeCopy.subtitle} locale={locale}>
  <Container class="py-4 sm:py-6" size="page">
    <Breadcrumb locale={locale} rootItem={{ label: t('nav.home') }} items={[]} />
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero__content">
        <p class="home-hero__eyebrow">{homeCopy.eyebrow}</p>
        <h1 id="home-title">{homeCopy.title}</h1>
        <p class="home-hero__subtitle">{homeCopy.subtitle}</p>
        <div class="home-hero__auth" id="login">
          <AuthGate locale={locale} />
        </div>
      </div>

      <div class="home-hero__preview" aria-hidden="true">
        <div class="home-preview-card home-preview-card--active">
          <span>{t('dashboard.lunch')}</span>
          <strong>Ensalada templada de quinoa</strong>
          <small>IA · sano · equilibrado</small>
        </div>
        <div class="home-preview-card">
          <span>{t('dashboard.dinner')}</span>
          <strong>Crema de calabaza</strong>
          <small>Guardado en tus platos</small>
        </div>
        <div class="home-preview-card">
          <span>{t('dashboard.breakfast')}</span>
          <strong>Tostadas con tomate</strong>
          <small>Listo para mañana</small>
        </div>
      </div>
    </section>

    <section class="home-sections" aria-labelledby="home-sections-title">
      <div class="home-sections__heading">
        <p class="home-hero__eyebrow">{t('home.eyebrow')}</p>
        <h2 id="home-sections-title">{homeCopy.sectionsTitle}</h2>
        <p>{homeCopy.sectionsSubtitle}</p>
      </div>

      <div class="home-feature-grid">
        {homeCopy.features.map((feature, index) => (
          <article class="home-feature-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>

<style>
  .home-hero,
  .home-sections {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2rem);
  }

  .home-hero {
    align-items: center;
    min-height: auto;
    padding: clamp(1.35rem, 5vw, 4rem);
    border: 1px solid color-mix(in srgb, var(--panel-border), var(--color-primary) 8%);
    border-radius: clamp(1.5rem, 4vw, 2.35rem);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-primary), transparent 90%), transparent 18rem),
      linear-gradient(135deg, color-mix(in srgb, var(--color-surface), transparent 0%), color-mix(in srgb, var(--color-surface-soft), transparent 62%));
    box-shadow: var(--shadow-sm);
  }

  .home-hero__content {
    display: grid;
    gap: clamp(0.8rem, 2vw, 1.2rem);
    justify-items: start;
  }

  .home-hero__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: clamp(1rem, 2.4vw, 1.65rem);
    font-weight: 380;
    letter-spacing: -0.045em;
    line-height: 1.05;
    text-transform: none;
  }

  .home-hero h1 {
    max-width: 10ch;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(3.4rem, 14vw, 8.4rem);
    font-weight: 650;
    letter-spacing: -0.1em;
    line-height: 0.82;
  }

  .home-hero__subtitle {
    max-width: 44rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 420;
    letter-spacing: -0.035em;
    line-height: 1.42;
  }

  .home-hero__auth {
    width: 100%;
    max-width: 24rem;
    margin-top: 0.35rem;
  }

  .home-hero__preview {
    display: grid;
    gap: 0.75rem;
    align-self: stretch;
    align-content: center;
  }

  .home-preview-card {
    display: grid;
    gap: 0.28rem;
    padding: 0.95rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-border), var(--color-text) 5%);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-surface), transparent 4%);
    box-shadow: none;
  }

  .home-preview-card--active {
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 36%);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary-soft), transparent 20%), var(--color-surface-raised));
    box-shadow: var(--shadow-xs);
  }

  .home-preview-card span,
  .home-preview-card small {
    color: var(--color-muted);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-preview-card small {
    font-size: 0.74rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    text-transform: none;
  }

  .home-preview-card strong {
    color: var(--color-text);
    font-size: clamp(1rem, 2.3vw, 1.35rem);
    font-weight: 720;
    letter-spacing: -0.055em;
    line-height: 1.1;
  }

  .home-sections {
    margin-top: clamp(1.5rem, 5vw, 3rem);
  }

  .home-sections__heading {
    display: grid;
    gap: 0.55rem;
    max-width: 54rem;
  }

  .home-sections__heading h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.2rem, 8vw, 5.6rem);
    font-weight: 600;
    line-height: 0.88;
    letter-spacing: -0.095em;
  }

  .home-sections__heading p:not(.home-hero__eyebrow) {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    font-weight: 420;
    line-height: 1.58;
    letter-spacing: -0.025em;
  }

  .home-feature-grid {
    display: grid;
    gap: 0.9rem;
  }

  .home-feature-card {
    display: grid;
    gap: 0.85rem;
    min-height: 12rem;
    padding: clamp(1rem, 3vw, 1.25rem);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-2xl);
    background: var(--panel-background);
    box-shadow: var(--shadow-xs);
  }

  .home-feature-card span {
    display: inline-flex;
    width: fit-content;
    color: var(--color-primary);
    font-size: 0.95rem;
    font-weight: 420;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .home-feature-card h3 {
    margin: auto 0 0;
    color: var(--color-text);
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 620;
    line-height: 1;
    letter-spacing: -0.07em;
  }

  .home-feature-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    font-weight: 420;
    line-height: 1.55;
    letter-spacing: -0.02em;
  }

  @media (min-width: 760px) {
    .home-hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(17rem, 0.65fr);
      min-height: min(640px, calc(100vh - 9rem));
    }

    .home-feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1040px) {
    .home-feature-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
