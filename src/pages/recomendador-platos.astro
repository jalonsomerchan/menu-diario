---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import DishRecommenderApp from '../components/DishRecommenderApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useDishRecommenderTranslations } from '../i18n/dish-recommender';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
const tr = useDishRecommenderTranslations(locale);
---

<BaseLayout title={`${tr('title')} · ${siteConfig.name}`} description={tr('description')} locale={locale}>
  <AppPageShell locale={locale} title={tr('title')} description={tr('description')}>
    <DishRecommenderApp locale={locale} />
  </AppPageShell>
</BaseLayout>
