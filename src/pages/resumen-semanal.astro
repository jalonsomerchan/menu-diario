---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import WeeklySummaryApp from '../components/WeeklySummaryApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('summary.title')} · ${siteConfig.name}`} description={t('summary.description')} locale={locale}>
  <Container class="py-4 sm:py-6">
    <WeeklySummaryApp locale={locale} />
  </Container>
</BaseLayout>
