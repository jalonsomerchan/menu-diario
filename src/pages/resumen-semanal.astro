---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppPageShell from '../components/AppPageShell.astro';
import WeeklySummaryApp from '../components/WeeklySummaryApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('summary.title')} · ${siteConfig.name}`} description={t('summary.description')} locale={locale}>
  <AppPageShell locale={locale} title={t('summary.title')} description={t('summary.description')}>
    <WeeklySummaryApp locale={locale} />
  </AppPageShell>
</BaseLayout>
