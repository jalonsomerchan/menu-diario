---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import TuppersApp from '../components/TuppersApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
---

<BaseLayout title={`${t('tuppers.title')} · ${siteConfig.name}`} description={t('tuppers.description')} locale={locale}>
  <Container class="py-4 sm:py-6">
    <TuppersApp locale={locale} />
  </Container>
</BaseLayout>
